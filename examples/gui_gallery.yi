cask gui_gallery

bring stdr
bring cogito

def app = cogito.app()
def ?drawing_tool = "Pen"
def ?shape_phase = 0.0
def ?shape_paused = true
def ?shape_armed = false
def ?shape_timer_id = 0
def ?shape_instruction_text = "5 - Inhale"

macro clicked_message() (( string )) {
    "Button clicked."
}

: build_page(title = string, blurb = string) (( cogito.VStack )) {
    let vstack = cogito.vstack()
    .set_vexpand(true)
    .set_hexpand(true)
    .set_gap(12)
    .set_padding(0, 18, 0, 18)

    let info = cogito.label(blurb)
    .set_class("body")
    .set_wrap(true)
    .set_hexpand(true)
    .set_padding(0, 0, 24, 0)
    vstack.add(info)

    return vstack
}

: build_button_page() (( cogito.VStack )) {
    let vstack = build_page("Button", "Buttons trigger immediate actions. This page showcases all button variants, sizes, and states.")

    let status = cogito.label("Tap a button to update this status.")
    .set_class("body")
    .set_wrap(true)
    .set_hexpand(true)
    vstack.add(status)

    -- Section: Button Styles
    let styles_label = cogito.label("Styles")
    .set_class("heading")
    vstack.add(styles_label)

    let styles_row = cogito.hstack()
    .set_gap(12)
    .set_hexpand(true)

    : make_style_handler(label = string) (( -> )) {
        return (b = cogito.Button) => {
            status.set_text(label !clicked_message)
        }
    }

    let filled = cogito.button("Filled")
    .on_click(make_style_handler("Filled"))
    styles_row.add(filled)

    let outlined = cogito.button("Outlined")
    .set_class("outlined")
    .on_click(make_style_handler("Outlined"))
    styles_row.add(outlined)

    let text_btn = cogito.button("Text")
    .set_class("text")
    .on_click(make_style_handler("Text"))
    styles_row.add(text_btn)

    vstack.add(styles_row)

    -- Section: Button Size Dropdown
    let size_dd_label = cogito.label("Size Selector")
    .set_class("heading")
    vstack.add(size_dd_label)

    let size_dd_row = cogito.hstack()
    .set_gap(12)
    .set_hexpand(true)

    let size_dd = cogito.dropdown()
    .set_items(["XS", "S", "M", "L", "XL"])
    .set_selected(2)
    size_dd_row.add(size_dd)

    let sized_btn = cogito.button("Dynamic Size")
    .set_size(2)
    .on_click((b = cogito.Button) => {
        status.set_text("Dynamic button clicked!")
    })
    size_dd_row.add(sized_btn)

    size_dd.on_change((d = cogito.Dropdown) => {
        let ?sel = d.selected()
        sized_btn.set_size(sel)
        status.set_text("Button size changed to: $$sel$$")
    })

    vstack.add(size_dd_row)

    -- Section: Disabled States
    let disabled_label = cogito.label("Disabled States")
    .set_class("heading")
    vstack.add(disabled_label)

    let disabled_row = cogito.hstack()
    .set_gap(12)
    .set_hexpand(true)

    let disabled_filled = cogito.button("Filled")
    .set_disabled(true)
    disabled_row.add(disabled_filled)

    let disabled_outlined = cogito.button("Outlined")
    .set_class("outlined")
    .set_disabled(true)
    disabled_row.add(disabled_outlined)

    let disabled_text = cogito.button("Text")
    .set_class("text")
    .set_disabled(true)
    disabled_row.add(disabled_text)

    vstack.add(disabled_row)

    return vstack
}

: build_iconbtn_page() (( cogito.VStack )) {
    let vstack = build_page("Icon Button", "Icon buttons come in 4 color styles (Filled, Tonal, Outlined, Iconic), 2 shapes (Circle, Rounded Square), and 3 widths (Narrow, Default, Wide).")

    let status = cogito.label("Tap an icon button.")
    .set_class("body")
    vstack.add(status)

    -- Section: Color Style Selector
    let color_label = cogito.label("Color Style")
    .set_class("heading")
    vstack.add(color_label)

    let color_dd = cogito.dropdown()
    .set_items(["Filled", "Tonal", "Outlined", "Iconic"])
    .set_selected(0)
    vstack.add(color_dd)

    -- Section: Shape Selector
    let shape_label = cogito.label("Shape")
    .set_class("heading")
    vstack.add(shape_label)

    let shape_dd = cogito.dropdown()
    .set_items(["Circle", "Rounded Square"])
    .set_selected(0)
    vstack.add(shape_dd)

    -- Section: Size Selector
    let size_label = cogito.label("Size")
    .set_class("heading")
    vstack.add(size_label)

    let size_dd = cogito.dropdown()
    .set_items(["XS", "S", "M", "L", "XL"])
    .set_selected(2)
    vstack.add(size_dd)

    -- Section: Width Selector
    let width_label = cogito.label("Width")
    .set_class("heading")
    vstack.add(width_label)

    let width_dd = cogito.dropdown()
    .set_items(["Narrow", "Default", "Wide"])
    .set_selected(1)
    vstack.add(width_dd)

    -- Interactive Icon Button
    let preview_label = cogito.label("Interactive Preview")
    .set_class("heading")
    vstack.add(preview_label)

    let btn_row = cogito.hstack()
    .set_hexpand(true)
    .set_gap(12)

    let icon_btn = cogito.iconbtn("sf:star.fill")
    .set_color_style(0)
    .set_shape(0)
    .set_width(1)
    .set_size(2)
    .on_click((b = cogito.IconButton) => {
        status.set_text("Icon button clicked!")
    })
    btn_row.add(icon_btn)

    let toggle_btn = cogito.iconbtn("sf:heart")
    .set_color_style(0)
    .set_shape(0)
    .set_width(1)
    .set_size(2)
    .set_toggle(true)
    .on_click((b = cogito.IconButton) => {
        let state = if b.checked() { "on" } else { "off" }
        status.set_text("Toggle: $$state$$")
    })
    btn_row.add(toggle_btn)

    vstack.add(btn_row)

    -- Update handlers
    color_dd.on_change((d = cogito.Dropdown) => {
        let sel = d.selected()
        icon_btn.set_color_style(sel)
        toggle_btn.set_color_style(sel)
        status.set_text("Color style changed.")
    })

    shape_dd.on_change((d = cogito.Dropdown) => {
        let sel = d.selected()
        icon_btn.set_shape(sel)
        toggle_btn.set_shape(sel)
        status.set_text("Shape changed.")
    })

    size_dd.on_change((d = cogito.Dropdown) => {
        let sel = d.selected()
        icon_btn.set_size(sel)
        toggle_btn.set_size(sel)
        status.set_text("Size changed.")
    })

    width_dd.on_change((d = cogito.Dropdown) => {
        let sel = d.selected()
        icon_btn.set_width(sel)
        toggle_btn.set_width(sel)
        status.set_text("Width changed.")
    })

    return vstack
}

: build_textfield_page() (( cogito.VStack )) {
    let vstack = build_page("TextField", "TextField is a single-line editable input for concise text entry.")

    let status = cogito.label("Current value: ")
    .set_class("body")
    vstack.add(status)

    let tf = cogito.textfield("Label text")
    .set_hexpand(true)
    .set_hint("Supporting text")
    tf.on_change((field = cogito.TextField) => {
        let txt = field.text()
        status.set_text("Current value: $$txt$$")
    })
    vstack.add(tf)

    let filled = cogito.textfield("Filled state")
    .set_hexpand(true)
    filled.set_text("Input text")
    vstack.add(filled)

    let counter = cogito.textfield("With character counter")
    .set_hexpand(true)
    .set_hint("0/20")
    counter.on_change((field = cogito.TextField) => {
        let ?n = len(field.text())
        let ?shown = if n > 20 { 20 } else { n }
        let txt = field.text()
        field.set_hint("$$shown$$ / 20")
        status.set_text("Current value: $$txt$$")
    })
    vstack.add(counter)

    let disabled = cogito.textfield("Disabled")
    .set_hexpand(true)
    .set_hint("Supporting text")
    .set_disabled(true)
    disabled.set_text("Read-only value")
    vstack.add(disabled)

    let non_editable = cogito.textfield("Not editable")
    .set_hexpand(true)
    .set_hint("Supporting text")
    .set_editable(false)
    non_editable.set_text("Focusable layout, editing off")
    vstack.add(non_editable)

    let note = cogito.label("Tip: helper + counter can be combined in one hint using two lines.")
    .set_class("caption")
    .set_wrap(true)
    vstack.add(note)

    return vstack
}

: build_searchfield_page() (( cogito.VStack )) {
    let vstack = build_page("SearchField", "SearchField is optimized for query text with search-focused styling and behavior.")

    let status = cogito.label("Query: ")
    .set_class("body")
    vstack.add(status)

    let sf = cogito.searchfield("Search…")
    .set_hexpand(true)
    sf.on_change((field = cogito.SearchField) => {
        let txt = field.text()
        status.set_text("Query: $$txt$$")
    })
    vstack.add(sf)

    return vstack
}

: build_textview_page() (( cogito.VStack )) {
    let vstack = build_page("TextView", "TextView is a multi-line editable area suitable for notes and longer text.")

    let status = cogito.label("Edit the text view to trigger change notifications.")
    .set_class("body")
    .set_wrap(true)
    .set_hexpand(true)
    vstack.add(status)

    let tv = cogito.textview("Multi-line text view")
    .set_hexpand(true)
    tv.on_change((field = cogito.TextView) => {
        status.set_text("TextView changed.")
    })
    vstack.add(tv)

    return vstack
}

: build_checkbox_page() (( cogito.VStack )) {
    let vstack = build_page("Checkbox", "Checkboxes capture independent yes/no selections.")

    let status = cogito.label("Toggle a checkbox.")
    .set_class("body")
    vstack.add(status)

    let cb1 = cogito.checkbox("Enable notifications", null)
    cb1.on_change((c = cogito.Checkbox) => {
        let ?chk = c.checked()
        status.set_text("Enable notifications: $$chk$$")
    })
    vstack.add(cb1)

    let cb2 = cogito.checkbox("Sync in background", null)
    cb2.on_change((c = cogito.Checkbox) => {
        let ?chk = c.checked()
        status.set_text("Sync in background: $$chk$$")
    })
    vstack.add(cb2)

    let divider = cogito.divider("", false)
    vstack.add(divider)

    let group = cogito.checkbox("", null) -- Grouper
    let cb3 = cogito.checkbox("Dark mode", group)
    let cb4 = cogito.checkbox("Light mode", group)
    cb3.on_change((c = cogito.Checkbox) => {
        let ?chk = c.checked()
        status.set_text("Dark mode: $$chk$$")
    })
    cb4.on_change((c = cogito.Checkbox) => {
        let ?chk = c.checked()
        status.set_text("Light mode: $$chk$$")
    })
    vstack.add(cb3)
    vstack.add(cb4)

    return vstack
}

: build_switch_page() (( cogito.VStack )) {
    let vstack = build_page("Switch", "Switches represent immediate on/off state and are ideal for settings toggles.")

    let status = cogito.label("Switch is off.")
    .set_class("body")
    vstack.add(status)

    let sw = cogito.switch("Airplane Mode")
    .on_change((s = cogito.Switch) => {
        let ?on = if s.checked() { "on" } else { "off" }
        status.set_text("Switch is $$on$$.")
    })
    vstack.add(sw)

    let sw2 = cogito.switch("Dark Mode")
    .set_checked(true)
    .on_change((s = cogito.Switch) => {
        let ?on = if s.checked() { "on" } else { "off" }
        status.set_text("Switch is $$on$$.")
    })
    vstack.add(sw2)

    return vstack
}

: build_slider_page() (( cogito.VStack )) {
    let vstack = build_page("Slider", "Sliders let users choose a value along a continuous range.")

    let status = cogito.label("Value: 50")
    .set_class("body")
    vstack.add(status)

    -- Standard Slider
    let standard_label = cogito.label("Standard Slider (0-100)")
    .set_class("heading")
    vstack.add(standard_label)

    let sl = cogito.slider(0, 100, 50)
    .set_hexpand(true)
    sl.on_change((s = cogito.Slider) => {
        let v = s.value()
        status.set_text("Value: $$v$$")
    })
    vstack.add(sl)

    -- Range Slider
    let range_label = cogito.label("Range Slider (10-90)")
    .set_class("heading")
    vstack.add(range_label)

    let range_status = cogito.label("Range: 10 - 90")
    .set_class("body")
    vstack.add(range_status)

    let range_slider = cogito.slider(0, 100, 50)
    .set_hexpand(true)
    .set_range(10, 90)
    range_slider.on_change((s = cogito.Slider) => {
        let start = s.range_start()
        let end = s.range_end()
        range_status.set_text("Range: $$start$$ - $$end$$")
    })
    vstack.add(range_slider)

    -- Discrete Slider
    let discrete_label = cogito.label("Discrete Slider (step 10, centered at 0)")
    .set_class("heading")
    vstack.add(discrete_label)

    let discrete_status = cogito.label("Centered value: 0")
    .set_class("body")
    vstack.add(discrete_status)

    let discrete_slider = cogito.slider(-100, 100, 0)
    .set_hexpand(true)
    .set_centered(true)
    .set_step(10)
    .set_step_dots(true)
    discrete_slider.on_change((s = cogito.Slider) => {
        let v = s.value()
        discrete_status.set_text("Centered value: $$v$$")
    })
    vstack.add(discrete_slider)

    return vstack
}

: build_stepper_page() (( cogito.VStack )) {
    let vstack = build_page("Stepper", "Steppers provide precise incremental adjustments using +/- controls.")

    let status = cogito.label("Value: 0")
