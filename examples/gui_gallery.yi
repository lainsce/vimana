}

: build_drawing_area_page() (( cogito.VStack )) {
    let vstack = build_page("DrawingArea", "DrawingArea captures press, drag, and release gestures. Use the pen toggle and eraser to switch tools.")

    let status = cogito.label("Tool - Pen | Event - Idle | Pointer - (0, 0)")
    .set_class("body")
    vstack.add(status)

    let hint = cogito.label("Press inside the area, drag continuously, then release. Status updates on every drag event.")
    .set_class("caption")
    .set_wrap(true)
    vstack.add(hint)

    drawing_tool = "Pen"

    let pen_btn = cogito.iconbtn("sf:pencil")
    .set_toggle(true)
    .set_checked(true)
    .on_click((b = cogito.IconButton) => {
        b.set_checked(true)
        drawing_tool = "Pen"
        status.set_text("Tool - Pen | Event - Tool Changed")
    })

    let eraser_btn = cogito.iconbtn("sf:eraser")
    .set_toggle(true)
    .set_checked(false)
    .on_click((b = cogito.IconButton) => {
        b.set_checked(true)
        pen_btn.set_checked(false)
        drawing_tool = "Eraser"
        status.set_text("Tool - Eraser | Event - Tool Changed")
    })

    let area_row = cogito.hstack()
    .set_hexpand(true)
    .set_gap(12)

    area_row.add(cogito.label("").set_hexpand(true))

    let area = cogito.drawing_area()
    .set_class("outlined")
    .set_hexpand(true)
    .on_press((a = cogito.DrawingArea) => {
        let tool = drawing_tool
        let ?x = a.get_x()
        let ?y = a.get_y()
        status.set_text("Tool - $$tool$$ | Event - Press | Pointer - ( $$x$$, $$y$$ )")
    })
    .on_drag((a = cogito.DrawingArea) => {
        let tool = drawing_tool
        let ?x = a.get_x()
        let ?y = a.get_y()
        status.set_text("Tool - $$tool$$ | Event - Drag | Pointer - ( $$x$$, $$y$$ )")
    })
    .on_release((a = cogito.DrawingArea) => {
        let tool = drawing_tool
        let ?x = a.get_x()
        let ?y = a.get_y()
        status.set_text("Tool - $$tool$$ | Event - Release | Pointer - ( $$x$$, $$y$$ )")
    })
    area_row.add(area)

    area_row.add(cogito.label("").set_hexpand(true))
    vstack.add(area_row)

    let controls = cogito.hstack()
    .set_hexpand(true)
    .set_gap(12)

    controls.add(cogito.label("").set_hexpand(true))
    controls.add(pen_btn)
    controls.add(eraser_btn)

    controls.add(cogito.label("").set_hexpand(true))
    vstack.add(controls)

    return vstack
}

: session_breath_multiplier(phase = num, min_multiplier = num) (( num )) {
    if phase < 0.25 {
        return min_multiplier + (phase * 4.0) * (1.0 - min_multiplier)
    } elif phase < 0.5 {
        return 1.0
    } elif phase < 0.75 {
        return 1.0 - ((phase - 0.5) * 4.0) * (1.0 - min_multiplier)
    }
    return min_multiplier
}

: session_countdown5(progress = num) (( num )) {
    let p = progress * 5.0
    if p < 1.0 { return 5 }
    elif p < 2.0 { return 4 }
    elif p < 3.0 { return 3 }
    elif p < 4.0 { return 2 }
    return 1
}

: session_wrap_phase(v = num) (( num )) {
    if v >= 1.0 { return v - 1.0 }
    return v
}

: session_add(a = num, b = num) (( num )) {
    return a + b
}

: session_phase_label(phase = num) (( string )) {
    if phase < 0.25 {
        return "Inhale"
    } elif phase < 0.5 {
        return "Hold"
    } elif phase < 0.75 {
        return "Exhale"
    }
    return "Hold"
}

: session_phase_progress(phase = num) (( num )) {
    if phase < 0.25 {
        return phase * 4.0
    } elif phase < 0.5 {
        return (phase - 0.25) * 4.0
    } elif phase < 0.75 {
        return (phase - 0.5) * 4.0
    }
    return (phase - 0.75) * 4.0
}

: session_layer_size(base_size = num, phase = num, min_multiplier = num, layer_index = num, layer_count = num) (( num )) {
    let lag = layer_index * 0.015
    let staggered_phase = if phase >= lag { phase - lag } else { phase - lag + 1.0 }
    let mult = session_breath_multiplier(staggered_phase, min_multiplier)
    let radius_factor = 1.0 - (0.9 * layer_index / (layer_count - 1.0))
    let size = base_size * radius_factor * mult
    if size < 24.0 { return 24.0 }
    return size
}

: session_apply_scaled_vertices(target = cogito.Shape, template = cogito.Shape, scale = num) (( -- )) {
    let ?s = scale
    if s < 0.01 { s = 0.01 }
    if s > 1.0 { s = 1.0 }
    for (let ?i = 0; i < 128; i += 1) {
        let ?bx = template.get_vertex_x(i)
        let ?by = template.get_vertex_y(i)
        let ?x = 0.5 + (bx - 0.5) * s
        let ?y = 0.5 + (by - 0.5) * s
        target.set_vertex(i, x, y)
    }
}

: build_shape_gallery_page() (( cogito.VStack )) {
    let vstack = build_page("Shape Gallery", "Breathing Flower Animation with 18 layers of shapes.")

    let section = cogito.label("Shape Breathing Animation")
    .set_class("heading")
    vstack.add(section)

    shape_instruction_text = "5 - Inhale"
    let instruction = cogito.label(shape_instruction_text)
    .set_class("body")
    vstack.add(instruction)

    if shape_timer_id != 0 {
        cogito.clear_timer(shape_timer_id)
        shape_timer_id = 0
    }
    shape_phase = 0.0
    shape_paused = true
    shape_armed = false
    let min_multiplier = 0.6
    let layer_count = 18.0
    let base_size = 256.0

    -- Create 18 flower layers with different colors
    let layers = [
        cogito.shape(27).set_size(256).set_color("#23398D"),
        cogito.shape(27).set_size(256).set_color("#2E4A9E"),
        cogito.shape(27).set_size(256).set_color("#3A5BAF"),
        cogito.shape(27).set_size(256).set_color("#466CC0"),
        cogito.shape(27).set_size(256).set_color("#527DD1"),
        cogito.shape(27).set_size(256).set_color("#5E8EE2"),
        cogito.shape(27).set_size(256).set_color("#6A9FF3"),
        cogito.shape(27).set_size(256).set_color("#76B0FF"),
        cogito.shape(27).set_size(256).set_color("#82C1FF"),
        cogito.shape(27).set_size(256).set_color("#8ED2FF"),
        cogito.shape(27).set_size(256).set_color("#9AE3FF"),
        cogito.shape(27).set_size(256).set_color("#A6F4FF"),
        cogito.shape(27).set_size(256).set_color("#B0B5FE"),
        cogito.shape(27).set_size(256).set_color("#C0C5FF"),
        cogito.shape(27).set_size(256).set_color("#D0D5FF"),
        cogito.shape(27).set_size(256).set_color("#E0E5FF"),
        cogito.shape(27).set_size(256).set_color("#E3ED86"),
        cogito.shape(27).set_size(256).set_color("#F0F5A0")
    ]
    let layer_bases = [
        cogito.shape(27).set_size(256), cogito.shape(27).set_size(256),
        cogito.shape(27).set_size(256), cogito.shape(27).set_size(256),
        cogito.shape(27).set_size(256), cogito.shape(27).set_size(256),
        cogito.shape(27).set_size(256), cogito.shape(27).set_size(256),
        cogito.shape(27).set_size(256), cogito.shape(27).set_size(256),
        cogito.shape(27).set_size(256), cogito.shape(27).set_size(256),
        cogito.shape(27).set_size(256), cogito.shape(27).set_size(256),
        cogito.shape(27).set_size(256), cogito.shape(27).set_size(256),
        cogito.shape(27).set_size(256), cogito.shape(27).set_size(256)
    ]

    let anchor = cogito.shape(27).set_size(256).set_color("transparent")

    let render = () => {
        let wrapped = session_wrap_phase(shape_phase)

        let progress = session_phase_progress(wrapped)
        let second = session_countdown5(progress)
        let instruction_text = session_phase_label(wrapped)
        let next_instruction = "$$second$$ - $$instruction_text$$"
        if next_instruction != shape_instruction_text {
            shape_instruction_text = next_instruction
            instruction.set_text(next_instruction)
        }

        for (let ?i = 0; i < 18; i += 1) {
            let layer = layers[i]
            let base = layer_bases[i]
            let idx = i * 1.0
            let lag = idx * 0.015
            let shifted = if wrapped >= lag { wrapped - lag } else { wrapped - lag + 1.0 }
            let phase01 = if shifted < 0.5 { shifted * 2.0 } else { (1.0 - shifted) * 2.0 }
            let mult = min_multiplier + phase01 * (1.0 - min_multiplier)
            let radius_factor = 1.0 - (0.9 * idx / (layer_count - 1.0))
            let ?layer_size = base_size * radius_factor * mult
            if layer_size < 24.0 { layer_size = 24.0 }
            let scale = layer_size / base_size
            session_apply_scaled_vertices(layer, base, scale)
        }
    }

    let tick = () => {
        shape_phase = session_wrap_phase(session_add(shape_phase, 0.002))
        render()
    }

    let stop_timer = () => {
        if shape_timer_id != 0 {
            cogito.clear_timer(shape_timer_id)
            shape_timer_id = 0
        }
    }
    let start_timer = () => {
        if shape_timer_id == 0 && shape_armed && !shape_paused {
            shape_timer_id = cogito.set_interval_for(anchor, 50, () => {
                tick()
            })
        }
    }

    let stack = cogito.zstack()
    .set_align(4)
    .set_hexpand(true)
    .add(anchor)

    -- Add all 18 layers to the stack (innermost first)
    for (let ?i = 0; i < 18; i += 1) {
        let layer = layers[i]
        stack.add(layer)
    }

    render()
    vstack.add(stack)

    let controls = cogito.hstack()
    .set_gap(12)

    let play_button = cogito.button("Play")
    .set_class("filled")
    .on_click((b = cogito.Button) => {
        shape_armed = true
        shape_paused = false
        tick()
        start_timer()
    })
    controls.add(play_button)

    let pause_button = cogito.button("Pause / Resume")
    .set_class("outlined")
    .on_click((b = cogito.Button) => {
        if shape_armed {
            let now_paused = !shape_paused
            shape_paused = now_paused
            if now_paused {
                stop_timer()
            } else {
                start_timer()
            }
        }
    })
    controls.add(pause_button)

    let reset_button = cogito.button("Reset")
    .set_class("text")
    .on_click((b = cogito.Button) => {
        shape_phase = 0.0
        shape_paused = true
        shape_armed = false
        shape_instruction_text = "5 - Inhale"
        instruction.set_text(shape_instruction_text)
        stop_timer()
        render()
    })
    controls.add(reset_button)
    vstack.add(controls)

    return vstack
}

