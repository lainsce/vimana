: build_fabmenu_page() (( cogito.VStack )) {
    let vstack = build_page("FABMenu", "FABMenu combines a Floating Action Button with a menu of related actions.")

    let status = cogito.label("Tap a FAB.")
    .set_class("body")
    .set_wrap(true)
    .set_hexpand(true)
    vstack.add(status)

    -- Section: Variant Selector
    let variant_label = cogito.label("Variant")
    .set_class("heading")
    vstack.add(variant_label)

    let variant_dd = cogito.dropdown()
    .set_items(["Primary", "Secondary", "Tertiary"])
    .set_selected(0)
    vstack.add(variant_dd)

    -- Section: Size Selector
    let size_label = cogito.label("Size")
    .set_class("heading")
    vstack.add(size_label)

    let size_dd = cogito.dropdown()
    .set_items(["S", "M", "L"])
    .set_selected(1)
    vstack.add(size_dd)

    let fabmenu = cogito.fab_menu("plus")
    .set_color(0)
    .set_size(1)
    .set_hexpand(true)
    .set_vexpand(true)
    .add_item("Info", "info", (b = any) => {
        status.set_text("Info action selected.")
    })
    .add_item("Edit", "pencil", (b = any) => {
        status.set_text("Edit action selected.")
    })
    .add_item("Delete", "trash", (b = any) => {
        status.set_text("Delete action selected.")
    })
    vstack.add(fabmenu)

    variant_dd.on_change((d = cogito.Dropdown) => {
        let ?sel = d.selected()
        fabmenu.set_color(sel)
        status.set_text("FAB Menu variant changed.")
    })

    size_dd.on_change((d = cogito.Dropdown) => {
        let ?sel = d.selected()
        fabmenu.set_size(sel)
        status.set_text("FAB Menu size changed.")
    })

    return vstack
}

