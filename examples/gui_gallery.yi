: build_toolbar_page() (( cogito.VStack )) {
    let vstack = build_page("Toolbar", "Toolbars support six slot-based actions; docked and floating variants share the same slot model.")

    let dock_label = cogito.label("Docked")
    .set_class("body")
    vstack.add(dock_label)

    let docked = cogito.toolbar()
    .set_hexpand(true)
    .add(cogito.iconbtn("archivebox").set_class("iconic"))
    .add(cogito.iconbtn("trash").set_class("iconic"))
    .add(cogito.iconbtn("photo").set_class("iconic"))
    .add(cogito.iconbtn("clock").set_class("iconic"))
    .add(cogito.iconbtn("star").set_class("iconic"))
    .add(cogito.menu_button("ellipsis"))
    vstack.add(docked)

    let float_label = cogito.label("Floating")
    .set_class("body")
    vstack.add(float_label)

    let floating = cogito.toolbar()
    .set_class("floating")
    .set_hexpand(true)
    .add(cogito.iconbtn("sf:textformat.bold").set_class("iconic"))
    .add(cogito.iconbtn("sf:textformat.italic").set_class("iconic"))
    .add(cogito.iconbtn("sf:textformat.underline").set_class("iconic"))
    .add(cogito.iconbtn("sf:textformat").set_class("iconic"))
    .add(cogito.iconbtn("sf:paintbrush").set_class("iconic"))
    .add(cogito.menu_button("sf:ellipsis"))
    vstack.add(floating)

    let compact_label = cogito.label("Floating Compact")
    .set_class("body")
    vstack.add(compact_label)

    let compact_wrap = cogito.hstack()
    .set_hexpand(true)
    .set_gap(8)

    let compact = cogito.toolbar()
    .set_class("floating_compact")
    .add(cogito.iconbtn("sf:checkmark.square").set_class("iconic"))
    .add(cogito.iconbtn("sf:paintbrush").set_class("iconic"))
    .add(cogito.iconbtn("sf:mic").set_class("iconic"))
    .add(cogito.iconbtn("sf:photo").set_class("iconic"))

    let add_btn = cogito.fab("plus")
    .set_class("toolbar_plus")
    .set_valign(1)

    compact.add(add_btn)
    compact_wrap.add(compact)
    vstack.add(compact_wrap)

    let vibrant_wrap = cogito.hstack()
    .set_hexpand(true)
    .set_gap(8)

    let vibrant = cogito.toolbar()
    .set_vibrant(true)
    .set_vertical(true)
    .set_class("floating_compact")
    .add(cogito.iconbtn("sf:checkmark.square").set_class("iconic"))
    .add(cogito.iconbtn("sf:paintbrush").set_class("iconic"))
    .add(cogito.iconbtn("sf:mic").set_class("iconic"))
    .add(cogito.iconbtn("sf:photo").set_class("iconic"))
    .add(cogito.menu_button("sf:ellipsis").set_class("tertiary"))

    vibrant_wrap.add(vibrant)
    vstack.add(vibrant_wrap)

    return vstack
}

: build_dialog_page() (( cogito.VStack )) {
    let vstack = build_page("Dialog", "Dialogs interrupt normal flow to request confirmation or gather focused input.")

    let status = cogito.label("Open the dialog to continue.")
    .set_class("body")
    .set_wrap(true)
    .set_hexpand(true)
    vstack.add(status)

    let show_btn = cogito.button("Show Dialog")
    vstack.add(show_btn)

    let slot = cogito.dialog_slot()
    vstack.add(slot)

    show_btn.on_click((b = cogito.Button) => {
        let dlg = cogito.dialog("")

        let top = cogito.vstack()
        .set_hexpand(true)
        .set_gap(6)
        .add(cogito.iconbtn("sf:photo")
            .set_class("iconic")
            .set_halign(1)
            .set_disabled(true))
            .add(cogito.label("Delete selected files?")
                .set_halign(1))
            .add(cogito.label("This test dialog previews final layout and spacing.")
                .set_class("body"))
            .add(cogito.label("Selected files are moved to Trash and can be restored.")
                .set_class("body"))
            .add(cogito.label("Use the action buttons below to close this test dialog.")
                .set_class("body"))

        let custom = cogito.vstack()
        .set_hexpand(true)
        .set_vexpand(true)
        .set_padding(12, 0, 12, 0)
        .add(cogito.label("Custom Content (Test Area)")
            .set_class("body")
            .set_halign(1)
            .set_valign(1))

            let actions = cogito.hstack()
            .set_gap(12)
            .set_align(2)
        .add(cogito.button("Dismiss")
            .set_class("text")
            .on_click((db = cogito.Button) => {
                dlg.close()
                status.set_text("Dialog dismissed.")
            }))
        .add(cogito.button("Close")
            .set_class("text")
            .on_click((cb = cogito.Button) => {
                dlg.close()
                status.set_text("Dialog closed.")
            }))

        dlg.add(top)
        dlg.add(custom)
        dlg.add(actions)
        slot.show(dlg)
        status.set_text("Dialog opened.")
    })

    return vstack
}

: build_toast_page() (( cogito.VStack )) {
    let vstack = build_page("Toast", "Toasts provide lightweight, temporary notifications without blocking interaction.")

    let status = cogito.label("Show a toast notification.")
    .set_class("body")
    .set_wrap(true)
    .set_hexpand(true)
    vstack.add(status)

    let btn = cogito.button("Show Toast")
    vstack.add(btn)

    let toasts = cogito.toasts()
    vstack.add(toasts)

    btn.on_click((b = cogito.Button) => {
        let t = cogito.toast("Saved. Click me to acknowledge.")
        t.on_click((tt = cogito.Toast) => {
            status.set_text("Toast clicked.")
        })
        toasts.add(t)
        status.set_text("Toast shown.")
    })

    return vstack
}

: build_treeview_page() (( cogito.VStack )) {
    let vstack = build_page("TreeView", "TreeView shows hierarchical content where branches can be expanded or collapsed.")

    let tree = cogito.treeview()
    .set_hexpand(true)
    .set_vexpand(true)

    let branch_files = cogito.vstack()
    .set_class("files")
    .add(cogito.button("README.md"))
    .add(cogito.button("LICENSE"))

    let branch_src = cogito.vstack()
    .set_class("src")
    .add(cogito.button("cogito.c"))
    .add(cogito.button("theme.sum"))

    tree.add(branch_files)
    tree.add(branch_src)
    vstack.add(tree)

    return vstack
}

: build_card_page() (( cogito.VStack )) {
    let vstack = build_page("Card", "Cards group related content and actions within an elevated container. Choose a variant to change the elevation and fill.")

    let status = cogito.label("Select a card variant.")
    .set_class("body")
    vstack.add(status)

    -- Variant Selector
    let variant_label = cogito.label("Variant")
    .set_class("heading")
    vstack.add(variant_label)

    let variant_dd = cogito.dropdown()
    .set_items(["Elevated", "Filled", "Outlined"])
    .set_selected(0)
    vstack.add(variant_dd)

    -- Interactive Card
    let card = cogito.card("Release Notes")
    .set_hexpand(true)
    .set_class("elevated")

    let body = cogito.label("Version 1.0 includes improved layout, theming, and gallery structure.")
    .set_class("body")
    .set_wrap(true)
    .set_hexpand(true)
    card.add(body)

    let action = cogito.button("View Details")
    .set_class("outlined")
    .on_click((b = cogito.Button) => {
        status.set_text("Card action clicked!")
    })
    card.add(action)

    vstack.add(card)

    -- Variant update handler
    variant_dd.on_change((d = cogito.Dropdown) => {
        let sel = d.selected()
        let class_name = if sel == 0 { "elevated" } elif sel == 1 { "filled" } else { "outlined" }
        card.set_class(class_name)
        status.set_text("Card variant: $$class_name$$")
    })

    return vstack
}

: build_avatar_page() (( cogito.VStack )) {
    let vstack = build_page("Avatar", "Avatars represent people or entities through initials, icons, or images.")

    let status = cogito.label("Select an avatar type.")
    .set_class("body")
    vstack.add(status)

    -- Type Selector
    let type_label = cogito.label("Avatar Type")
    .set_class("heading")
    vstack.add(type_label)

    let type_dd = cogito.dropdown()
    .set_items(["Initials", "Icon", "Image"])
    .set_selected(0)
    vstack.add(type_dd)

    -- Interactive Avatar
    let avatar_row = cogito.hstack()
    .set_gap(12)
    .set_hexpand(true)

    let interactive_avatar = cogito.avatar("AB")
    avatar_row.add(interactive_avatar)

    vstack.add(avatar_row)

    -- Static Examples
    let examples_label = cogito.label("Examples")
    .set_class("heading")
    vstack.add(examples_label)

    let examples_row = cogito.hstack()
    .set_gap(12)
    .add(cogito.avatar("Alice"))
    .add(cogito.avatar("Bob"))
    .add(cogito.avatar("Charlie"))
    .add(cogito.avatar("sf:person"))

    vstack.add(examples_row)

    -- Type update handler
    type_dd.on_change((d = cogito.Dropdown) => {
        let sel = d.selected()
        if sel == 0 {
            status.set_text("Type: Initials")
        } elif sel == 1 {
            status.set_text("Type: Icon")
        } else {
            status.set_text("Type: Image")
        }
    })

    return vstack
}

