    .add(sidebar_item("Avatar"))
    .add(sidebar_item("Badge"))
    .add(sidebar_item("Banner"))
    .add(sidebar_item("Divider"))
    .add(sidebar_item("Image"))
    .add(sidebar_item("ActiveIndicator"))
    .add(sidebar_item("SwitchBar"))
    .add(sidebar_item("SplitButton"))
    .add(sidebar_item("MenuButton"))
    .add(sidebar_item("EmptyPage"))
    .add(sidebar_item("WelcomeScreen"))
    .add(sidebar_item("SettingsWindow"))
    .add(sidebar_item("ViewDual"))
    .add(sidebar_item("ViewChooser"))
    .add(sidebar_item("AboutWindow"))
    .add(sidebar_item("Typography"))
    .add(sidebar_item("SideSheet"))
    .add(sidebar_item("FAB Menu"))
    .add(sidebar_item("Ensor"))
    .add(sidebar_item("Revealer"))
    .add(sidebar_item("Bin"))
    .add(sidebar_item("DrawingArea"))
    .add(sidebar_item("Shape Gallery"))
    .on_select((idx) => {
        let vid = view_id_from_index(idx)
        views.set_active(vid)
        content_bar.set_title(view_title_from_index(idx))
    })

    let selected_idx = 0
    let initial_view = view_id_from_index(selected_idx)
    views.set_active(initial_view)
    content_bar.set_title(view_title_from_index(selected_idx))

    let sidebar_scroller = cogito.scroller()
    .set_class("sidebar")
    .set_axes(false, true)
    .add(sidebar_list)
    .set_hexpand(false)

    sidebar_bar.pair_with_scroller(sidebar_scroller)
    sidebar.add(sidebar_scroller)
    root.add(sidebar)

    let content = cogito.vstack()
    .set_hexpand(true)
    .set_vexpand(true)
    .add(content_bar)

    let content_scroller = cogito.scroller()
    .set_axes(false, true)
    .set_vexpand(true)
    .set_hexpand(true)
    .add(views)
    content_bar.pair_with_scroller(content_scroller)
    content.add(content_scroller)

    root.add(content)
    win.add(root)
}

entry () (( -- )) {
    let the_app = app
    the_app.set_appid("yis.cogito.Gallery")
    the_app.set_accent_color("#72dec2", false)

    let main_win = cogito.window_size("Cogito Gallery", 1024, 768)
    .build(build_ui)
    .set_a11y_label("Cogito Gallery")
    .set_resizable(true)
    .set_autosize(false)

    app.run(main_win)
}
