: add_typography_row(vstack = cogito.VStack, name = string, cls = string, sample = string, ypad = num) (( -- )) {
    let row = cogito.hstack()
    .set_hexpand(true)
    .set_gap(24)
    .set_padding(ypad, 0, ypad, 0)

    let left = cogito.label(name)
    .set_class("content-title")
    left.set_valign(1)
    row.add(left)

    let right = cogito.label(sample)
    right.set_class(cls)
    right.set_text_align(2)
    right.set_valign(1)
    right.set_hexpand(true)
    row.add(right)

    vstack.add(row)
}

: build_typography_page() (( cogito.VStack )) {
    let vstack = build_page("Typography", "Typography classes define consistent text rhythm for headings and content.")

    let font_controls = cogito.hstack()
    .set_hexpand(true)
    .set_gap(12)

    let baseline_font = cogito.fontbutton()
    .set_font("System Default")
    .set_hexpand(true)
    .set_a11y_label("Choose baseline font")
    baseline_font.on_change((btn = cogito.FontButton) => {
        let name = btn.font()
        if name == "System Default" {
            app.set_baseline_font("")
        } else {
            app.set_baseline_font(name)
        }
    })
    font_controls.add(baseline_font)

    let emphasized_font = cogito.fontbutton()
    .set_font("System Default")
    .set_hexpand(true)
    .set_a11y_label("Choose emphasized font")
    emphasized_font.on_change((btn = cogito.FontButton) => {
        let name = btn.font()
        if name == "System Default" {
            app.set_emphasized_font("")
        } else {
            app.set_emphasized_font(name)
        }
    })
    font_controls.add(emphasized_font)

    vstack.add(font_controls)

    let tabs = cogito.tabs()
    .set_items(["Baseline", "Emphasized"])
    .set_ids(["baseline", "emphasized"])
    .set_selected(0)
    .set_hexpand(true)
    vstack.add(tabs)

    let tab_views = cogito.view_switcher()
    .set_hexpand(true)
    .add("baseline", (vs = cogito.ViewSwitcher) => {
        let t = cogito.vstack().set_hexpand(true).set_gap(0)

        let header = cogito.hstack().set_hexpand(true).set_gap(24)
        header.add(cogito.label("Class").set_class("caption"))
        header.add(cogito.label("Sample").set_class("caption").set_text_align(2).set_hexpand(true))
        t.add(header)

        add_typography_row(t, "Big Display", "big-display", "Baseline, 56", 10)
        add_typography_row(t, "Display", "display", "Baseline, 36", 8)
        add_typography_row(t, "View Title", "view-title", "Baseline, 24", 6)
        add_typography_row(t, "View Subtitle", "view-subtitle", "Baseline, 18", 4)
        add_typography_row(t, "Heading", "heading", "Baseline, 16", 3)
        add_typography_row(t, "Content Title", "content-title", "Baseline, 16", 3)
        add_typography_row(t, "Content Subtitle", "content-subtitle", "Baseline, 14", 3)
        add_typography_row(t, "Body", "body", "Baseline, 14", 3)
        add_typography_row(t, "Caption", "caption", "Baseline, 12", 2)

        let tabular_row = cogito.hstack().set_hexpand(true).set_gap(24).set_padding(10, 0, 0, 0)
        tabular_row.add(cogito.label("Tabular").set_class("content-title").set_valign(1))
        tabular_row.add(cogito.label("09:41  001  128  999").set_class("tabular").set_text_align(2).set_valign(1).set_hexpand(true))
        t.add(tabular_row)

        let mono_row = cogito.hstack().set_hexpand(true).set_gap(24).set_padding(10, 0, 0, 0)
        mono_row.add(cogito.label("Monospace").set_class("content-title").set_valign(1))
        mono_row.add(cogito.label("$ bash ~/").set_class("monospace").set_text_align(2).set_valign(1).set_hexpand(true))
        t.add(mono_row)

        return t
    })
    .add("emphasized", (vs = cogito.ViewSwitcher) => {
        let t = cogito.vstack().set_hexpand(true).set_gap(0)

        let header = cogito.hstack().set_hexpand(true).set_gap(24)
        header.add(cogito.label("Class").set_class("caption"))
        header.add(cogito.label("Sample").set_class("caption").set_text_align(2).set_hexpand(true))
        t.add(header)

        add_typography_row(t, "Big Display", "big-display emphasized", "Emphasized, 56", 10)
        add_typography_row(t, "Display", "display emphasized", "Emphasized, 36", 8)
        add_typography_row(t, "View Title", "view-title emphasized", "Emphasized, 24", 6)
        add_typography_row(t, "View Subtitle", "view-subtitle emphasized", "Emphasized, 18", 4)
        add_typography_row(t, "Heading", "heading emphasized", "Emphasized, 16", 3)
        add_typography_row(t, "Content Title", "content-title emphasized", "Emphasized, 16", 3)
        add_typography_row(t, "Content Subtitle", "content-subtitle emphasized", "Emphasized, 14", 3)
        add_typography_row(t, "Body", "body emphasized", "Emphasized, 14", 3)
        add_typography_row(t, "Caption", "caption emphasized", "Emphasized, 12", 2)

        let tabular_row = cogito.hstack().set_hexpand(true).set_gap(24).set_padding(10, 0, 0, 0)
        tabular_row.add(cogito.label("Tabular").set_class("content-title").set_valign(1))
        tabular_row.add(cogito.label("09:41  001  128  999").set_class("tabular").set_text_align(2).set_valign(1).set_hexpand(true))
        t.add(tabular_row)

        let mono_row = cogito.hstack().set_hexpand(true).set_gap(24).set_padding(10, 0, 0, 0)
        mono_row.add(cogito.label("Monospace").set_class("content-title").set_valign(1))
        mono_row.add(cogito.label("$ bash ~/").set_class("monospace").set_text_align(2).set_valign(1).set_hexpand(true))
        t.add(mono_row)

        return t
    })
    .set_active("baseline")

    tabs.bind(tab_views)
    vstack.add(tab_views)

    return vstack
}

: build_side_sheet_page() (( cogito.VStack )) {
    let vstack = build_page("SideSheet", "SideSheet slides in from the right edge, useful for detail views or settings.")

    let status = cogito.label("Click the button to open a side sheet.")
    .set_class("body")
    .set_wrap(true)
    .set_hexpand(true)
    vstack.add(status)

    let button_row = cogito.hstack().set_gap(12)
    vstack.add(button_row)

    let open_modal_btn = cogito.button("Open Modal Side Sheet")
    .on_click((b = cogito.Button) => {
        let win = b.window()
        if win {
            let ss = cogito.side_sheet("Modal Details")
            ss.set_mode(0) -- COGITO_SIDE_SHEET_MODAL
            ss.add(cogito.label("This is a modal side sheet content."))
            win.set_side_sheet(ss)
        }
    })
    button_row.add(open_modal_btn)

    let open_inset_btn = cogito.button("Open Inset Side Sheet")
    .on_click((b = cogito.Button) => {
        let win = b.window()
        if win {
            let ss = cogito.side_sheet("Inset Details")
            ss.set_mode(1) -- COGITO_SIDE_SHEET_INSET
            ss.add(cogito.label("This is an inset side sheet content."))
            win.set_side_sheet(ss)
        }
    })
    button_row.add(open_inset_btn)

    let open_sidebar_btn = cogito.button("Open Sidebar")
    .on_click((b = cogito.Button) => {
        let win = b.window()
        if win {
            let ss = cogito.side_sheet("Sidebar")
            ss.set_mode(2) -- COGITO_SIDE_SHEET_SIDEBAR
            ss.add(cogito.label("This is sidebar content."))
            win.set_side_sheet(ss)
        }
    })
    button_row.add(open_sidebar_btn)

    -- Placeholder for where sidebar content would go
    let sidebar_placeholder = cogito.vstack()
    .set_hexpand(true)
    .add(cogito.label("Press 'Open Sidebar' to show the sidebar."))
    vstack.add(sidebar_placeholder)

    return vstack
}

: build_revealer_page() (( cogito.VStack )) {
    let vstack = build_page("Revealer", "Revealer toggles visibility of its children programmatically.")

    let status = cogito.label("Revealer children are visible.")
    .set_class("body")
    .set_wrap(true)
    .set_hexpand(true)
    vstack.add(status)

    let reveal_toggle = cogito.switch("Show revealer children")
    .set_checked(true)
    vstack.add(reveal_toggle)

    let revealer_content = cogito.vstack()
    .set_gap(8)
    .add(cogito.label("This content is inside a Revealer."))
    .add(cogito.button("Child button").on_click((b = cogito.Button) => {
        status.set_text("Revealer child button clicked.")
    }))

    let revealer = cogito.revealer()
    .set_padding(12, 12, 12, 12)
    .set_class("card")
    .add(revealer_content)
    vstack.add(revealer)

    reveal_toggle.on_change((s = cogito.Switch) => {
        let shown = s.checked()
        revealer.set_show_children(shown)
        if shown {
            status.set_text("Revealer children are visible.")
        } else {
            status.set_text("Revealer children are hidden.")
        }
    })

    return vstack
}

: build_bin_page() (( cogito.VStack )) {
    let vstack = build_page("Bin", "Bin applies a local Ensor accent to itself and descendants without changing app-wide accent.")

    let status = cogito.label("Bin accent is #72DEC2.")
    .set_class("body")
    .set_wrap(true)
    .set_hexpand(true)
    vstack.add(status)

    let accent_title = cogito.label("Bin local accent")
    .set_class("heading")
    vstack.add(accent_title)

    let bin_status = cogito.label("Interact with controls inside this Bin.")
    .set_wrap(true)

    let bin_switch = cogito.switch("Bin switch")
    .on_change((s = cogito.Switch) => {
        let on = if s.checked() { "on" } else { "off" }
        bin_status.set_text("Bin switch is $$on$$.")
    })

    let bin_controls = cogito.hstack()
    .set_gap(8)
    .add(cogito.button("Bin button").on_click((b = cogito.Button) => {
        bin_status.set_text("Bin button clicked.")
    }))
    .add(cogito.iconbtn("sf:star.fill")
        .set_color_style(1)
        .on_click((ib = cogito.IconButton) => {
            bin_status.set_text("Tonal icon button clicked.")
        }))

    let bin_controls2 = cogito.hstack()
    .set_gap(8)
    .add(cogito.textfield("").set_class("outline"))
    .add(cogito.checkbox("Bin checkbox", null))

    let bin_content = cogito.vstack()
    .set_gap(8)
    .add(cogito.label("This Bin uses its own accent-derived surface."))
    .add(cogito.label("Changing it does not alter app-wide accent."))
    .set_hexpand(true)
    .add(bin_switch)
    .add(bin_controls)
    .add(bin_controls2)
    .add(bin_status)

    let bin = cogito.bin()
    .set_padding(24, 24, 24, 24)
    .set_accent_color("#72DEC2")
    .set_hexpand(true)
    .add(bin_content)
    vstack.add(bin)

    let accent_row = cogito.buttongroup()
    .set_connected(true)
    .set_hexpand(true)
    .add(cogito.button("Teal").on_click((b = cogito.Button) => {
        bin.set_accent_color("#72DEC2")
        status.set_text("Bin accent set to #72DEC2.")
    }))
    .add(cogito.button("Blue").on_click((b = cogito.Button) => {
        bin.set_accent_color("#4F8CFF")
        status.set_text("Bin accent set to #4F8CFF.")
    }))
    .add(cogito.button("Pink").on_click((b = cogito.Button) => {
        bin.set_accent_color("#E65AB8")
        status.set_text("Bin accent set to #E65AB8.")
    }))
    .add(cogito.button("Green").on_click((b = cogito.Button) => {
        bin.set_accent_color("#4ea93e")
        status.set_text("Bin accent set to #4ea93e.")
    }))
    .add(cogito.button("Yellow").on_click((b = cogito.Button) => {
        bin.set_accent_color("#FFD700")
        status.set_text("Bin accent set to #FFD700.")
    }))
    .add(cogito.button("Red").on_click((b = cogito.Button) => {
        bin.set_accent_color("#ff3c00")
        status.set_text("Bin accent set to #FF3C00.")
    }))
    vstack.add(accent_row)

    return vstack
}

