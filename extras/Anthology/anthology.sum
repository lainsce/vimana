@diagnostics: warn

; ── Theme tokens ──────────────────────────────────────────────

@accent: #256A5A
@accent-light: rgba(37, 106, 90, 0.10)
@on-surface-variant: #5C6B66
@surface-container-lowest: #FFFFFF
@surface-container: #E0E9E5
@primary-container: #ACF0DB
@secondary-container: #CDE9DE
@tertiary-container: #B8EEFE

; ── Base ──────────────────────────────────────────────────────

vstack
hstack
zstack
grid
  background: transparent

content_list
content_list=first
content_list=middle
content_list=last
content_list=single
  background: transparent
  border-radius: 32

content_list=selected
  background: @accent-light
  border-radius: 32

window_bar
  background: @surface-container

appbar
  font-family: "Roboto Serif"

; ── Global shapes ─────────────────────────────────────────────

button
  border-radius: 32

iconbtn
  border-radius: 32

fab
  border-radius: 12

card
  border-radius: 26

chip
  border-radius: 26

; ── Content panel ─────────────────────────────────────────────

.content-panel
  border-radius: 18 0 0 0

; ── Sidebar ───────────────────────────────────────────────────

vstack.anthology-sidebar
  min-width: 320
  max-width: 320

label.sidebar-header
  font-family: "Roboto Serif"
  font-size: 24
  font-weight: 500

label.sidebar-collection-name
  font-size: 15
  font-weight: 500

label.sidebar-collection-count
  font-size: 13
  opacity: 0.55

vstack.sidebar-icon-bg
  min-width: 40
  max-width: 40
  min-height: 48
  max-height: 48
  border-radius: 6

vstack.icon-bg-primary
  background: @primary-container

vstack.icon-bg-secondary
  background: @secondary-container

vstack.icon-bg-tertiary
  background: @tertiary-container

button.new-collection-btn
  border: 1 dashed rgba(0, 0, 0, 0.25)
  border-radius: 32
  min-height: 80
  max-height: 80
  background: transparent

label.new-collection-label
  font-size: 15
  opacity: 0.6

; ── Home view ─────────────────────────────────────────────────

label.home-section-title
  font-family: "Roboto Serif"
  font-size: 20
  font-variation: wdth 150, opsz 14
  font-weight: 500

label.home-collection-heading
  font-family: "Roboto Serif"
  font-size: 36
  font-variation: wdth 150, opsz 14
  font-weight: 400

; ── Collection cards (home carousel) ──────────────────────────

carousel.collection-carousel
  min-height: 160
  border-radius: 26
  padding: 8 24 8 24

carousel_item
  padding: 0
  border-radius: 26

card.collection-card
  border-radius: 26
  padding: 16

card.item-primary
  background: @primary-container

card.item-secondary
  background: @secondary-container

card.item-tertiary
  background: @tertiary-container

label.collection-card-name
  font-family: "Roboto Serif"
  font-size: 16
  font-weight: 600

vstack.collection-icon-bg
  min-width: 48
  max-width: 48
  min-height: 48
  max-height: 48
  border-radius: 12

; ── Note cards ────────────────────────────────────────────────

card.note-card
  border-radius: 28
  padding: 24

card.note-card-compact
  border-radius: 28
  padding: 16

label.note-card-title
  font-family: "Roboto Serif"
  font-size: 20
  font-weight: 600

label.note-card-title-compact
  font-family: "Roboto Serif"
  font-size: 20
  font-weight: 600

label.note-card-preview
  font-size: 14
  color: @on-surface-variant

label.note-card-date
  font-size: 12
  letter-spacing: 0.5
  color: @accent

chip.note-tag:disabled
  background: transparent
  border: 1 solid @accent-light
  border-radius: 20
  opacity: 1
  font-size: 12

; ── Editor ────────────────────────────────────────────────────

textfield.editor-title
  font-family: "Roboto Serif"
  font-size: 36
  font-weight: 500
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0
  min-height: 0

textview.editor-body
  font-size: 16
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0

textview.editor-body-10
  font-size: 10
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0

textview.editor-body-12
  font-size: 12
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0

textview.editor-body-14
  font-size: 14
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0

textview.editor-body-18
  font-size: 18
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0

textview.editor-body-20
  font-size: 20
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0

textview.editor-body-22
  font-size: 22
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0

textview.editor-body-24
  font-size: 24
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0

textview.editor-body-26
  font-size: 26
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0

textview.editor-body-28
  font-size: 28
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0

textview.editor-body-30
  font-size: 30
  background: transparent
  border: 0 solid transparent
  border-radius: 0
  padding: 0

toolbar.editor-toolbar
  background: @surface-container-lowest

label.editor-meta
  font-size: 12
  letter-spacing: 0.5
  color: @on-surface-variant

; ── Settings dialog ───────────────────────────────────────────

label.settings-desc
  font-size: 12
  color: @on-surface-variant

label.settings-label
  font-size: 14
  font-weight: 500

; ── Dark mode overrides ───────────────────────────────────────

@when dark
  @on-surface-variant: #8A9A94
  @accent-light: rgba(37, 106, 90, 0.15)
  @surface-container: #2B3735
  @surface-container-lowest: #202524
  @primary-container: #256A5A
  @secondary-container: #3E524B
  @tertiary-container: #4A645E

  button.new-collection-btn
    border: 1 solid @accent-light
    border-style: dashed

  chip.note-tag:disabled
    border: 1 solid @accent-light
    opacity: 1

  toolbar.editor-toolbar
    background: @surface-container