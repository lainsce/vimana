def FOLD_N1 = [0x00ff, 0x0000, 0x0000, 0x0000, 0x0000, 0xffff, 0xffff, 0xffff]
def FOLD_N2 = [0x00ff, 0x0101, 0x0101, 0x0101, 0x0000, 0xfefe, 0xfefe, 0xfefe]
def FOLD_N3 = [0x0100, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000]
def FOLD_N4 = [0x0080, 0x4020, 0x1008, 0x0402, 0xff7f, 0x3f1f, 0x0f07, 0x0301]
def FOLD_N5 = [0x0101, 0x0101, 0x0101, 0x0101, 0xfefe, 0xfefe, 0xfefe, 0xfefe]
def FOLD_N6 = [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000]
