cask cal_font

bring stdr
bring vimana

-- Chicago character widths (ASCII 32-127)
def WIDTHS = [4, 6, 7, 10, 7, 11, 10, 3, 5, 5, 7, 7, 4, 7, 4, 7, 8, 8, 8, 8, 8, 8, 8, 8, 8, 8, 4, 4, 6, 8, 6, 8, 11, 8, 8, 8, 8, 7, 7, 8, 8, 6, 7, 9, 7, 12, 9, 8, 8, 8, 8, 7, 6, 8, 8, 12, 8, 8, 8, 5, 7, 5, 8, 8, 6, 8, 8, 7, 8, 8, 6, 8, 8, 4, 6, 8, 4, 12, 8, 8, 8, 8, 6, 7, 6, 8, 8, 12, 8, 8, 8, 5, 5, 5, 8, 8]

--| Corner dog-ear tiles (2bpp, 3 cols × 4 rows per state) |--

def FOLD_D_ADDR = 0x0000
def FOLD_N_ADDR = 0x00C0
def FOLD_B_ADDR = 0x0180

-- Default state
def FOLD_D0 = [0x0000, 0x0000, 0x0000, 0x5555, 0x1AAA, 0x06AA, 0x01AA, 0x006A]
def FOLD_D1 = [0x0000, 0x0000, 0x0000, 0x5555, 0xAAAA, 0xAAAA, 0xAAAA, 0xAAAA]
def FOLD_D2 = [0x0000, 0x0000, 0x0000, 0x5550, 0xAA90, 0xAA90, 0xAA90, 0xAA90]
def FOLD_D3 = [0x001A, 0x0006, 0x0001, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000]
def FOLD_D4 = [0xAAAA, 0xAAAA, 0xAAAA, 0x6AAA, 0x1AAA, 0x06AA, 0x01AA, 0x006A]
