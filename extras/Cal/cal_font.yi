def FOLD_D9 = [0x0000, 0x0000, 0x5555, 0x0000, 0x5555, 0x0000, 0x5555, 0x5555]
def FOLD_D10 = [0x0000, 0x0000, 0x5555, 0x0000, 0x5555, 0x0000, 0x5555, 0x5555]
def FOLD_D11 = [0x0015, 0x0000, 0x5555, 0x0000, 0x5555, 0x0000, 0x5555, 0x5555]

-- Next state
def FOLD_N0 = [0x0000, 0x5555, 0x1AAA, 0x06AA, 0x01AA, 0x006A, 0x001A, 0x0006]
def FOLD_N1 = [0x0000, 0x5555, 0xAAAA, 0xAAAA, 0xAAAA, 0xAAAA, 0xAAAA, 0xAAAA]
def FOLD_N2 = [0x0000, 0x5555, 0xAAA9, 0xAAA9, 0xAAA9, 0xAAA9, 0xAAA9, 0xAAA9]
def FOLD_N3 = [0x0001, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000]
def FOLD_N4 = [0xAAAA, 0x6AAA, 0x1AAA, 0x06AA, 0x01AA, 0x006A, 0x001A, 0x0006]
def FOLD_N5 = [0xAAA9, 0xAAA9, 0xAAA9, 0xAAA9, 0xAAA9, 0xAAA9, 0xAAA9, 0xAAA9]
def FOLD_N6 = [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000]
def FOLD_N7 = [0x0001, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000]
def FOLD_N8 = [0xAAA9, 0x6AA9, 0x1AA9, 0x06A9, 0x01A9, 0x0069, 0x0019, 0x0005]
def FOLD_N9 = [0x0000, 0x0000, 0x5555, 0x0000, 0x5555, 0x0000, 0x5555, 0x5555]
def FOLD_N10 = [0x0000, 0x0000, 0x5555, 0x0000, 0x5555, 0x0000, 0x5555, 0x5555]
def FOLD_N11 = [0x0001, 0x0000, 0x5555, 0x0000, 0x5555, 0x0000, 0x5555, 0x5555]

-- Back state
def FOLD_B0 = [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x5555, 0x1AAA, 0x06AA]
def FOLD_B1 = [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x5555, 0xAAAA, 0xAAAA]
def FOLD_B2 = [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x5500, 0xA900, 0xA900]
def FOLD_B3 = [0x01AA, 0x006A, 0x001A, 0x0006, 0x0001, 0x0000, 0x0000, 0x0000]
def FOLD_B4 = [0xAAAA, 0xAAAA, 0xAAAA, 0xAAAA, 0xAAAA, 0x6AAA, 0x1AAA, 0x06AA]
def FOLD_B5 = [0xA900, 0xA900, 0xA900, 0xA900, 0xA900, 0xA900, 0xA900, 0xA900]
def FOLD_B6 = [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000]
def FOLD_B7 = [0x01AA, 0x006A, 0x001A, 0x0006, 0x0001, 0x0000, 0x0000, 0x0000]
def FOLD_B8 = [0xA900, 0xA900, 0xA900, 0xA900, 0xA900, 0x6900, 0x1900, 0x0500]
def FOLD_B9 = [0x0000, 0x0000, 0x5555, 0x0000, 0x5555, 0x0000, 0x5555, 0x5555]
def FOLD_B10 = [0x0000, 0x0000, 0x5555, 0x0000, 0x5555, 0x0000, 0x5555, 0x5555]
def FOLD_B11 = [0x0155, 0x0000, 0x5555, 0x0000, 0x5555, 0x0000, 0x5555, 0x5555]

:: get_fold_addr(state = num) (( num ))
    if state == 1 <- FOLD_N_ADDR
    if state == 2 <- FOLD_B_ADDR
    <- FOLD_D_ADDR
;

-- Measure text width in pixels using proportional widths
:: text_width(s = string) (( num ))
    let ?w = 0
    let n = stdr.len(s)
    for (let ?i = 0; i < n; i += 1)
        let c = stdr.char_code(stdr.slice(s, i, i + 1))
        if c >= 32 && c < 128
            w = w + WIDTHS[c - 32]
        else
            w = w + 8
    <- w
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Chicago bitmap font (8×16 proportional, same as Musi)
-- ─────────────────────────────────────────────────────────────────────────────

:: install(scr = vimana.screen) (( vimana.screen ))
    scr.set_font_size(2)

    -- ASCII 0x20–0x7f glyphs (16 bytes each = 8×16 pixels)
