-- Back state
def FOLD_B0 = [0x0000, 0x0000, 0x00ff, 0x4020, 0x0000, 0x0000, 0x0000, 0x3f1f]
def FOLD_B1 = [0x0000, 0x0000, 0x00ff, 0x0000, 0x0000, 0x0000, 0x0000, 0xffff]
def FOLD_B2 = [0x0000, 0x0000, 0x00f0, 0x1010, 0x0000, 0x0000, 0x0000, 0xe0e0]
def FOLD_B3 = [0x1008, 0x0402, 0x0100, 0x0000, 0x0f07, 0x0301, 0x0000, 0x0000]
def FOLD_B4 = [0x0000, 0x0000, 0x0080, 0x4020, 0xffff, 0xffff, 0xff7f, 0x3f1f]
def FOLD_B5 = [0x1010, 0x1010, 0x1010, 0x1010, 0xe0e0, 0xe0e0, 0xe0e0, 0xe0e0]
def FOLD_B6 = [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000]
def FOLD_B7 = [0x1008, 0x0402, 0x0100, 0x0000, 0x0f07, 0x0301, 0x0000, 0x0000]
def FOLD_B8 = [0x1010, 0x1010, 0x1090, 0x5030, 0xe0e0, 0xe0e0, 0xe060, 0x2000]
def FOLD_B9 = [0x0000, 0xff00, 0xff00, 0xffff, 0x0000, 0x0000, 0x0000, 0x0000]
def FOLD_B10 = [0x0000, 0xff00, 0xff00, 0xffff, 0x0000, 0x0000, 0x0000, 0x0000]
def FOLD_B11 = [0x1f00, 0xff00, 0xff00, 0xffff, 0x0000, 0x0000, 0x0000, 0x0000]

:: get_fold_addr(state = num) (( num ))
    if state == 1 <- FOLD_N_ADDR
    if state == 2 <- FOLD_B_ADDR
    <- FOLD_D_ADDR
;

-- Measure text width in pixels using proportional widths
:: text_width(s = string) (( num ))
    let ?w = 0
    let n = stdr.len(s)
    for (let ?i = 0; i < n; i += 1)
        let c = stdr.char_code(s[i])
        if c >= 32 && c < 128
            w = w + WIDTHS[c - 32]
        else
            w = w + 8
    <- w
;

