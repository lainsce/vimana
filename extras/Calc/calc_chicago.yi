    if n == 158 <- [0x282A, 0x2828, 0x2828, 0x0AAA, 0x0000, 0x0555, 0x1014, 0x0554]
    if n == 159 <- [0x28A8, 0x2A28, 0x2828, 0x8AA0, 0x0000, 0x0551, 0x1414, 0x1414]
    if n == 160 <- [0x0A00, 0x2800, 0x2808, 0x0BE0, 0x0140, 0x0000, 0x0140, 0x0140]
    if n == 161 <- [0x0A00, 0x0A00, 0x0A00, 0x0F00, 0x0500, 0x0000, 0x0500, 0x0500]
    if n == 162 <- [0x0020, 0x0020, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x1550]
    if n == 163 <- [0x0220, 0x0220, 0x0080, 0x0080, 0x0001, 0x0001, 0x0404, 0x1404]
    if n == 164 <- [0x0A00, 0x0A00, 0x0A00, 0x0B40, 0x0F00, 0x2D00, 0x1540, 0x0500]
    if n == 165 <- [0x02A8, 0x0800, 0x0000, 0x0000, 0x0000, 0x0001, 0x0154, 0x0401]
    if n == 166 <- [0x0808, 0x0808, 0x2002, 0x2AAA, 0x0040, 0x0040, 0x0110, 0x0110]
    if n == 167 <- [0x2080, 0x0820, 0x0208, 0x0082, 0x0000, 0x0041, 0x0104, 0x0410]
    if n == 168 <- [0x0082, 0x0208, 0x0820, 0x2080, 0x0000, 0x1040, 0x0410, 0x0104]
    if n == 169 <- [0x0000, 0x0000, 0x0A0A, 0x0A0A, 0x0000, 0x0000, 0x0000, 0x0000]
    <- [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000]
;

-- Right 8x8 tile (packed 2bpp), only non-zero for wide glyphs
:: chicago_glyph_r(n = num) (( [any] ))
    if n == 3 <- [0x0000, 0x0000, 0x0000, 0x0000, 0x4000, 0x0000, 0x0000, 0x0000]
    if n == 5 <- [0x8000, 0x2000, 0x2000, 0x8000, 0x0000, 0x0000, 0x0000, 0x0000]
    if n == 6 <- [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x4000, 0x4000, 0x0000]
    if n == 32 <- [0x2000, 0x8000, 0x0000, 0x0000, 0x0000, 0x4000, 0x1000, 0x1000]
    if n == 45 <- [0x2800, 0x2800, 0x2800, 0x2C00, 0x1400, 0x5400, 0x5400, 0x1400]
    if n == 55 <- [0x2800, 0x2800, 0x2000, 0x9400, 0x1400, 0x1400, 0x1400, 0x1400]
    if n == 77 <- [0x2800, 0x2800, 0x2800, 0x2800, 0x0000, 0x5000, 0x1400, 0x1400]
    if n == 87 <- [0x2800, 0x2800, 0x2000, 0x8000, 0x0000, 0x1400, 0x1400, 0x1400]
    if n == 136 <- [0x8000, 0x8000, 0x0000, 0x0000, 0x0000, 0x4000, 0x4000, 0x4000]
    if n == 137 <- [0x8000, 0x8000, 0x0000, 0x0000, 0x0000, 0x4000, 0x4000, 0x4000]
    if n == 138 <- [0x0000, 0x0000, 0x0000, 0x1000, 0x5000, 0x1000, 0x1000, 0x0000]
    if n == 142 <- [0x0000, 0x0000, 0x0000, 0xF000, 0x0000, 0x0000, 0x0000, 0x4000]
    if n == 143 <- [0x0000, 0x0000, 0x0000, 0x4000, 0x0000, 0x0000, 0x0000, 0x0000]
    if n == 144 <- [0x8080, 0x2A00, 0x0000, 0x0000, 0x0000, 0x5500, 0x4040, 0x0040]
    if n == 148 <- [0x0000, 0x0000, 0x0000, 0x4000, 0x0000, 0x4000, 0x0000, 0x4000]
    if n == 149 <- [0x0000, 0x0000, 0x0000, 0x8000, 0x0000, 0x0000, 0x0000, 0x0000]
    if n == 152 <- [0x0000, 0x0000, 0x0000, 0x4000, 0x0000, 0x0000, 0x0000, 0x0000]
    if n == 153 <- [0x8000, 0x8000, 0x8000, 0x0000, 0x1000, 0x4000, 0x4000, 0x4000]
    if n == 157 <- [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x4000, 0x4000, 0x4000]
    if n == 158 <- [0xA800, 0x0000, 0x0800, 0xA000, 0x0000, 0x5000, 0x1400, 0x1400]
    if n == 163 <- [0x0000, 0x0000, 0x5400, 0x4000, 0x0000, 0x0000, 0x0000, 0x0000]
    if n == 169 <- [0x0000, 0x0000, 0x0A00, 0x0A00, 0x0000, 0x0000, 0x0000, 0x0000]
    <- [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000]
;

-- Draw a string using Chicago font at tile coordinates
-- Returns the pixel x position after the last character
:: draw_text(scr = vimana.screen, px = num, ty = num, text = string) (( num ))
    let ?cx = px
    let n = stdr.len(text)
    for (let ?i = 0; i < n; i += 1)
        let ch = stdr.char_at(text, i)
        let code = stdr.char_code(ch)
        let ?idx = code - 32
        if idx < 0 || idx >= 96
            idx = 0
        ;
        let tx = stdr.floor(cx / 8)
        scr.set_sprite(SCRATCH_L, chicago_glyph_l(idx), vimana.sprite_2bpp)
        scr.set_auto(0)
        scr.set_addr(SCRATCH_L).set_x(tx).set_y(ty).sprite(0x85)
        let w = CHICAGO_W[idx]
        if w > 8
            scr.set_sprite(SCRATCH_R, chicago_glyph_r(idx), vimana.sprite_2bpp)
            scr.set_addr(SCRATCH_R).set_x(tx + 1).set_y(ty).sprite(0x85)
        ;
        cx = cx + w
    ;
    <- cx
;
