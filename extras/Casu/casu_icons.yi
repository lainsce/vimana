cask casu_icons

bring stdr
bring vimana

-- ─────────────────────────────────────────────────────────────────────────────
-- Toolbar icons: 8 bytes (1bpp 8×8), rows high-bit = leftmost pixel
-- ─────────────────────────────────────────────────────────────────────────────
def ICN_BRUSH  = [0, 0x70, 0x68, 0x44, 0x22, 0x11, 0x09, 0x06]
def ICN_SELECT = [0, 0x40, 0x60, 0x70, 0x78, 0x7C, 0x70, 0x08]
def ICN_ZOOM   = [0, 0x30, 0x48, 0x84, 0x84, 0x48, 0x34, 0x02]
def ICN_PIXEL  = [0x7C, 0xFE, 0xFE, 0xFE, 0xFE, 0xFE, 0x7C, 0]
def ICN_SAVE   = [0, 0x08, 0x2A, 0x14, 0x63, 0x14, 0x2A, 0x08]
def ICN_MAKE   = [0, 0x7F, 0x41, 0x41, 0x41, 0x42, 0x45, 0x7A]
def ICN_LOAD   = [0, 0x7F, 0x55, 0x6B, 0x55, 0x6A, 0x55, 0x7A]
def ICN_FILL   = [0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF]
def ICN_BLANK  = [0, 0, 0, 0, 0, 0, 0, 0]
def ICN_HALF   = [0xAA, 0x55, 0xAA, 0x55, 0xAA, 0x55, 0xAA, 0x55]

-- Zoom icons (two states: not zoomed / zoomed)
def ICN_ZOOM0  = [0, 0x30, 0x48, 0x84, 0x84, 0x48, 0x34, 0x02]
def ICN_ZOOM1  = [0, 0x32, 0x45, 0x82, 0x84, 0x48, 0x34, 0x02]

-- Direction icon (for scroll direction indicator)
def ICN_DIR0   = [0, 0x7E, 0, 0x7E, 0, 0x70, 0, 0]
def ICN_DIR1   = [0, 0x54, 0x54, 0x54, 0x50, 0x50, 0, 0]

-- Big pixel: top-left 4×4 block of an 8×8 cell (for 4× zoom rendering)
def ICN_BIGPIXEL = [0xF0, 0xF0, 0xF0, 0xF0, 0, 0, 0, 0]

-- Slider left/right end caps
def ICN_SLIDER0 = [0xF0, 0xF0, 0xF0, 0xF0, 0xF0, 0xF0, 0xF0, 0]
def ICN_SLIDER1 = [0x50, 0xA0, 0x50, 0xA0, 0x50, 0xA0, 0x50, 0]

-- Circle (empty / filled)
def ICN_CIRCLE0 = [0, 0x1C, 0x22, 0x41, 0x41, 0x41, 0x22, 0x1C]
def ICN_CIRCLE1 = [0, 0x1C, 0x3E, 0x7F, 0x7F, 0x7F, 0x3E, 0x1C]

-- Arrow icons
def ICN_ARROW_L = [0x08, 0x0C, 0x0E, 0x7F, 0x0E, 0x0C, 0x08, 0]
def ICN_ARROW_R = [0x08, 0x18, 0x38, 0x7F, 0x38, 0x18, 0x08, 0]
def ICN_ARROW_U = [0x08, 0x1C, 0x3E, 0x7F, 0x08, 0x08, 0x08, 0]
def ICN_ARROW_D = [0x08, 0x08, 0x08, 0x7F, 0x3E, 0x1C, 0x08, 0]

-- ─────────────────────────────────────────────────────────────────────────────
-- Atari 8-bit font from nasu.tal @font section — 96 glyphs (ASCII 32–127).
-- Each glyph is 8 bytes (1bpp 8×8), transcribed directly from nasu.tal hex words.
-- ─────────────────────────────────────────────────────────────────────────────
def FONT_BYTES = [
    -- nasu.tal: 0000 0000 0000 0000
    0, 0, 0, 0, 0, 0, 0, 0,                          -- 32 space
    -- nasu.tal: 6060 6060 6000 6000
    0x60, 0x60, 0x60, 0x60, 0x60, 0, 0x60, 0,                    -- 33 !
    -- nasu.tal: 6666 6600 0000 0000
    0x66, 0x66, 0x66, 0, 0, 0, 0, 0,                    -- 34 "
