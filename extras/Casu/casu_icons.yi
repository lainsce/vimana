def ICN_LOAD   = [0x007f, 0x556b, 0x556a, 0x557a]
def ICN_FILL   = [0xffff, 0xffff, 0xffff, 0xffff]
def ICN_BLANK  = [0x0000, 0x0000, 0x0000, 0x0000]
def ICN_HALF   = [0xaa55, 0xaa55, 0xaa55, 0xaa55]

-- Zoom icons (two states: not zoomed / zoomed)
def ICN_ZOOM0  = [0x0030, 0x4884, 0x8448, 0x3402]
def ICN_ZOOM1  = [0x0032, 0x4582, 0x8448, 0x3402]

-- Direction icon (for scroll direction indicator)
def ICN_DIR0   = [0x007e, 0x007e, 0x0070, 0x0000]
def ICN_DIR1   = [0x0054, 0x5454, 0x5050, 0x5000]

-- Big pixel: top-left 4×4 block of an 8×8 cell (for 4× zoom rendering)
def ICN_BIGPIXEL = [0xf0f0, 0xf0f0, 0x0000, 0x0000]

-- Slider left/right end caps
def ICN_SLIDER0 = [0xf0f0, 0xf0f0, 0xf0f0, 0xf000]
def ICN_SLIDER1 = [0x50a0, 0x50a0, 0x50a0, 0x5000]

-- Circle (empty / filled)
def ICN_CIRCLE0 = [0x001c, 0x2241, 0x4141, 0x221c]
def ICN_CIRCLE1 = [0x001c, 0x3e7f, 0x7f7f, 0x3e1c]

-- Arrow icons
def ICN_ARROW_L = [0x080c, 0x0e7f, 0x0e0c, 0x0800]
def ICN_ARROW_R = [0x0818, 0x387f, 0x3818, 0x0800]
