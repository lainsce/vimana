-- Install the Atari 8-bit font into the screen's glyph memory.
: setup_font(scr = vimana.screen) (( -- ))
    for (let ?code = 32; code <= 127; code += 1)
        let base = (code - 32) * 4
        scr.set_font(code, [
            FONT_WORDS[base],
            FONT_WORDS[base + 1],
            FONT_WORDS[base + 2],
            FONT_WORDS[base + 3]])
;

-- Install the toolbar icons into sprite slots 0xF100–0xF1FF.
-- These are used via put_icn directly and do not need sprite slot pre-loading.
def ICON_SLOT_BASE = 0xF100

: setup_icons(scr = vimana.screen) (( -- ))
    -- Icons are referenced by their arrays at draw time via put_icn.
    -- No sprite slot pre-upload needed for 1bpp put_icn calls.
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Frame sprite data for panel borders.
-- The active Casu UI border uses 1bpp sprite tiles uploaded here and drawn
-- through `screen.sprite(...)` from casu_view.yi.
-- ─────────────────────────────────────────────────────────────────────────────

-- 1bpp frame icons derived from the visible frame2 stroke in casu.tal.
def FRAME2_TL = [0x0000, 0x0000, 0x0001, 0x0204]
def FRAME2_TR = [0x0000, 0x0000, 0x0080, 0x4020]
def FRAME2_BL = [0x0402, 0x0100, 0x0000, 0x0000]
def FRAME2_BR = [0x2040, 0x8000, 0x0000, 0x0000]
def FRAME2_HT = [0x0000, 0x0000, 0x00ff, 0x0000]
def FRAME2_HB = [0x0000, 0xff00, 0x0000, 0x0000]
def FRAME2_VL = [0x0404, 0x0404, 0x0404, 0x0404]
def FRAME2_VR = [0x2020, 0x2020, 0x2020, 0x2020]

-- Sprite memory addresses for frame tiles (each tile = 16 bytes)
def FRAME2_TL_ADDR = 0x1060
def FRAME2_TR_ADDR = 0x1068
def FRAME2_BL_ADDR = 0x1070
def FRAME2_BR_ADDR = 0x1078
def FRAME2_HT_ADDR = 0x1080
def FRAME2_HB_ADDR = 0x1088
def FRAME2_VL_ADDR = 0x1090
def FRAME2_VR_ADDR = 0x1098

-- Upload active frame tiles to sprite memory.
: setup_frames(scr = vimana.screen) (( -- ))
    scr.set_sprite(FRAME2_TL_ADDR, FRAME2_TL, vimana.sprite_1bpp)
    scr.set_sprite(FRAME2_TR_ADDR, FRAME2_TR, vimana.sprite_1bpp)
    scr.set_sprite(FRAME2_BL_ADDR, FRAME2_BL, vimana.sprite_1bpp)
    scr.set_sprite(FRAME2_BR_ADDR, FRAME2_BR, vimana.sprite_1bpp)
    scr.set_sprite(FRAME2_HT_ADDR, FRAME2_HT, vimana.sprite_1bpp)
    scr.set_sprite(FRAME2_HB_ADDR, FRAME2_HB, vimana.sprite_1bpp)
    scr.set_sprite(FRAME2_VL_ADDR, FRAME2_VL, vimana.sprite_1bpp)
    scr.set_sprite(FRAME2_VR_ADDR, FRAME2_VR, vimana.sprite_1bpp)
;
