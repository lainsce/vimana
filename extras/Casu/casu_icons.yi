    0, 0x66, 0x3C, 0xFF, 0x3C, 0x66, 0, 0,                  -- 42 *
    -- nasu.tal: 0018 187e 1818 0000
    0, 0x18, 0x18, 0x7E, 0x18, 0x18, 0, 0,                    -- 43 +
