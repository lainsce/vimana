cask casu_icons

bring stdr
bring vimana

-- ─────────────────────────────────────────────────────────────────────────────
-- Toolbar icons: 4 words (1bpp 8×8), rows high-bit = leftmost pixel
-- ─────────────────────────────────────────────────────────────────────────────
def ICN_BRUSH  = [0x0070, 0x6844, 0x2211, 0x0906]
def ICN_SELECT = [0x0040, 0x6070, 0x787c, 0x7008]
def ICN_ZOOM   = [0x0030, 0x4884, 0x8448, 0x3402]
def ICN_PIXEL  = [0x7cfe, 0xfefe, 0xfefe, 0x7c00]
