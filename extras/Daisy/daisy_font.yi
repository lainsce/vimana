    if code == 63 <- [0x3c66, 0x060c, 0x1800, 0x1800]
    if code == 64 <- [0x3c66, 0x6e6a, 0x6e60, 0x3e00]
    if code == 65 <- [0x183c, 0x6666, 0x7e66, 0x6600]
    if code == 66 <- [0x7c66, 0x667c, 0x6666, 0x7c00]
