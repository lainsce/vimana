    if code == 115 <- [0x0000, 0x3e60, 0x3c06, 0x7c00]
    if code == 116 <- [0x0018, 0x7e18, 0x1818, 0x0e00]
    if code == 117 <- [0x0000, 0x6666, 0x6666, 0x3e00]
    if code == 118 <- [0x0000, 0x6666, 0x663c, 0x1800]
    if code == 119 <- [0x0000, 0xc6c6, 0xd67c, 0x6c00]
    if code == 120 <- [0x0000, 0x663c, 0x183c, 0x6600]
    if code == 121 <- [0x0000, 0x6666, 0x663e, 0x067c]
    if code == 122 <- [0x0000, 0x7e0c, 0x1830, 0x7e00]
    if code == 123 <- [0x1c30, 0x3060, 0x3030, 0x1c00]
    if code == 124 <- [0x1818, 0x1818, 0x1818, 0x1818]
    if code == 125 <- [0x380c, 0x0c06, 0x0c0c, 0x3800]
    if code == 126 <- [0x0000, 0x60f2, 0x9e0c, 0x0000]
    if code == 127 <- [0x1038, 0x7cfe, 0x7c38, 0x1000]
    <- ICN_BLANK
;

:: install(scr = vimana.screen) (( vimana.screen ))
    for (let ?code = 0; code < 128; code += 1)
        scr.set_font(code, glyph(code))
    <- scr
;
