cask daisy_font

bring vimana

def ICN_BLANK = [0x0000, 0x0000, 0x0000, 0x0000]

: glyph(code = num) (( [any] ))
    if code < 32 || code > 127
        <- ICN_BLANK
    if code == 32 <- [0x0000, 0x0000, 0x0000, 0x0000]
    if code == 33 <- [0x6060, 0x6060, 0x6000, 0x6000]
    if code == 34 <- [0x6666, 0x6600, 0x0000, 0x0000]
    if code == 35 <- [0x006c, 0xfe6c, 0x6cfe, 0x6c00]
    if code == 36 <- [0x183e, 0x603c, 0x067c, 0x1800]
    if code == 37 <- [0x0066, 0x6c18, 0x3066, 0x4600]
    if code == 38 <- [0x386c, 0x3870, 0xdecc, 0x7600]
    if code == 39 <- [0x6060, 0x6000, 0x0000, 0x0000]
    if code == 40 <- [0x1c30, 0x3030, 0x3030, 0x1c00]
    if code == 41 <- [0x380c, 0x0c0c, 0x0c0c, 0x3800]
    if code == 42 <- [0x0066, 0x3cff, 0x3c66, 0x0000]
    if code == 43 <- [0x0018, 0x187e, 0x1818, 0x0000]
    if code == 44 <- [0x0000, 0x0000, 0x0030, 0x3060]
    if code == 45 <- [0x0000, 0x007e, 0x0000, 0x0000]
    if code == 46 <- [0x0000, 0x0000, 0x0018, 0x1800]
    if code == 47 <- [0x0306, 0x0c18, 0x3060, 0xc000]
    if code == 48 <- [0x3c66, 0x6e76, 0x6666, 0x3c00]
    if code == 49 <- [0x1838, 0x1818, 0x1818, 0x7e00]
    if code == 50 <- [0x3c66, 0x060c, 0x1830, 0x7e00]
