    if code == 95 <- [0x0000, 0x0000, 0x0000, 0xfe00]
    if code == 96 <- [0x0060, 0x3018, 0x0000, 0x0000]
    if code == 97 <- [0x0000, 0x3c06, 0x3e66, 0x3e00]
    if code == 98 <- [0x6060, 0x7c66, 0x6666, 0x7c00]
    if code == 99 <- [0x0000, 0x3c60, 0x6060, 0x3c00]
    if code == 100 <- [0x0606, 0x3e66, 0x6666, 0x3e00]
    if code == 101 <- [0x0000, 0x3c66, 0x7e60, 0x3c00]
    if code == 102 <- [0x1c30, 0x7c30, 0x3030, 0x3000]
    if code == 103 <- [0x0000, 0x3e66, 0x663e, 0x067c]
    if code == 104 <- [0x6060, 0x7c66, 0x6666, 0x6600]
    if code == 105 <- [0x1800, 0x3818, 0x1818, 0x3c00]
