    if code == 52 <- [0x0c1c, 0x3c6c, 0x7e0c, 0x0c00]
    if code == 53 <- [0x7e60, 0x7c06, 0x0666, 0x3c00]
    if code == 54 <- [0x3c60, 0x607c, 0x6666, 0x3c00]
