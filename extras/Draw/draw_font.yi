-- ─────────────────────────────────────────────────────────────────────────────
def MONACO_TOP = [
    [0, 0, 0, 0x38, 0x44, 0x44, 0x44, 0x44],
    [0, 0, 0, 0x10, 0x30, 0x10, 0x10, 0x10],
    [0, 0, 0, 0x38, 0x44, 0x04, 0x04, 0x08],
    [0, 0, 0, 0x38, 0x44, 0x04, 0x18, 0x04],
    [0, 0, 0, 0x08, 0x18, 0x28, 0x48, 0x7C],
    [0, 0, 0, 0x7C, 0x40, 0x40, 0x78, 0x04],
    [0, 0, 0, 0x18, 0x20, 0x40, 0x78, 0x44],
    [0, 0, 0, 0x7C, 0x04, 0x04, 0x08, 0x10],
    [0, 0, 0, 0x38, 0x44, 0x44, 0x38, 0x44],
    [0, 0, 0, 0x38, 0x44, 0x44, 0x44, 0x44]
]
def MONACO_BOT = [
    [0x44, 0x44, 0x44, 0x38, 0, 0, 0, 0],
    [0x10, 0x10, 0x10, 0x10, 0, 0, 0, 0],
    [0x10, 0x20, 0x40, 0x7C, 0, 0, 0, 0],
    [0x04, 0x04, 0x44, 0x38, 0, 0, 0, 0],
    [0x08, 0x08, 0x08, 0x08, 0, 0, 0, 0],
    [0x04, 0x04, 0x44, 0x38, 0, 0, 0, 0],
    [0x44, 0x44, 0x44, 0x38, 0, 0, 0, 0],
    [0x10, 0x10, 0x10, 0x10, 0, 0, 0, 0],
    [0x44, 0x44, 0x44, 0x38, 0, 0, 0, 0],
    [0x3C, 0x04, 0x08, 0x30, 0, 0, 0, 0]
]

def MONACO_X_T = [0, 0, 0, 0, 0, 0, 0x44, 0x28]
def MONACO_X_B = [0x10, 0x10, 0x28, 0x44, 0, 0, 0, 0]
def BLANK_ICN  = [0, 0, 0, 0, 0, 0, 0, 0]

: draw_monaco_digit(scr = vimana.screen, tx = num, ty = num, d = num, fg = num, bg = num) (( -- ))
    scr.put_icn(tx, ty, MONACO_TOP[d], fg, bg)
    scr.put_icn(tx, ty + 8, MONACO_BOT[d], fg, bg)
;

:: draw_size(scr = vimana.screen, right_tx = num, ty = num, w = num, h = num, fg = num, bg = num) (( -- ))
    let w1 = w / 10
    let w0 = w - (w1 * 10)
    let h1 = h / 10
    let h0 = h - (h1 * 10)
    let ?tx = right_tx - 48
    draw_monaco_digit(scr, tx, ty, w1, fg, bg)
    tx = tx + 8
    draw_monaco_digit(scr, tx, ty, w0, fg, bg)
    tx = tx + 8
    scr.put_icn(tx, ty, MONACO_X_T, fg, bg)
    scr.put_icn(tx, ty + 8, MONACO_X_B, fg, bg)
    tx = tx + 8
    draw_monaco_digit(scr, tx, ty, h1, fg, bg)
    tx = tx + 8
    draw_monaco_digit(scr, tx, ty, h0, fg, bg)
;