cask hello_font

bring vimana

def ICN_BLANK = [
    "0000", "0000", "0000", "0000",
    "0000", "0000", "0000", "0000",
    "0000", "0000", "0000", "0000",
    "0000", "0000", "0000", "0000"
]

def ICN_QUESTION = [
    "0550", "1414", "0014", "0050",
    "0140", "0000", "0140", "0000",
    "0000", "0000", "0000", "0000",
    "0000", "0000", "0000", "0000"
]

: glyph_icn(code = num) (( [any] ))
