        <- ICN_BLANK

    if code >= 97 && code <= 122
        code = code - 32

    if code == 32 <- ICN_BLANK
    if code == 33 <- ["0140", "0140", "0140", "0140", "0140", "0000", "0140", "0000", "0000", "0000", "0000", "0000", "0000", "0000", "0000", "0000"]
