@diagnostics: warn

hstack
vstack
zstack
  background: transparent

vstack.kairos-sidebar
  min-width: 300
  max-width: 300

appbar.kairos-sidebar-bar
  background: transparent

appbar.kairos-content-bar
  background: transparent

content_list.kairos-location-list
  background: transparent
  border-radius: 0

content_list.kairos-dialog-results
  background: transparent
  border-radius: 0

hstack.kairos-location-row
  border-radius: 12

label.kairos-location-name
  font-size: 16

label.kairos-location-subtitle
  font-size: 12
  font-weight: bold

iconbtn.kairos-add-location
  border-radius: 12

vstack.kairos-card
  border-radius: 10

vstack.kairos-chart-card
  border-radius: 10
  background: alpha(#000000, 5%)

hstack.kairos-header
  background: transparent

label.kairos-current-temp
  font-size: 48
  font-weight: bold

label.kairos-current-place
  font-size: 20

label.kairos-current-desc
  font-size: 24
  font-weight: bold

label.kairos-current-feels
  font-size: 18

label.kairos-status
  font-size: 16

image.kairos-current-icon
  min-width: 52
  max-width: 52
  min-height: 52
  max-height: 52

label.kairos-section-title
  font-size: 20
  font-weight: bold

zstack.kairos-chart-fixed
  min-height: 170
  max-height: 170

drawing_area.kairos-chart-area
  min-height: 170
  max-height: 170

label.kairos-chart-tooltip
  font-size: 14
  font-weight: bold
  min-width: 80
  max-width: 80

label.kairos-chart-zero-label
  font-size: 12
  color: alpha(#000000, 40%)

grid.kairos-timeline-grid
  background: transparent

vstack.kairos-hour-cell
  min-width: 68
  max-width: 68
  background: alpha(#000000, 5%)
  border-radius: 10

label.kairos-hour-label
  font-size: 13

image.kairos-hour-icon
  min-width: 24
  max-width: 24
  min-height: 24
  max-height: 24

label.kairos-hour-value
  font-size: 18
  font-weight: bold

content_list.kairos-hourly-list
  background: transparent

image.kairos-hourly-icon
  min-width: 24
  max-width: 24
  min-height: 24
  max-height: 24

label.kairos-hourly-time
  font-size: 18
  font-weight: bold

label.kairos-hourly-label
  font-size: 14

label.kairos-hourly-temp
  font-size: 18
  font-weight: bold

label.kairos-hourly-humidity
  font-size: 16

label.kairos-metric-title
  font-size: 16

label.kairos-metric-value
  font-size: 20
  font-weight: bold

drawing_area.kairos-orbit-area
  min-height: 230
  max-height: 230
  border-radius: 12

label.kairos-orbit-status
  font-size: 16

label.kairos-attribution
  font-size: 13

dialog.kairos-add-dialog
  min-width: 420
  max-width: 460
  min-height: 420
  max-height: 520

label.kairos-dialog-title
  font-size: 24
  font-weight: bold

label.kairos-dialog-hint
  font-size: 12

hstack.kairos-dialog-result-row
  background: transparent

label.kairos-dialog-placeholder-text
  font-size: 22
  font-weight: bold

image.kairos-location-pin
  min-width: 24
  max-width: 24
  min-height: 24
  max-height: 24

image.kairos-orbit-icon
  min-width: 24
  max-width: 24
  min-height: 24
  max-height: 24