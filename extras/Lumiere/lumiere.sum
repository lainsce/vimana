@diagnostics: warn

vstack
hstack
grid
  background: transparent

appbar.lumiere-library-bar
  background: transparent

window.lumiere-player-win
  background: #000000

window_bar.lumiere-player-wbar
  background: transparent
  color: #ffffff
  opacity: 0.7

hstack.lumiere-player-topbar
  background: alpha(#000000, 40%)
  color: #ffffff
  padding: 0

iconbtn.lumiere-back-btn
  color: #ffffff

grid.lumiere-library-grid
  background: transparent

content_list.lumiere-library-list
  background: transparent
  border-radius: 0

card.lumiere-video-card
  min-height: 200
  min-width: 180
  border-radius: 12

hstack.lumiere-video-row
  border-radius: 12
  border: 1 solid #00000008

shape.lumiere-row-thumb
  min-width: 80
  min-height: 52
  max-width: 80
  max-height: 52
  border-radius: 8

label.lumiere-row-title
  font-size: 15

vstack.lumiere-player-view
  background: transparent

label.lumiere-player-title
  font-size: 18
  font-weight: bold
  text-overflow: fade
  color: #ffffff

label.lumiere-player-subtitle
  font-size: 13
  opacity: 0.6
  text-overflow: fade
  color: #ffffff

toolbar.lumiere-controls-bar
  background: alpha(#000000, 40%)

iconbtn.lumiere-play-btn
  color: #ffffff

iconbtn.lumiere-settings-btn
  color: #ffffff

label.lumiere-time-label
  font-size: 12
  opacity: 0.7
  min-width: 48
  color: #ffffff

hstack.lumiere-compact-seek-bar
  background: alpha(#000000, 40%)
  color: #ffffff

label.lumiere-settings-heading
  font-size: 15
  font-weight: bold

video-view.lumiere-video-view
  background: #000000
  border-radius: 0
  padding: 0

slider.lumiere-seek-slider
  color: #ffffff

@when dark
  hstack.lumiere-video-row
    border: 1 solid #ffffff10
  toolbar.lumiere-controls-bar
    background: alpha(#000000, 75%)
  hstack.lumiere-compact-seek-bar
    background: alpha(#000000, 75%)
