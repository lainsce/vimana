-- Rocket flame frame A (16x16)
def RKT_A = [
    -- Tile 0: Top-Left
    0x0F0F, 0x0707, 0x0303, 0x0101, -- Plane 0
    0x0000, 0x0000, 0x0000, 0x0000, -- Plane 1
    0x0000, 0x0000, 0x0000, 0x0000, -- Plane 2
