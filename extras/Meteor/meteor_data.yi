cask meteor_data

bring stdr
bring vimana

bring meteor_planet_assets
bring meteor_tileset_assets

--| ADDRESSES |--
-- ─────────────────────────────────────────────────────────────────────────────
-- Sprite addresses — packed contiguously
--
-- Element tiles  (11 × 0x0080)  (T1..T10 + WALL, 4bpp)
-- Chrome buttons  (2 × 0x0120)  (4bpp)
-- UI sprites      (3 × 0x0080)  (SELECT, ROCKET_A/B, 4bpp)
-- Planets        (18 × 0x0200)  (4bpp)
-- Mini planets   (18 × 0x0080)  (4bpp)
-- Space frames    (5 × 0x0080)  (4bpp)
-- Time frames     (5 × 0x0080)  (4bpp)
-- Borders        (18 × 0x00A0)  (4bpp)
-- ─────────────────────────────────────────────────────────────────────────────

-- Element tiles (16x16, 4bpp — load(count=4) = 4 × 0x20 = 0x80 each)
def ADDR_TILE1  = 0x0000
def ADDR_TILE2  = 0x0080
def ADDR_TILE3  = 0x0100
def ADDR_TILE4  = 0x0180
def ADDR_TILE5  = 0x0200
def ADDR_TILE6  = 0x0280
def ADDR_TILE7  = 0x0300
def ADDR_TILE8  = 0x0380
def ADDR_TILE9  = 0x0400
def ADDR_TILE10 = 0x0480
def ADDR_WALL   = 0x0500

-- Dithered variants (share addresses with normal tiles)
def ADDR_DTILE1  = ADDR_TILE1
def ADDR_DTILE3  = ADDR_TILE3
def ADDR_DTILE4  = ADDR_TILE4
def ADDR_DTILE5  = ADDR_TILE5
def ADDR_DTILE7  = ADDR_TILE7
def ADDR_DTILE8  = ADDR_TILE8
def ADDR_DTILE9  = ADDR_TILE9
def ADDR_DTILE10 = ADDR_TILE10

-- Chrome buttons (9 sub-tiles, 4bpp — load(count=9) = 9 × 0x20 = 0x120 each)
def ADDR_CHR_UP = 0x0580
def ADDR_CHR_DN = 0x06A0

-- UI sprites (4 sub-tiles, 4bpp — load(count=4) = 4 × 0x20 = 0x80 each)
def ADDR_SELECT   = 0x07C0
def ADDR_ROCKET_A = 0x0840
def ADDR_ROCKET_B = 0x08C0

-- Planet sprites (32x32, 4bpp — load(count=16) = 16 × 0x20 = 0x200 each)
def ADDR_PL_H   = 0x0980
def ADDR_PL_S   = 0x0B80
def ADDR_PL_W   = 0x0D80
def ADDR_PL_F   = 0x0F80
def ADDR_PL_SN  = 0x1180
def ADDR_PL_D   = 0x1380
def ADDR_PL_G   = 0x1580
def ADDR_PL_PR  = 0x1780
def ADDR_PL_GG  = 0x1980
def ADDR_PL_RS  = 0x1B80
def ADDR_PL_NR  = 0x1D80
def ADDR_PL_LL  = 0x1F80
def ADDR_PL_OR  = 0x2180
def ADDR_PL_HN  = 0x2380
def ADDR_PL_TK  = 0x2580
def ADDR_PL_BK  = 0x2780
def ADDR_PL_GL  = 0x2980
def ADDR_PL_MT  = 0x2B80

-- Mini planet sprites (16x16, 4bpp — load(count=4) = 4 × 0x20 = 0x80 each × 18 = 0x900 total)
def ADDR_MINI_PL = 0x2D80

-- Rare metal sprites (Space & Time, 4bpp — 5 frames × 0x80 = 0x280 each)
def ADDR_SPACE_BASE = 0x3680
def ADDR_TIME_BASE  = 0x3900

-- Border sprites (18 planets × 5 sub-tiles, load(count=5) = 5 × 0x20 = 0xA0 each)
def ADDR_BDR = 0x3B80

def PLANET_ADDRS = [
    0x0980, 0x0B80, 0x0D80, 0x0F80, 0x1180,
    0x1380, 0x1580, 0x1780, 0x1980, 0x1B80,
    0x1D80, 0x1F80, 0x2180, 0x2380, 0x2580,
    0x2780, 0x2980, 0x2B80
]

:: planet_addr(p = num) (( num ))
    <- PLANET_ADDRS[p]
;

:: mini_planet_addr(p = num) (( num ))
    <- ADDR_MINI_PL + p * 0x80
;

-- Planet → tileset mapping
-- (0=original, 1=S2, 2=S3, 3=S4, 4=S5, 5=S6, 6=S7, 7=S8, 8=S9, 9=S10, 10=S11, 11=S12)
-- Array displayed as the planet select screen.

def PLANET_TILESET = [
    0, 2, 1, 16,
    14, 16, 9, 13,
    12, 10, 6, 4,
    14, 4, 6, 1,
    15, 11
]

-- Tile address table
-- Index:
-- 0=unused, 1=Air, 2=Fire, 3=Water,
-- 4=Soil, 5=Iron, 6=Zap, 7=Herb,
-- 8=Dark, 9=Zoo, 10=Glow, 11=Garbage
-- The addr order here reflects the above.
def TILE_ADDRS = [
    0x0000, 0x0000, 0x0080, 0x0100,
    0x0180, 0x0200, 0x0280, 0x0300,
    0x0380, 0x0400, 0x0480, 0x0500
]

-- `frame` is a 5-step animation counter (0..4), only consulted for rare
-- metals (Space=12, Time=13). Callers for normal tiles pass 0.
:: tile_addr(t = num, frame = num) (( num ))
    if t == 12
        <- ADDR_SPACE_BASE + (frame % 5) * 0x80
    if t == 13
        <- ADDR_TIME_BASE + (frame % 5) * 0x80
    if t < 1 || t > 11
        <- 0
    <- TILE_ADDRS[t]
;

-- Sprite control word per tile type (4bpp=0x200 | blend)
-- blend: 1=identity (color0=BG, 1..15=palette slots 1..15)
def TILE_CTRLS = [
    0x201, 0x201, 0x201, 0x201,
    0x201, 0x201, 0x201, 0x201,
    0x201, 0x201, 0x201, 0x201
]

:: tile_ctrl(t = num) (( num ))
    -- Rare metals are 4bpp and cycle palette slots for the glow pulse.
    if t == 12 || t == 13
        <- 0x201
    if t < 1 || t > 11
        <- 0x201
    <- TILE_CTRLS[t]
;

:: rocket_addr(frame = num) (( num ))
    if frame == 0
        <- ADDR_ROCKET_A
    <- ADDR_ROCKET_B
;

