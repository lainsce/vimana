-- planet palette
:: set_planet_palette(scr = vimana.screen, p = num) (( -- ))
    let pal = PALETTES[p]
    scr.set_palette(vimana.color_bg,  pal[0])
       .set_palette(vimana.color_fg,  pal[1])
       .set_palette(vimana.color_2,   pal[2])
       .set_palette(vimana.color_3,   pal[3])
       .set_palette(vimana.color_4,   pal[4])
       .set_palette(vimana.color_5,   pal[5])
       .set_palette(vimana.color_6,   pal[6])
       .set_palette(vimana.color_7,   pal[7])
       .set_palette(vimana.color_8,   pal[8])
       .set_palette(vimana.color_9,   pal[9])
       .set_palette(vimana.color_10,  pal[10])
       .set_palette(vimana.color_11,  pal[11])
       .set_palette(vimana.color_12,  pal[12])
       .set_palette(vimana.color_13,  pal[13])
       .set_palette(vimana.color_14,  pal[14])
       .set_palette(vimana.color_15,  pal[15])
;

-- Menu palette
:: set_menu_palette(scr = vimana.screen) (( -- ))
    scr.set_palette(vimana.color_bg,  PAL_UNIFIED[0])
       .set_palette(vimana.color_fg,  PAL_UNIFIED[1])
       .set_palette(vimana.color_2,   PAL_UNIFIED[2])
       .set_palette(vimana.color_3,   PAL_UNIFIED[3])
       .set_palette(vimana.color_4,   PAL_UNIFIED[4])
       .set_palette(vimana.color_5,   PAL_UNIFIED[5])
       .set_palette(vimana.color_6,   PAL_UNIFIED[6])
       .set_palette(vimana.color_7,   PAL_UNIFIED[7])
       .set_palette(vimana.color_8,   PAL_UNIFIED[8])
       .set_palette(vimana.color_9,   PAL_UNIFIED[9])
       .set_palette(vimana.color_10,  PAL_UNIFIED[10])
       .set_palette(vimana.color_11,  PAL_UNIFIED[11])
       .set_palette(vimana.color_12,  PAL_UNIFIED[12])
       .set_palette(vimana.color_13,  PAL_UNIFIED[13])
       .set_palette(vimana.color_14,  PAL_UNIFIED[14])
       .set_palette(vimana.color_15,  PAL_UNIFIED[15])
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Sprite data (2bpp, 16x16 = 4 quadrants of 8x8)
-- Each word = 8 pixels × 2 bits. Bits 15-14 = pixel 0 (left), bits 1-0 = pixel 7
-- Always this order: TR, TL, BR, BL
-- Color 00=bg, 01=fg, 10=color2, 11=color3
-- ─────────────────────────────────────────────────────────────────────────────

--| UI |--

-- Selection corners (color 1, small L-brackets at each corner)
def SEL = [
    -- Tile 0: Top-Left
    0xF0F0, 0xC0C0, 0x0000, 0x0000, 0xF0F0, 0xC0C0, 0x0000, 0x0000,
    0xF0F0, 0xC0C0, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000,
    -- Tile 1: Top-Right
    0x0F0F, 0x0303, 0x0000, 0x0000, 0x0F0F, 0x0303, 0x0000, 0x0000,
    0x0F0F, 0x0303, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000,
    -- Tile 2: Bottom-Left
    0x0000, 0x0000, 0xC0C0, 0xF0F0, 0x0000, 0x0000, 0xC0C0, 0xF0F0,
    0x0000, 0x0000, 0xC0C0, 0xF0F0, 0x0000, 0x0000, 0x0000, 0x0000,
    -- Tile 3: Bottom-Right
    0x0000, 0x0000, 0x0303, 0x0F0F, 0x0000, 0x0000, 0x0303, 0x0F0F,
    0x0000, 0x0000, 0x0303, 0x0F0F, 0x0000, 0x0000, 0x0000, 0x0000
]

