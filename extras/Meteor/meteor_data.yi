--| FUNCTIONS |--

-- Load a 4bpp 8x8 sub-tile (16 words, 0x20 stride).
: load(scr = vimana.screen, addr = num, d = any, count = num) (( -- ))
    for (let ?i = 0; i < count; i = i + 1)
        let off = i * 16
        let tile = [d[off], d[off + 1], d[off + 2], d[off + 3],
                    d[off + 4], d[off + 5], d[off + 6], d[off + 7],
                    d[off + 8], d[off + 9], d[off + 10], d[off + 11],
                    d[off + 12], d[off + 13], d[off + 14], d[off + 15]]
        scr.set_sprite(addr + i * 0x20, tile, vimana.sprite_4bpp)
    ;
;

: load_tileset_tiles(scr = vimana.screen, ts = num) (( -- ))
    -- Main tiles: type→addr mapping matches TILE_ADDRS
    load(scr, ADDR_TILE1,  meteor_tileset_assets.tile(ts, 1),  4)
    load(scr, ADDR_TILE2,  meteor_tileset_assets.tile(ts, 2),  4)
    load(scr, ADDR_TILE3,  meteor_tileset_assets.tile(ts, 3),  4)
    load(scr, ADDR_TILE4,  meteor_tileset_assets.tile(ts, 4),  4)
    load(scr, ADDR_TILE5,  meteor_tileset_assets.tile(ts, 5),  4)
    load(scr, ADDR_TILE6,  meteor_tileset_assets.tile(ts, 6),  4)
    load(scr, ADDR_TILE7,  meteor_tileset_assets.tile(ts, 7),  4)
    load(scr, ADDR_TILE8,  meteor_tileset_assets.tile(ts, 8),  4)
    load(scr, ADDR_TILE9,  meteor_tileset_assets.tile(ts, 9),  4)
    load(scr, ADDR_TILE10, meteor_tileset_assets.tile(ts, 10), 4)
    load(scr, ADDR_WALL,   meteor_tileset_assets.tile(ts, 11), 4)
    -- Dithered variants
    load(scr, ADDR_DTILE1,  meteor_tileset_assets.tile(ts, 1),  4)
    load(scr, ADDR_DTILE3,  meteor_tileset_assets.tile(ts, 3),  4)
    load(scr, ADDR_DTILE4,  meteor_tileset_assets.tile(ts, 4),  4)
    load(scr, ADDR_DTILE5,  meteor_tileset_assets.tile(ts, 5),  4)
    load(scr, ADDR_DTILE7,  meteor_tileset_assets.tile(ts, 7),  4)
    load(scr, ADDR_DTILE8,  meteor_tileset_assets.tile(ts, 8),  4)
    load(scr, ADDR_DTILE9,  meteor_tileset_assets.tile(ts, 9),  4)
    load(scr, ADDR_DTILE10, meteor_tileset_assets.tile(ts, 10), 4)
;

: load_border_sprites(scr = vimana.screen) (( -- ))
    let borders = [
        BDR_0,
        BDR_1,
        BDR_2,
        BDR_3,
        BDR_4,
        BDR_5,
        BDR_6,
        BDR_7,
        BDR_8,
        BDR_9,
        BDR_10,
        BDR_11,
        BDR_12,
        BDR_13,
        BDR_15,
        BDR_16,
        BDR_17,
        BDR_14
    ]
    let ?a = ADDR_BDR
    for (let ?p = 0; p < 18; p = p + 1)
        load(scr, a, borders[p], 5)
        a = a + 0xA0
;

:: load_planet_tiles(scr = vimana.screen, p = num) (( -- ))
    load_tileset_tiles(scr, PLANET_TILESET[p])
;

:: load_sprites(scr = vimana.screen) (( -- ))
    load_tileset_tiles(scr, 0)
    load(scr, ADDR_SELECT, SEL, 4)
    load(scr, ADDR_ROCKET_A, RKT_A, 4)
    load(scr, ADDR_ROCKET_B, RKT_B, 4)
    load(scr, ADDR_PL_H,  meteor_planet_assets.planet32(0),  16)
    load(scr, ADDR_PL_S,  meteor_planet_assets.planet32(1),  16)
    load(scr, ADDR_PL_W,  meteor_planet_assets.planet32(2),  16)
    load(scr, ADDR_PL_F,  meteor_planet_assets.planet32(3),  16)
    load(scr, ADDR_PL_SN, meteor_planet_assets.planet32(4),  16)
    load(scr, ADDR_PL_D,  meteor_planet_assets.planet32(5),  16)
    load(scr, ADDR_PL_G,  meteor_planet_assets.planet32(6),  16)
    load(scr, ADDR_PL_PR, meteor_planet_assets.planet32(7),  16)
    load(scr, ADDR_PL_GG, meteor_planet_assets.planet32(8),  16)
    load(scr, ADDR_PL_RS, meteor_planet_assets.planet32(9),  16)
    load(scr, ADDR_PL_NR, meteor_planet_assets.planet32(10), 16)
    load(scr, ADDR_PL_LL, meteor_planet_assets.planet32(11), 16)
    load(scr, ADDR_PL_OR, meteor_planet_assets.planet32(12), 16)
    load(scr, ADDR_PL_HN, meteor_planet_assets.planet32(13), 16)
    load(scr, ADDR_PL_TK, meteor_planet_assets.planet32(14), 16)
    load(scr, ADDR_PL_BK, meteor_planet_assets.planet32(15), 16)
    load(scr, ADDR_PL_GL, meteor_planet_assets.planet32(16), 16)
    load(scr, ADDR_PL_MT, meteor_planet_assets.planet32(17), 16)
    load(scr, ADDR_CHR_UP, CHR_UP, 9)
    load(scr, ADDR_CHR_DN, CHR_DN, 9)

    -- Rare metal sprites (Space, Time) — 5 frames each, tileset-agnostic.
    load(scr, ADDR_SPACE_BASE           , SPACE_F0, 4)
    load(scr, ADDR_SPACE_BASE +     0x80, SPACE_F1, 4)
    load(scr, ADDR_SPACE_BASE + 2 * 0x80, SPACE_F2, 4)
    load(scr, ADDR_SPACE_BASE + 3 * 0x80, SPACE_F3, 4)
    load(scr, ADDR_SPACE_BASE + 4 * 0x80, SPACE_F4, 4)
    load(scr, ADDR_TIME_BASE            , TIME_F0,  4)
    load(scr, ADDR_TIME_BASE  +     0x80, TIME_F1,  4)
    load(scr, ADDR_TIME_BASE  + 2 * 0x80, TIME_F2,  4)
    load(scr, ADDR_TIME_BASE  + 3 * 0x80, TIME_F3,  4)
    load(scr, ADDR_TIME_BASE  + 4 * 0x80, TIME_F4,  4)

    -- Border sprites (# planets × 5 types)
    load_border_sprites(scr)

    -- Mini planet sprites (16x16, 4bpp — downscaled from 32x32)
    let minis = [
        meteor_planet_assets.planet16(0),  meteor_planet_assets.planet16(1),
        meteor_planet_assets.planet16(2),  meteor_planet_assets.planet16(3),
        meteor_planet_assets.planet16(4),  meteor_planet_assets.planet16(5),
        meteor_planet_assets.planet16(6),  meteor_planet_assets.planet16(7),
        meteor_planet_assets.planet16(8),  meteor_planet_assets.planet16(9),
        meteor_planet_assets.planet16(10), meteor_planet_assets.planet16(11),
        meteor_planet_assets.planet16(12), meteor_planet_assets.planet16(13),
        meteor_planet_assets.planet16(14), meteor_planet_assets.planet16(15),
        meteor_planet_assets.planet16(16), meteor_planet_assets.planet16(17)
    ]
    for (let ?mp = 0; mp < 18; mp = mp + 1)
        load(scr, ADDR_MINI_PL + mp * 0x80, minis[mp], 4)
;

:: chr_up_addr() (( num ))
    <- ADDR_CHR_UP
;

:: chr_dn_addr() (( num ))
    <- ADDR_CHR_DN
;
