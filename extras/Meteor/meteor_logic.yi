cask meteor_logic

bring stdr
bring vimana

bring meteor_model

-- ─────────────────────────────────────────────────────────────────────────────
-- PRNG
-- ─────────────────────────────────────────────────────────────────────────────

def ?seed = 12345

:: seed_prng(sys = vimana.system) (( -- ))
    let dt = sys.datetime()
    seed = dt.second() + dt.minute() * 60 + dt.hour() * 3600 + dt.day() * 17 + dt.month() * 31
    if seed == 0
        seed = 1
;

: prng() (( num ))
    seed = (seed * 1103515245 + 12345) % 65536
    if seed < 0
        seed = 0 - seed
    <- seed
;

: prng_range(n = num) (( num ))
    <- prng() % n
;

: sqrt_approx(v = num) (( num ))
    if v <= 0
        <- 0
    let ?x = v * 0.5 + 0.5
    for (let ?i = 0; i < 8; i = i + 1)
        x = 0.5 * (x + v / x)
    <- x
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Planet-weighted element distribution (cumulative thresholds out of 10000)
-- Air=1, Fire=2, Water=3, Soil=4, Iron=5, Zap=6, Herb=7, Dark=8, Zoo=9, Glow=10
-- EALTHAL:  Soil=22.12, Air=22.12, Water=22.12, Fire=22.12, Zoo=11.06, Glow=0.46
-- SASSAZI:  Soil=36.24, Air=18.12, Fire=18.12, Iron=18.12, Zoo=9.05, Dark=0.35
-- WHALEEN:  Water=28.48, Air=17.79, Fire=17.79, Zap=17.79, Herb=17.79, Glow=0.36
-- FIEREEM:  Fire=39.84, Soil=14.94, Air=14.94, Iron=14.94, Zap=14.94, Dark=0.40
-- SERNOVA:  Fire=28.58, Zap=28.58, Glow=14.24, Zoo=14.24, Iron=12.24, Water=1.20, Dark=0.92
-- DOORSKY:  equal 11.11% each of Soil,Air,Water,Fire,Iron,Glow,Zoo,Zap,Dark (no Herb)
-- GRAFANT:  equal 25% Air, Soil, Iron, Zap
-- PERILLA:  Herb=36.0, Air=19.0, Water=19.0, Soil=19.0, Glow=7.0
-- GELGEEL:  Fire=33.33, Air=16.67, Water=16.67, Zap=16.67, Iron=16.66
-- RASTARL:  Glow=22.29, Air=22.29, Fire=22.29, Iron=22.29, Water=10.84
-- NEURALI:  Zap=51.95, Water=12.99, Iron=12.99, Herb=12.99, Dark=10.90
-- LUA=LUA:  Glow=35.71, Fire=16.07, Soil=16.07, Zap=16.07, Dark=16.08
-- ORKAROL:  equal 25% Glow, Water, Zoo, Herb
-- HOLONUL:  Zap=52.0, Iron=10.26, Water=10.26, Fire=10.26, Glow=17.22
-- METTEOR:  all 10 types equally at 10% each
-- ─────────────────────────────────────────────────────────────────────────────

: weighted_tile(p = num) (( num ))
