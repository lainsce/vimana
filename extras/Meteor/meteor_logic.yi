    -- Ealthal (p == 0)
    if p == 0
        if r < 2212
            <- 4
        if r < 4424
            <- 1
        if r < 6636
            <- 3
        if r < 8848
            <- 2
        if r < 8894
            <- 10
        <- 9
    -- Sassazi (p == 1)
    if p == 1
        if r < 3624
            <- 4
        if r < 5436
            <- 1
        if r < 7248
            <- 2
        if r < 9060
            <- 5
        if r < 9965
            <- 9
        <- 8
    -- Whaleen (p == 2)
    if p == 2
        if r < 2848
            <- 3
