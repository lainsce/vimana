:: get_ai_tile_n(n = num, x = num, y = num) (( num ))
    let idx = y * MAX_W + x
    if n == 0
        <- ai_tiles_0[idx]
    if n == 1
        <- ai_tiles_1[idx]
    <- ai_tiles_2[idx]
;

:: set_ai_tile_n(n = num, x = num, y = num, v = num) (( -- ))
    let idx = y * MAX_W + x
    if n == 0
        ai_tiles_0[idx] = v
    elif n == 1
        ai_tiles_1[idx] = v
    else
        ai_tiles_2[idx] = v
;

:: get_ai_gtimer_n(n = num, x = num, y = num) (( num ))
    let idx = y * MAX_W + x
    if n == 0
        <- ai_gtimer_0[idx]
    if n == 1
        <- ai_gtimer_1[idx]
    <- ai_gtimer_2[idx]
;
:: set_ai_gtimer_n(n = num, x = num, y = num, v = num) (( -- ))
    let idx = y * MAX_W + x
    if n == 0
        ai_gtimer_0[idx] = v
    elif n == 1
        ai_gtimer_1[idx] = v
    else
        ai_gtimer_2[idx] = v
;
:: get_ai_gdest_n(n = num, x = num, y = num) (( num ))
    let idx = y * MAX_W + x
    if n == 0
        <- ai_gdest_0[idx]
    if n == 1
        <- ai_gdest_1[idx]
    <- ai_gdest_2[idx]
;
:: set_ai_gdest_n(n = num, x = num, y = num, v = num) (( -- ))
    let idx = y * MAX_W + x
    if n == 0
        ai_gdest_0[idx] = v
    elif n == 1
        ai_gdest_1[idx] = v
    else
        ai_gdest_2[idx] = v
;
:: place_ai_garbage_n(n = num, x = num, y = num, dest = num) (( -- ))
    set_ai_tile_n(n, x, y, GARBAGE)
    set_ai_gtimer_n(n, x, y, PLANET_RT[ai_assigns[n]])
    set_ai_gdest_n(n, x, y, dest)
;

-- Backward-compat wrappers (slot 0)
:: get_ai_tile(x = num, y = num) (( num ))
    <- ai_tiles_0[y * MAX_W + x]
;
:: set_ai_tile(x = num, y = num, v = num) (( -- ))
    ai_tiles_0[y * MAX_W + x] = v
;

:: get_ai_sent_n(n = num) (( num )) <- ai_sent_arr[n] ;
:: add_ai_sent_n(n = num, v = num) (( -- )) ai_sent_arr[n] = ai_sent_arr[n] + v ;
:: get_ai_score_n(n = num) (( num )) <- ai_score_arr[n] ;
:: add_ai_score_n(n = num, v = num) (( -- )) ai_score_arr[n] = ai_score_arr[n] + v ;
:: get_ai_rise_timer_n(n = num) (( num )) <- ai_rise_timer_arr[n] ;
:: set_ai_rise_timer_n(n = num, v = num) (( -- )) ai_rise_timer_arr[n] = v ;
:: inc_ai_rise_timer_n(n = num) (( -- )) ai_rise_timer_arr[n] = ai_rise_timer_arr[n] + 1 ;
:: get_ai_lives_n(n = num) (( num )) <- ai_lives_arr[n] ;
:: set_ai_lives_n(n = num, v = num) (( -- )) ai_lives_arr[n] = v ;
:: dec_ai_lives_n(n = num) (( -- ))
    if ai_lives_arr[n] > 0
        ai_lives_arr[n] = ai_lives_arr[n] - 1
;

:: get_ai_recv_flash_n(n = num) (( num )) <- ai_recv_flash_arr[n] ;
:: set_ai_recv_flash_n(n = num, v = num) (( -- )) ai_recv_flash_arr[n] = v ;
:: dec_ai_recv_flash_n(n = num) (( -- ))
    if ai_recv_flash_arr[n] > 0
        ai_recv_flash_arr[n] = ai_recv_flash_arr[n] - 1
;
:: get_ai_recv_count_n(n = num) (( num )) <- ai_recv_count_arr[n] ;
:: set_ai_recv_count_n(n = num, v = num) (( -- )) ai_recv_count_arr[n] = v ;
:: get_ai_launch_flash_n(n = num) (( num )) <- ai_launch_flash_arr[n] ;
:: set_ai_launch_flash_n(n = num, v = num) (( -- )) ai_launch_flash_arr[n] = v ;
:: dec_ai_launch_flash_n(n = num) (( -- ))
    if ai_launch_flash_arr[n] > 0
        ai_launch_flash_arr[n] = ai_launch_flash_arr[n] - 1
;
:: get_ai_launch_col_n(n = num) (( num )) <- ai_launch_col_arr[n] ;
:: set_ai_launch_col_n(n = num, v = num) (( -- )) ai_launch_col_arr[n] = v ;
:: get_ai_launch_y_n(n = num) (( num )) <- ai_launch_y_arr[n] ;
:: set_ai_launch_y_n(n = num, v = num) (( -- )) ai_launch_y_arr[n] = v ;
:: get_ai_launch_len_n(n = num) (( num )) <- ai_launch_len_arr[n] ;
:: set_ai_launch_len_n(n = num, v = num) (( -- )) ai_launch_len_arr[n] = v ;
:: get_ai_launch_dir_n(n = num) (( num )) <- ai_launch_dir_arr[n] ;
:: set_ai_launch_dir_n(n = num, v = num) (( -- )) ai_launch_dir_arr[n] = v ;

-- Backward-compat scalar wrappers
:: get_ai_sent() (( num )) <- ai_sent_arr[0] ;
:: add_ai_sent(v = num) (( -- )) ai_sent_arr[0] = ai_sent_arr[0] + v ;
:: get_ai_score() (( num )) <- ai_score_arr[0] ;
:: add_ai_score(v = num) (( -- )) ai_score_arr[0] = ai_score_arr[0] + v ;

:: get_ai_rise_timer() (( num )) <- ai_rise_timer_arr[0] ;
:: set_ai_rise_timer(v = num) (( -- )) ai_rise_timer_arr[0] = v ;
:: inc_ai_rise_timer() (( -- )) ai_rise_timer_arr[0] = ai_rise_timer_arr[0] + 1 ;

:: ai_field_w_n(n = num) (( num ))
    <- PLANET_W[ai_assigns[n]]
;
:: ai_rise_rate_n(n = num) (( num ))
    <- PLANET_RATE[ai_assigns[n]]
;

:: get_vs_submode() (( num )) <- vs_submode ;
:: set_vs_submode(v = num) (( -- )) vs_submode = v ;
:: get_ai_difficulty() (( num )) <- ai_difficulty ;
:: set_ai_difficulty(v = num) (( -- )) ai_difficulty = v ;
:: get_player_lives() (( num )) <- player_lives ;
:: set_player_lives(v = num) (( -- )) player_lives = v ;
:: dec_player_lives() (( -- )) player_lives = player_lives - 1 ;
:: get_ai_lives() (( num )) <- ai_lives ;
:: set_ai_lives(v = num) (( -- )) ai_lives = v ;
:: dec_ai_lives() (( -- )) ai_lives = ai_lives - 1 ;

:: get_cpu_count() (( num )) <- cpu_count ;
:: set_cpu_count(v = num) (( -- )) cpu_count = v ;
:: get_ai_assign(slot = num) (( num )) <- ai_assigns[slot] ;
:: set_ai_assign(slot = num, p = num) (( -- )) ai_assigns[slot] = p ;
:: clear_excess_assigns() (( -- ))
    for (let ?i = cpu_count; i < 3; i = i + 1)
        ai_assigns[i] = -1
;
:: all_ai_assigned() (( bool ))
    for (let ?i = 0; i < cpu_count; i = i + 1)
        if ai_assigns[i] < 0
            <- false
    <- true
;
:: assign_ai_planet(p = num) (( -- ))
    -- If already assigned, remove it
    for (let ?i = 0; i < cpu_count; i = i + 1)
        if ai_assigns[i] == p
            ai_assigns[i] = -1
            <- 
    -- Otherwise assign to lowest open slot
    for (let ?j = 0; j < cpu_count; j = j + 1)
        if ai_assigns[j] < 0
            ai_assigns[j] = p
            <-
;
:: ai_assign_label(p = num) (( num ))
    -- Returns 1/2/3 if planet p is assigned to a slot, 0 if not
    for (let ?i = 0; i < 3; i = i + 1)
        if ai_assigns[i] == p
            <- i + 1
    <- 0
;
:: get_countdown() (( num )) <- countdown ;
:: set_countdown(v = num) (( -- )) countdown = v ;
:: dec_countdown() (( -- ))
    if countdown > 0
        countdown = countdown - 1
;

:: clear_ai_n(n = num) (( -- ))
    for (let ?i = 0; i < MAX_CELLS; i = i + 1)
        if n == 0
            ai_tiles_0[i] = 0
            ai_gtimer_0[i] = 0
            ai_gdest_0[i] = 0
        elif n == 1
            ai_tiles_1[i] = 0
            ai_gtimer_1[i] = 0
            ai_gdest_1[i] = 0
        else
            ai_tiles_2[i] = 0
            ai_gtimer_2[i] = 0
            ai_gdest_2[i] = 0
    ai_rise_timer_arr[n] = 0
;

:: clear_all_ais() (( -- ))
    for (let ?n = 0; n < 3; n = n + 1)
        clear_ai_n(n)
        ai_sent_arr[n] = 0
        ai_score_arr[n] = 0
        ai_lives_arr[n] = 3
;

:: clear_ai() (( -- ))
    clear_ai_n(0)
;

:: clear_ai_field() (( -- ))
    clear_ai_n(0)
;

:: get_flick_col() (( num )) <- flick_col ;
:: set_flick_col(v = num) (( -- )) flick_col = v ;
:: get_flick_tile() (( num )) <- flick_tile ;
:: set_flick_tile(v = num) (( -- )) flick_tile = v ;
:: get_flick_from() (( num )) <- flick_from ;
:: set_flick_from(v = num) (( -- )) flick_from = v ;
:: get_flick_off() (( num )) <- flick_off ;
:: set_flick_off(v = num) (( -- )) flick_off = v ;
:: get_flick_vel() (( num )) <- flick_vel ;
:: set_flick_vel(v = num) (( -- )) flick_vel = v ;
:: get_flick_cooldown() (( num )) <- flick_cooldown ;
:: set_flick_cooldown(v = num) (( -- )) flick_cooldown = v ;

-- ─────────────────────────────────────────────────────────────────────────────
-- Astral Adventure accessors and helpers
-- ─────────────────────────────────────────────────────────────────────────────

:: get_astral_path() (( num )) <- astral_path ;
:: set_astral_path(v = num) (( -- )) astral_path = v ;

:: get_astral_pos() (( num )) <- astral_pos ;
:: set_astral_pos(v = num) (( -- )) astral_pos = v ;

:: get_astral_at_ealthal() (( bool )) <- astral_at_ealthal ;
:: set_astral_at_ealthal(v = bool) (( -- )) astral_at_ealthal = v ;

:: get_astral_max_single() (( num )) <- astral_max_single ;
:: set_astral_max_single(v = num) (( -- )) astral_max_single = v ;

:: get_astral_screen_clear() (( bool )) <- astral_screen_clear ;
:: set_astral_screen_clear(v = bool) (( -- )) astral_screen_clear = v ;

:: reset_astral_mission() (( -- ))
    astral_max_single = 0
    astral_screen_clear = false
;

-- Current planet ID for the active Astral step
:: astral_planet() (( num ))
    if astral_at_ealthal
        <- P_EALTHAL
    if astral_path == ASTRAL_GAMMA
        <- ASTRAL_GAMMA_SEQ[astral_pos]
    if astral_path == ASTRAL_BETA
        <- ASTRAL_BETA_SEQ[astral_pos]
    <- ASTRAL_ALPHA_SEQ[astral_pos]
;

:: astral_path_len() (( num ))
    if astral_path == ASTRAL_GAMMA
        <- ASTRAL_GAMMA_LEN
    if astral_path == ASTRAL_BETA
        <- ASTRAL_BETA_LEN
    <- ASTRAL_ALPHA_LEN
;

-- True if the current step is the path's final boss
:: astral_is_boss() (( bool ))
    if astral_at_ealthal
        <- false
    <- astral_pos == astral_path_len() - 1
;

:: astral_mission_type() (( num ))
    <- ASTRAL_MISS_TYPE[astral_planet()]
;

:: astral_mission_target() (( num ))
    <- ASTRAL_MISS_TARGET[astral_planet()]
;

-- True if current mission involves a VS opponent
:: astral_is_vs() (( bool ))
    let mt = ASTRAL_MISS_TYPE[astral_planet()]
    <- mt == AMISS_WIN || mt == AMISS_VS3
;

-- CPU count for this mission (1 or 3)
:: astral_cpu_count() (( num ))
    let mt = ASTRAL_MISS_TYPE[astral_planet()]
    if mt == AMISS_VS3
        <- 3
    if astral_is_boss() && astral_path == ASTRAL_GAMMA
        <- 3
    <- 1
;

-- AI difficulty for this mission (1–4)
:: astral_difficulty() (( num ))
    if astral_is_boss() && astral_path == ASTRAL_GAMMA
        <- 4
    if astral_planet() == P_LUALUA
        <- 2
    <- 3
;

:: astral_path_name() (( string ))
    if astral_path == ASTRAL_GAMMA
        <- "TRUE PATH"
    if astral_path == ASTRAL_BETA
        <- "TWINKLE PATH"
    <- "TRICKY PATH"
;

:: astral_planet_name() (( string ))
    <- PLANET_NAMES[astral_planet()]
;

:: astral_planet_desc() (( string ))
    <- PLANET_DESC[astral_planet()]
;

:: astral_mission_desc() (( string ))
    let mt = ASTRAL_MISS_TYPE[astral_planet()]
    let p  = astral_planet()
    if mt == AMISS_WIN
        if astral_is_boss() && astral_path == ASTRAL_GAMMA
            <- "Win vs. True Metteor!"
        if p == P_EALTHAL || p == P_WHALEEN
            <- "Win within 2:30!"
        <- "Win against it!"
    if mt == AMISS_LAUNCH_N
        let tgt = ASTRAL_MISS_TARGET[p]
        if tgt == 100
            <- "Launch 100 meteors!"
        if tgt == 200
            <- "Launch 200 meteors!"
        <- "Launch 50 meteors!"
    if mt == AMISS_CLEAR
        <- "Clear the screen!"
    if mt == AMISS_AT_ONCE
        <- "Launch 30 at once!"
    if mt == AMISS_WATER_30
        <- "Launch 30 Water!"
    if mt == AMISS_VS3
        <- "Win vs. 3 opponents!"
    <- "???"
;

-- Advance the journey after a win. Returns true when the journey is complete.
:: advance_astral() (( bool ))
    if astral_at_ealthal
        astral_at_ealthal = false
        astral_path = ASTRAL_GAMMA
        astral_pos = 0
        <- false
    if astral_is_boss()
        <- true
    astral_pos = astral_pos + 1
    <- false
;

-- Drop to a lower path after a fail. Returns true on game-over (no lower path).
:: fail_astral() (( bool ))
    if astral_at_ealthal
        astral_at_ealthal = false
        astral_path = ASTRAL_BETA
        astral_pos = 0
        <- false
    if astral_is_boss()
        <- true
    if astral_path == ASTRAL_ALPHA
        <- true
    if astral_path == ASTRAL_GAMMA
        astral_path = ASTRAL_BETA
        <- false
    -- On Beta: drop to Alpha at the same index
    astral_path = ASTRAL_ALPHA
    <- false
;

-- Full reset for a new Astral Adventure run
:: reset_astral() (( -- ))
    astral_path = ASTRAL_GAMMA
    astral_pos = 0
    astral_at_ealthal = true
    astral_max_single = 0
    astral_screen_clear = false
;
