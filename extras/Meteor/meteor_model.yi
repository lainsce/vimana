-- ─────────────────────────────────────────────────────────────────────────────
-- Dirty flag
-- ─────────────────────────────────────────────────────────────────────────────

def ?dirty = true

:: mark_dirty() (( -- ))
    dirty = true
;

:: is_dirty() (( bool ))
    let d = dirty
    dirty = false
    <- d
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Accessors
-- ─────────────────────────────────────────────────────────────────────────────

:: field_w() (( num ))
    <- PLANET_W[planet]
;

:: field_grav() (( num ))
    <- PLANET_GRAV[planet]
;

:: field_atmo() (( num ))
    <- PLANET_ATMO[planet]
;

:: get_launch_count() (( num ))
    <- launch_count
;

:: inc_launch_count() (( -- ))
    launch_count = launch_count + 1
;

:: reset_launch_count() (( -- ))
    launch_count = 0
;

:: get_launch_mode() (( num ))
    <- launch_mode
;

:: get_launch_target() (( num ))
    <- launch_target
;

:: get_launch_count_action() (( num ))
    <- launch_count_action
;

:: compute_launch_params(cargo = num) (( -- ))
    launch_mode = LM_NORMAL
    launch_target = 20
    launch_count_action = 1

    -- Grafantz: fuel mechanic
    if planet == P_GRAFANT
        if graf_fuel
            launch_mode = LM_INSTANT
        else
            launch_mode = LM_DUD
        launch_target = 0
        launch_count_action = 0
        <-

    -- Doorheaven: always instant
    if planet == P_DOORSKY
        launch_mode = LM_INSTANT
        launch_target = 0
        launch_count_action = 0
        <-

    -- Sasazi: conditional on cargo
    if planet == P_SASAZI
        if cargo < 7
            launch_mode = LM_NORMAL
            launch_target = 20
            launch_count_action = 0
            <-
        let n = launch_count
        if n == 0
            launch_target = 4
        elif n >= 1 && n <= 3
            launch_target = 2
        elif n == 4 || n == 5
            launch_target = 6
        else
            launch_mode = LM_DUD
            launch_target = 0
            launch_count_action = -1
            <-
        launch_count_action = 1
        <-

    let n = launch_count

    if planet == P_EALTHAL
        if n == 0
            launch_target = 5
        elif n == 1
            launch_target = 3
        elif n == 2
            launch_target = 6
        elif n == 3
            launch_target = 11
        else
            launch_target = 20
            launch_count_action = -1
        <-

    if planet == P_FIEREEM
        if n == 0
            launch_target = 3
        elif n == 1
            launch_target = 8
        elif n == 2
            launch_target = 11
        else
            launch_target = 20
            launch_count_action = -1
        <-

    if planet == P_WHALEEN
        if n == 0
            launch_target = 4
        elif n == 1
            launch_target = 6
        elif n == 2
            launch_target = 3
        elif n == 3
            launch_target = 3
        elif n == 4
            launch_target = 9
        else
            launch_target = 20
            launch_count_action = -1
        <-

    if planet == P_SERNOVA
        if n == 0
            launch_target = 12
        elif n == 1
            launch_target = 7
        elif n == 2
            launch_target = 8
        elif n == 3
            launch_target = 12
        else
            launch_target = 20
            launch_count_action = -1
        <-

    if planet == P_PERILLA
        if n == 0
            launch_target = 6
        elif n == 1
            launch_target = 9
        elif n == 2
            launch_target = 10
        else
            launch_target = 20
            launch_count_action = -1
        <-

    if planet == P_LUALUA
        -- Lunar gravity: easy ignitions, floaty launches
        if n == 0
            launch_target = 4
        elif n == 1
            launch_target = 6
        elif n == 2
            launch_target = 8
        else
            launch_target = 14
            launch_count_action = -1
        <-

    if planet == P_TEKHNIS
        -- Loom cadence: steady industrial rhythm
        if n == 0
            launch_target = 6
            launch_count_action = 0
        elif n == 1
            launch_target = 6
            launch_count_action = 0
        elif n == 2
            launch_target = 6
            launch_count_action = 0
        elif n == 3
            launch_target = 6
            launch_count_action = 0
        elif n == 4
            launch_target = 6
            launch_count_action = 0
        else
            launch_target = 6
            launch_count_action = 0
        <-

    if planet == P_BELLIKO
        -- Volatile war cadence: quick strikes then heavy bombardment
        if n == 0
            launch_target = 4
        elif n == 1
            launch_target = 4
        elif n == 2
            launch_target = 10
        elif n == 3
            launch_target = 5
        elif n == 4
            launch_target = 14
        else
            launch_target = 20
            launch_count_action = -1
        <-

    if planet == P_GAUSSLE
        -- Factory production line: steady rhythmic output with increasing pressure
        if n == 0
            launch_target = 5
        elif n == 1
            launch_target = 6
        elif n == 2
            launch_target = 7
        elif n == 3
            launch_target = 9
        elif n == 4
            launch_target = 11
        elif n == 5
            launch_target = 13
        else
            launch_target = 18
            launch_count_action = -1
        <-

    if planet == P_METTEOR
        if n == 0 || n == 2
            launch_target = 10
        elif n == 1 || n == 3
            launch_target = 12
        else
            launch_target = 20
            launch_count_action = -1
        <-

    if planet == P_GELGEEL
        if n == 0 || n == 1
            launch_target = 2
        elif n == 2 || n == 3
            launch_target = 3
        elif n == 4 || n == 5
            launch_target = 4
        elif n == 6
            launch_target = 5
        else
            launch_mode = LM_INSTANT
            launch_target = 0
            launch_count_action = -1
        <-

    if planet == P_RASTARL
        if n == 0
            launch_target = 8
        elif n == 1
            launch_target = 6
        elif n == 2
            launch_target = 10
        elif n == 3
            launch_target = 8
        elif n == 4
            launch_target = 12
        elif n == 5 || n == 6
            launch_mode = LM_INSTANT
            launch_target = 0
            launch_count_action = 0
        else
            launch_target = 20
            launch_count_action = -1
        <-

    if planet == P_NEURALI
        if n == 0
            launch_target = 10
        elif n == 1
            launch_target = 8
        elif n == 2
            launch_target = 6
        elif n == 3
            launch_target = 12
        elif n == 4
            launch_target = 8
        else
            launch_mode = LM_INSTANT
            launch_target = 0
            launch_count_action = -1
        <-

    if planet == P_ORKAROL
        -- Very high ignition: easy targets, 5-7 launches per screen
        if n == 0
            launch_target = 3
        elif n == 1
            launch_target = 3
        elif n == 2
            launch_target = 4
        elif n == 3
            launch_target = 4
        elif n == 4
            launch_target = 5
        elif n == 5
            launch_target = 5
        elif n == 6
            launch_target = 6
        else
            launch_target = 14
            launch_count_action = -1
        <-

    if planet == P_HOLONULL
        -- Null-void escalation: starts modest, reaches full-clear power by launch 3
        if n == 0
            launch_target = 5
        elif n == 1
            launch_target = 7
        elif n == 2
            launch_target = 10
        elif n == 3
            launch_target = 14
        else
            launch_target = 18
            launch_count_action = -1
        <-

    -- Any per-planet launch target above the field height becomes an
    -- instant rocket: the stack is too tall to lerp, so it just clears.
    if launch_target > MAX_H
        launch_mode = LM_INSTANT
;

:: has_graf_fuel() (( bool ))
    <- graf_fuel
;

:: set_graf_fuel(v = bool) (( -- ))
    graf_fuel = v
;

:: set_graf_fuel_timer(v = num) (( -- ))
    graf_fuel_timer = v
;

:: tick_graf_fuel() (( -- ))
    if !graf_fuel
        <-
    if graf_fuel_timer > 0
        graf_fuel_timer = graf_fuel_timer - 1
        if graf_fuel_timer <= 0
            graf_fuel = false
;

:: reset_graf_fuel() (( -- ))
    graf_fuel = false
    graf_fuel_timer = 0
;

-- Rare metal clock: advanced once per frame in process_phase, not affected by
-- speeder. When it reaches RARE_CLOCK_MAX the next rain_tiles rolls the 1-in-N
-- chance once, then the clock resets.
:: tick_rare_clock() (( -- ))
    rare_clock = rare_clock + 1
    if rare_clock >= RARE_CLOCK_MAX
        rare_pending = true
        rare_clock = 0
;

:: rare_is_pending() (( bool ))
    <- rare_pending
;

:: consume_rare_pending() (( -- ))
    rare_pending = false
;

:: reset_rare_clock() (( -- ))
    rare_clock = 0
    rare_pending = false
;

:: get_rare_metal() (( num ))
    <- PLANET_RARE[planet]
;

:: is_rare_metal(t = num) (( bool ))
    <- t == SPACE || t == TIME
;

-- Annihilation timer: 1s (60f) for width 7, up to 3s (180f) for width 11
:: annihilate_time() (( num ))
    <- 60 + (field_w() - 7) * 30
;

-- Speeder Factor (time shift rate): Geolyte = 6. When speeder is active the
-- spawn interval is divided by this factor (6x faster spawns).
:: rise_rate() (( num ))
    let r = PLANET_RATE[planet]
    if speeder
        <- stdr.floor(r / 6)
    <- r
;

:: field_x() (( num ))
    <- FIELD_ZONE_X + stdr.floor((FIELD_ZONE_W - field_w() * CELL_PX) / 2)
;

:: ai_field_w() (( num ))
    <- PLANET_W[ai_planet]
;

:: ai_planet_name() (( string ))
    <- PLANET_NAMES[ai_planet]
;

:: ai_rise_rate() (( num ))
    <- PLANET_RATE[ai_planet]
;

:: planet_name() (( string ))
    <- PLANET_NAMES[planet]
;

:: planet_desc() (( string ))
    <- PLANET_DESC[planet]
;

:: target() (( num ))
    if mode == MODE_100
        <- 100
    if mode == MODE_1000
        <- 1000
    <- 0
;

:: mode_name() (( string ))
    if mode == MODE_VS
        <- "VS"
    if mode == MODE_100
        <- "100-ELEMENT"
    if mode == MODE_230
        <- "2:30-TIMED"
    if mode == MODE_500
        <- "5:00-TIMED"
    if mode == MODE_ASTRAL
        <- "ASTRAL ADV."
    <- "1000-ELEMENT"
;

:: get_tile(x = num, y = num) (( num ))
    <- tiles[y * MAX_W + x]
;

:: set_tile(x = num, y = num, v = num) (( -- ))
    tiles[y * MAX_W + x] = v
;

:: get_matched(x = num, y = num) (( bool ))
    <- matched[y * MAX_W + x] == 1
;

:: get_matched_any(x = num, y = num) (( bool ))
    <- matched[y * MAX_W + x] >= 1
;

:: get_matched_val(x = num, y = num) (( num ))
    <- matched[y * MAX_W + x]
;

:: set_matched(x = num, y = num) (( -- ))
    matched[y * MAX_W + x] = 1
;

:: set_matched_stack(x = num, y = num) (( -- ))
    matched[y * MAX_W + x] = 2
;

:: clear_matched() (( -- ))
    for (let ?i = 0; i < MAX_CELLS; i = i + 1)
        matched[i] = 0
;

:: clear_selection() (( -- ))
    sel_x = -1
    sel_y = -1
;

:: has_selection() (( bool ))
    <- sel_x >= 0
;

:: clear_all() (( -- ))
    for (let ?i = 0; i < MAX_CELLS; i = i + 1)
        tiles[i] = 0
        matched[i] = 0
        garbage_timer[i] = 0
        garbage_dest[i] = 0
    phase = PH_INPUT
    phase_timer = 0
    sel_x = -1
    sel_y = -1
    sent = 0
    chain_sent = 0
    sent_flash = 0
    rise_timer = 0
    combo = 0
    match_flash = 0
    game_frames = 0
    received = 0
    speeder = false
    score = 0
    matched_count = 0
    last_cargo = 0
    rocket_sent_start = 0
    for (let ?ri = 0; ri < MAX_W; ri = ri + 1)
        rocket_off[ri] = 0
        rocket_vel[ri] = 0
        rocket_col_sent[ri] = 0
        rocket_top[ri] = MAX_H
    clear_all_ais()
    player_lives = 3
    countdown = 9000
    flick_col = -1
    flick_tile = 0
    flick_from = 0
    flick_off = 0
    flick_vel = 0
    flick_cooldown = 0
    -- Sync ai_planet from first assignment for backward compat
    if ai_assigns[0] >= 0
        ai_planet = ai_assigns[0]
;

-- ─────────────────────────────────────────────────────────────────────────────
-- State getters / setters
-- ─────────────────────────────────────────────────────────────────────────────

:: get_scene() (( num )) <- scene ;
:: set_scene(v = num) (( -- )) scene = v ;

:: get_planet() (( num )) <- planet ;
:: set_planet(v = num) (( -- )) planet = v ;

:: get_ai_planet() (( num )) <- ai_planet ;
:: set_ai_planet(v = num) (( -- )) ai_planet = v ;

:: get_mode() (( num )) <- mode ;
:: set_mode(v = num) (( -- )) mode = v ;

:: get_phase() (( num )) <- phase ;
:: set_phase(v = num) (( -- )) phase = v ;

:: get_phase_timer() (( num )) <- phase_timer ;
:: set_phase_timer(v = num) (( -- )) phase_timer = v ;
:: inc_phase_timer() (( -- )) phase_timer = phase_timer + 1 ;

:: get_sel_x() (( num )) <- sel_x ;
:: get_sel_y() (( num )) <- sel_y ;
:: set_sel(x = num, y = num) (( -- ))
    sel_x = x
    sel_y = y
;

:: get_sent() (( num )) <- sent ;
:: set_sent(v = num) (( -- )) sent = v ;
:: add_sent(v = num) (( -- ))
    sent = sent + v
    chain_sent = chain_sent + v
;

:: add_elem_session(tile = num, count = num) (( -- ))
    -- Skip invalid tiles and Garbage (tile 11)
    if tile < 1 || tile > 13 || tile == 11
        <-
    elem_session[tile - 1] = elem_session[tile - 1] + count
    elem_total[tile - 1] = elem_total[tile - 1] + count
;

:: clear_elem_session() (( -- ))
    for (let ?i = 0; i < 14; i = i + 1)
        elem_session[i] = 0
;

:: get_elem_session(idx = num) (( num )) <- elem_session[idx] ;
:: get_elem_total(idx = num) (( num )) <- elem_total[idx] ;

:: save_elem_total() (( -- ))
    let ?out = ""
    for (let ?i = 0; i < 14; i = i + 1)
        if i > 0
            out = stdr.str_concat(out, " ")
        out = stdr.str_concat(out, stdr.str(elem_total[i]))
    stdr.write_text_file(stdr.str_concat(stdr.home_dir(), "/.meteor_totals"), out)
;

:: load_elem_total() (( -- ))
    let path = stdr.str_concat(stdr.home_dir(), "/.meteor_totals")
    if !stdr.file_exists(path)
        <-
    let text = stdr.read_text_file(path)
    if stdr.is_null(text)
        <-
    let ?i = 0
    let ?start = 0
    let ?idx = 0
    let n = stdr.len(text)
    for (; i <= n && idx < 14; i = i + 1)
        let ch = stdr.slice(text, i, i + 1)
        if ch == " " || i == n
            if i > start
                let tok = stdr.slice(text, start, i)
                elem_total[idx] = stdr.num(tok)
                idx = idx + 1
            start = i + 1
;

:: get_chain_sent() (( num )) <- chain_sent ;
:: reset_chain_sent() (( -- )) chain_sent = 0 ;

:: get_sent_flash() (( num )) <- sent_flash ;
:: set_sent_flash(v = num) (( -- )) sent_flash = v ;
:: dec_sent_flash() (( -- ))
    if sent_flash > 0
        sent_flash = sent_flash - 1
;

:: get_rise_timer() (( num )) <- rise_timer ;
:: set_rise_timer(v = num) (( -- )) rise_timer = v ;
:: inc_rise_timer() (( -- )) rise_timer = rise_timer + 1 ;

:: get_combo() (( num )) <- combo ;
:: set_combo(v = num) (( -- )) combo = v ;
:: inc_combo() (( -- )) combo = combo + 1 ;

:: get_match_flash() (( num )) <- match_flash ;
:: set_match_flash(v = num) (( -- )) match_flash = v ;
:: get_max_run() (( num )) <- max_run ;
:: set_max_run(v = num) (( -- )) max_run = v ;
:: pop_sound() (( bool ))
    if sound_pending
        sound_pending = false
        <- true
    <- false
;
:: set_sound_pending() (( -- )) sound_pending = true ;
:: pop_rocket() (( bool ))
    if rocket_pending
        rocket_pending = false
        <- true
    <- false
;
:: set_rocket_pending() (( -- )) rocket_pending = true ;
:: pop_flick() (( bool ))
    if flick_pending
        flick_pending = false
        <- true
    <- false
;
:: set_flick_pending() (( -- )) flick_pending = true ;
:: pop_clear() (( bool ))
    if clear_pending
        clear_pending = false
        <- true
    <- false
;
:: set_clear_pending() (( -- )) clear_pending = true ;
:: dec_match_flash() (( -- ))
    if match_flash > 0
        match_flash = match_flash - 1
    if match_flash == 0 && combo > 0
        combo = 0
;

:: get_score() (( num )) <- score ;
:: add_score(v = num) (( -- )) score = score + v ;
:: get_matched_count() (( num )) <- matched_count ;
:: set_matched_count(v = num) (( -- )) matched_count = v ;
:: get_last_cargo() (( num )) <- last_cargo ;
:: set_last_cargo(v = num) (( -- )) last_cargo = v ;

:: get_game_frames() (( num )) <- game_frames ;
:: inc_game_frames() (( -- )) game_frames = game_frames + 1 ;

:: get_received() (( num )) <- received ;
:: add_received(v = num) (( -- )) received = received + v ;

:: get_speeder() (( bool )) <- speeder ;
:: toggle_speeder() (( -- )) speeder = !speeder ;

:: get_rocket_off(x = num) (( num )) <- rocket_off[x] ;
:: set_rocket_off(x = num, v = num) (( -- )) rocket_off[x] = v ;
:: get_rocket_vel(x = num) (( num )) <- rocket_vel[x] ;
:: set_rocket_vel(x = num, v = num) (( -- )) rocket_vel[x] = v ;
:: get_rocket_col_sent(x = num) (( num )) <- rocket_col_sent[x] ;
:: set_rocket_col_sent(x = num, v = num) (( -- )) rocket_col_sent[x] = v ;
:: get_rocket_top(x = num) (( num )) <- rocket_top[x] ;
:: set_rocket_top(x = num, v = num) (( -- )) rocket_top[x] = v ;
:: get_rocket_sent_start() (( num )) <- rocket_sent_start ;
:: set_rocket_sent_start(v = num) (( -- )) rocket_sent_start = v ;

:: get_garbage_timer(x = num, y = num) (( num )) <- garbage_timer[y * MAX_W + x] ;
:: set_garbage_timer(x = num, y = num, v = num) (( -- )) garbage_timer[y * MAX_W + x] = v ;
:: get_garbage_dest(x = num, y = num) (( num )) <- garbage_dest[y * MAX_W + x] ;
:: set_garbage_dest(x = num, y = num, v = num) (( -- )) garbage_dest[y * MAX_W + x] = v ;

:: place_garbage(x = num, y = num, dest = num) (( -- ))
    tiles[y * MAX_W + x] = GARBAGE
    garbage_timer[y * MAX_W + x] = PLANET_RT[planet]
    garbage_dest[y * MAX_W + x] = dest
;

