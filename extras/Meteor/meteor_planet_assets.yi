    elif p == 1: <- PLS32
    elif p == 16: <- PLGL32
    elif p == 7: <- PLPR32
    elif p == 13: <- PLHN32
    elif p == 8: <- PLGG32
    elif p == 14: <- PLTK32
    elif p == 9: <- PLRS32
    elif p == 4: <- PLSN32
    elif p == 6: <- PLG32
    elif p == 11: <- PLLL32
    elif p == 12: <- PLOR32
    elif p == 5: <- PLD32
    elif p == 15: <- PLBK32
    elif p == 10: <- PLNR32
    elif p == 17: <- PLMT32
    else: <- []
;

:: planet16(p = num) (( [num] ))
    if p == 0: <- PLH16
    elif p == 3: <- PLF16
    elif p == 2: <- PLW16
    elif p == 1: <- PLS16
    elif p == 16: <- PLGL16
    elif p == 7: <- PLPR16
    elif p == 13: <- PLHN16
    elif p == 8: <- PLGG16
    elif p == 14: <- PLTK16
    elif p == 9: <- PLRS16
    elif p == 4: <- PLSN16
    elif p == 6: <- PLG16
    elif p == 11: <- PLLL16
    elif p == 12: <- PLOR16
    elif p == 5: <- PLD16
    elif p == 15: <- PLBK16
    elif p == 10: <- PLNR16
    elif p == 17: <- PLMT16
    else: <- []
;
