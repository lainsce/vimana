-- ── SFX voice setup per planet ──────────────────────────────────────────────

: setup_sfx_voices(sys = vimana.system) (( -- ))
    let p = meteor_model.get_planet()
    if p == 0
        -- Ealthal: punchy military brass — sawtooth stabs
        sys.set_voice(4, vimana.wave_sawtooth)
        sys.set_envelope(4, 0, 5, 1, 3)
        -- V5: warm triangle harmony
        sys.set_voice(5, vimana.wave_triangle)
        sys.set_envelope(5, 0, 4, 1, 3)
    elif p == 1
        -- Sassazi: twangy narrow pulse — plucky Morricone guitar
        sys.set_voice(4, vimana.wave_pulse)
        sys.set_envelope(4, 0, 7, 1, 5)
        sys.set_pulse_width(4, 50)
        -- V5: triangle twang complement
        sys.set_voice(5, vimana.wave_triangle)
        sys.set_envelope(5, 0, 6, 1, 4)
    elif p == 2
        -- Whaleen: flowing triangle — oceanic bell tones
        sys.set_voice(4, vimana.wave_triangle)
        sys.set_envelope(4, 1, 9, 4, 8)
        -- V5: pulse shimmer complement
        sys.set_voice(5, vimana.wave_pulse)
        sys.set_envelope(5, 1, 8, 3, 6)
        sys.set_pulse_width(5, 80)
    elif p == 3
        -- Fiereem: aggressive pulse — raw rock crunch
        sys.set_voice(4, vimana.wave_pulse)
        sys.set_envelope(4, 0, 6, 2, 4)
        sys.set_pulse_width(4, 180)
        -- V5: triangle body complement
        sys.set_voice(5, vimana.wave_triangle)
        sys.set_envelope(5, 0, 5, 1, 3)
    elif p == 4
        -- Sernova: 50s/60s piano — triangle body, slow release
        sys.set_voice(4, vimana.wave_triangle)
        sys.set_envelope(4, 0, 7, 6, 8)
        -- V5: pulse bossa complement
        sys.set_voice(5, vimana.wave_pulse)
        sys.set_envelope(5, 0, 6, 5, 7)
        sys.set_pulse_width(5, 100)
    elif p == 5
        -- Doorsky: alien chatter — buzzy blips
        sys.set_voice(4, vimana.wave_pulse)
        sys.set_envelope(4, 0, 3, 0, 2)
        sys.set_pulse_width(4, 10)
        -- V5: triangle alien echo
        sys.set_voice(5, vimana.wave_triangle)
        sys.set_envelope(5, 0, 2, 0, 1)
    elif p == 6
        -- Grafant: hollow icy pulse — Phrygian cold stabs
        sys.set_voice(4, vimana.wave_pulse)
        sys.set_envelope(4, 0, 8, 1, 6)
        sys.set_pulse_width(4, 25)
        -- V5: triangle ice complement
        sys.set_voice(5, vimana.wave_triangle)
        sys.set_envelope(5, 0, 7, 1, 5)
    elif p == 7
        -- Perilla: tribal stone — deep nasal pulse
        sys.set_voice(4, vimana.wave_pulse)
        sys.set_envelope(4, 0, 5, 0, 3)
        sys.set_pulse_width(4, 25)
        -- V5: triangle stone echo
        sys.set_voice(5, vimana.wave_triangle)
        sys.set_envelope(5, 0, 4, 0, 2)
    elif p == 8
        -- Gelgeel: watery drip — triangle for liquid tone
        sys.set_voice(4, vimana.wave_triangle)
        sys.set_envelope(4, 1, 9, 3, 8)
        -- V5: pulse synth complement
        sys.set_voice(5, vimana.wave_pulse)
        sys.set_envelope(5, 1, 8, 2, 6)
        sys.set_pulse_width(5, 60)
    elif p == 9
        -- Rastarl: bright bell chime — triangle shimmer
        sys.set_voice(4, vimana.wave_triangle)
        sys.set_envelope(4, 0, 6, 2, 5)
        -- V5: pulse bell complement
        sys.set_voice(5, vimana.wave_pulse)
        sys.set_envelope(5, 0, 5, 1, 4)
        sys.set_pulse_width(5, 80)
    elif p == 10
        -- Neurali: digital stab — narrow pulse
        sys.set_voice(4, vimana.wave_pulse)
        sys.set_envelope(4, 0, 4, 1, 3)
        sys.set_pulse_width(4, 100)
        -- V5: triangle circuit complement
        sys.set_voice(5, vimana.wave_triangle)
        sys.set_envelope(5, 0, 3, 1, 2)
    elif p == 11
        -- Lua=Lua: ethereal moon tones — slow swell, long release
        sys.set_voice(4, vimana.wave_triangle)
        sys.set_envelope(4, 3, 11, 5, 11)
        -- V5: pulse moon complement
        sys.set_voice(5, vimana.wave_pulse)
        sys.set_envelope(5, 4, 10, 4, 10)
        sys.set_pulse_width(5, 90)
    elif p == 12
        -- Orkarol: sacred — warm organ triangle
        sys.set_voice(4, vimana.wave_triangle)
        sys.set_envelope(4, 2, 9, 5, 7)
        -- V5: pulse organ complement
        sys.set_voice(5, vimana.wave_pulse)
        sys.set_envelope(5, 2, 8, 4, 6)
        sys.set_pulse_width(5, 100)
    elif p == 13
        -- Holonull: neon glitch pulses
        sys.set_voice(4, vimana.wave_pulse)
        sys.set_envelope(4, 0, 6, 1, 5)
        sys.set_pulse_width(4, 90)
        sys.set_voice(5, vimana.wave_triangle)
        sys.set_envelope(5, 0, 5, 1, 4)
    elif p == 14
        -- Tekhnis: industrial loom — narrow pulse clockwork
        sys.set_voice(4, vimana.wave_pulse)
        sys.set_envelope(4, 0, 4, 0, 2)
        sys.set_pulse_width(4, 30)
        -- V5: triangle clockwork complement
        sys.set_voice(5, vimana.wave_triangle)
        sys.set_envelope(5, 0, 3, 0, 2)
    elif p == 15
        -- Belliko: war horn — sawtooth martial brass
        sys.set_voice(4, vimana.wave_sawtooth)
        sys.set_envelope(4, 0, 6, 2, 5)
        -- V5: pulse brass complement
        sys.set_voice(5, vimana.wave_pulse)
        sys.set_envelope(5, 0, 5, 1, 4)
        sys.set_pulse_width(5, 120)
    elif p == 16
        -- Gaussle: factory machinery — wide pulse hum, longer decay
        sys.set_voice(4, vimana.wave_pulse)
        sys.set_envelope(4, 1, 7, 3, 5)
        sys.set_pulse_width(4, 180)
        -- V5: sawtooth conveyor grind
        sys.set_voice(5, vimana.wave_sawtooth)
        sys.set_envelope(5, 0, 6, 2, 4)
    elif p == 17
        -- Metteor: boss fight — aggressive saw
        sys.set_voice(4, vimana.wave_sawtooth)
        sys.set_envelope(4, 0, 6, 2, 4)
        -- V5: triangle boss complement
        sys.set_voice(5, vimana.wave_triangle)
        sys.set_envelope(5, 0, 5, 1, 3)
    -- V6: universal bass voice — percussive triangle
    sys.set_voice(6, vimana.wave_triangle)
    sys.set_envelope(6, 0, 3, 0, 2)
;

-- ── SFX step ────────────────────────────────────────────────────────────────

: sfx_v0_at(idx = num) (( num ))
    let p = meteor_model.get_planet()
    if p == 0
        if sfx_tier == 0
            <- HTK_S0_V0[idx]
        if sfx_tier == 1
            <- HTK_S1_V0[idx]
        <- HTK_S2_V0[idx]
    elif p == 1
        if sfx_tier == 0
            <- SAS_S0_V0[idx]
        if sfx_tier == 1
            <- SAS_S1_V0[idx]
        <- SAS_S2_V0[idx]
    elif p == 2
        if sfx_tier == 0
            <- WAL_S0_V0[idx]
        if sfx_tier == 1
            <- WAL_S1_V0[idx]
        <- WAL_S2_V0[idx]
    elif p == 3
        if sfx_tier == 0
            <- FIR_S0_V0[idx]
        if sfx_tier == 1
            <- FIR_S1_V0[idx]
        <- FIR_S2_V0[idx]
    elif p == 4
        if sfx_tier == 0
            <- SRN_S0_V0[idx]
        if sfx_tier == 1
            <- SRN_S1_V0[idx]
        <- SRN_S2_V0[idx]
    elif p == 5
        if sfx_tier == 0
            <- DHV_S0_V0[idx]
        if sfx_tier == 1
            <- DHV_S1_V0[idx]
        <- DHV_S2_V0[idx]
    elif p == 6
        if sfx_tier == 0
            <- GRF_S0_V0[idx]
        if sfx_tier == 1
            <- GRF_S1_V0[idx]
        <- GRF_S2_V0[idx]
    elif p == 7
        if sfx_tier == 0
            <- PRL_S0_V0[idx]
        if sfx_tier == 1
            <- PRL_S1_V0[idx]
        <- PRL_S2_V0[idx]
    elif p == 8
        if sfx_tier == 0
            <- GEL_S0_V0[idx]
        if sfx_tier == 1
            <- GEL_S1_V0[idx]
        <- GEL_S2_V0[idx]
    elif p == 9
        if sfx_tier == 0
            <- RST_S0_V0[idx]
        if sfx_tier == 1
            <- RST_S1_V0[idx]
        <- RST_S2_V0[idx]
    elif p == 10
        if sfx_tier == 0
            <- NRL_S0_V0[idx]
        if sfx_tier == 1
            <- NRL_S1_V0[idx]
        <- NRL_S2_V0[idx]
    elif p == 11
        if sfx_tier == 0
            <- LLA_S0_V0[idx]
        if sfx_tier == 1
            <- LLA_S1_V0[idx]
        <- LLA_S2_V0[idx]
    elif p == 12
        if sfx_tier == 0
            <- ORK_S0_V0[idx]
        if sfx_tier == 1
            <- ORK_S1_V0[idx]
        <- ORK_S2_V0[idx]
    elif p == 13
        if sfx_tier == 0
            <- HOL_S0_V0[idx]
        if sfx_tier == 1
            <- HOL_S1_V0[idx]
        <- HOL_S2_V0[idx]
    elif p == 14
        if sfx_tier == 0
            <- TKS_S0_V0[idx]
        if sfx_tier == 1
            <- TKS_S1_V0[idx]
        <- TKS_S2_V0[idx]
    elif p == 15
        if sfx_tier == 0
            <- BLK_S0_V0[idx]
        if sfx_tier == 1
            <- BLK_S1_V0[idx]
        <- BLK_S2_V0[idx]
    elif p == 16
        if sfx_tier == 0
            <- GSS_S0_V0[idx]
        if sfx_tier == 1
            <- GSS_S1_V0[idx]
        <- GSS_S2_V0[idx]
    elif p == 17
        if sfx_tier == 0
            <- MTR_S0_V0[idx]
        if sfx_tier == 1
            <- MTR_S1_V0[idx]
        <- MTR_S2_V0[idx]
    <- 0
;

-- sfx_v1_at reinstated — V1 arrays repurposed as V5 harmony
