: setup_doorsky_bg(sys = vimana.system) (( -- ))
    -- V0: deep tritone swell pad — maximum sustain
    sys.set_voice(0, vimana.wave_triangle)
    sys.set_envelope(0, 12, 14, 13, 10)
    -- V2: triangle drone — max sustain, very slow attack/release for swell
    sys.set_voice(2, vimana.wave_triangle)
    sys.set_envelope(2, 10, 14, 12, 8)
    -- V3: triangle counter-drone — same long envelope
    sys.set_voice(3, vimana.wave_triangle)
    sys.set_envelope(3, 10, 14, 12, 8)
    -- Heavy lowpass — starts nearly closed, modulation does the breathing
    -- V1: slow pad triangle drift
    sys.set_voice(1, vimana.wave_triangle)
    sys.set_envelope(1, 8, 12, 10, 8)
    sys.set_filter(80, 12, 1)
    sys.set_filter_route(0, 1)
    sys.set_filter_route(1, 1)
    sys.set_filter_route(2, 1)
    sys.set_filter_route(3, 1)
