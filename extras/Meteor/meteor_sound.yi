    -- V0: Am open-fifth pad — triangle drone bed
    sys.set_voice(0, vimana.wave_triangle)
    sys.set_envelope(0, 3, 10, 7, 8)
    -- V2: loom bass — triangle with pulse-shaped attack
    sys.set_voice(2, vimana.wave_triangle)
    sys.set_envelope(2, 0, 7, 3, 5)
    -- V3: clockwork lead — narrow pulse mechanical melody
    sys.set_voice(3, vimana.wave_pulse)
    sys.set_envelope(3, 0, 5, 1, 3)
    sys.set_pulse_width(3, 30)
    -- V1: loom shuttle arp — narrow pulse mid
    sys.set_voice(1, vimana.wave_pulse)
    sys.set_envelope(1, 0, 5, 2, 4)
    sys.set_pulse_width(1, 40)
    sys.set_filter(550, 6, 1)
    sys.set_filter_route(0, 1)
    sys.set_filter_route(1, 1)
    sys.set_filter_route(2, 1)
    sys.set_filter_route(3, 1)
    -- V7: PSG percussion
    sys.set_voice(7, vimana.wave_psg)
    sys.set_envelope(7, 0, 2, 0, 1)
;

: setup_belliko_bg(sys = vimana.system) (( -- ))
    -- V0: Dm war pad — sawtooth sustain
    sys.set_voice(0, vimana.wave_sawtooth)
    sys.set_envelope(0, 2, 10, 6, 8)
    -- V2: heavy march bass — wide pulse for trench weight
    sys.set_voice(2, vimana.wave_pulse)
    sys.set_envelope(2, 0, 8, 4, 6)
    sys.set_pulse_width(2, 180)
    -- V3: trench horn lead — sawtooth bugle
    sys.set_voice(3, vimana.wave_sawtooth)
    sys.set_envelope(3, 0, 7, 2, 5)
    -- V1: war arp — gritty sawtooth mid
    sys.set_voice(1, vimana.wave_sawtooth)
    sys.set_envelope(1, 0, 6, 2, 4)
    sys.set_filter(500, 7, 1)
    sys.set_filter_route(0, 1)
    sys.set_filter_route(1, 1)
    sys.set_filter_route(2, 1)
    sys.set_filter_route(3, 1)
    -- V7: PSG percussion
    sys.set_voice(7, vimana.wave_psg)
    sys.set_envelope(7, 0, 2, 0, 1)
;

: setup_gaussle_bg(sys = vimana.system) (( -- ))
    -- V0: Em factory pad — pulse wave mechanical drone
    sys.set_voice(0, vimana.wave_pulse)
    sys.set_envelope(0, 2, 9, 5, 7)
    sys.set_pulse_width(0, 100)
    -- V2: conveyor bass — triangle for steady rhythm
    sys.set_voice(2, vimana.wave_triangle)
    sys.set_envelope(2, 0, 8, 4, 6)
    -- V3: mechanical whistle lead — narrow pulse alarm
    sys.set_voice(3, vimana.wave_pulse)
    sys.set_envelope(3, 0, 6, 2, 4)
    sys.set_pulse_width(3, 60)
    -- V1: factory arp — triangle mid-register
    sys.set_voice(1, vimana.wave_triangle)
    sys.set_envelope(1, 0, 7, 3, 5)
    sys.set_filter(600, 6, 1)
    sys.set_filter_route(0, 1)
    sys.set_filter_route(1, 1)
    sys.set_filter_route(2, 1)
    sys.set_filter_route(3, 1)
    -- V7: PSG percussion
    sys.set_voice(7, vimana.wave_psg)
    sys.set_envelope(7, 0, 2, 0, 1)
;

: setup_meteor_bg(sys = vimana.system) (( -- ))
    -- V0: dark Dm power pad — sawtooth sustain
    sys.set_voice(0, vimana.wave_sawtooth)
    sys.set_envelope(0, 2, 9, 5, 7)
    -- V2: aggressive sawtooth bass — raw harmonics, maximum bite
    sys.set_voice(2, vimana.wave_sawtooth)
    sys.set_envelope(2, 0, 7, 3, 5)
    -- V3: menacing lead — wide pulse for thick, ominous tone
    sys.set_voice(3, vimana.wave_pulse)
    sys.set_envelope(3, 0, 8, 4, 6)
    sys.set_pulse_width(3, 180)
    -- Lowpass: lets the aggression through but sweeps for drama
    -- V1: driving sawtooth villain arp
    sys.set_voice(1, vimana.wave_sawtooth)
    sys.set_envelope(1, 0, 4, 1, 3)
    sys.set_filter(700, 8, 1)
    sys.set_filter_route(0, 1)
    sys.set_filter_route(1, 1)
    sys.set_filter_route(2, 1)
    sys.set_filter_route(3, 1)
    -- V7: PSG percussion
    sys.set_voice(7, vimana.wave_psg)
    sys.set_envelope(7, 0, 2, 0, 1)
;

-- ── Filter & PWM modulation ─────────────────────────────────────────────────────

: modulate_bg(sys = vimana.system) (( -- ))
    let p = meteor_model.get_planet()
    if p == 0
        -- Ealthal: warm march filter + bugle PWM
        sys.set_filter(sweep32(bg_step, 350, 700), 5, 1)
        sys.set_pulse_width(3, 80 + sweep32(bg_step, 0, 40))
    elif p == 1
        -- Sassazi: dry filter sweep + subtle PWM
        sys.set_filter(sweep32(bg_step, 700, 1300), 5, 1)
        sys.set_pulse_width(2, 35 + sweep32(bg_step, 0, 20))
        sys.set_pulse_width(3, 50 + sweep32(bg_step, 0, 30))
    elif p == 2
        -- Whaleen: gentle wave-like filter swell
        sys.set_filter(sweep32(bg_step, 300, 700), 5, 2)
    elif p == 3
        -- Fiereem: filter sweep on lead + PWM on bass
        sys.set_filter(sweep32(bg_step, 400, 1000), 7, 1)
        sys.set_pulse_width(2, 180 + sweep32(bg_step, 0, 50))
    elif p == 4
        -- Sernova: bossa filter + PWM
        sys.set_filter(sweep32(bg_step, 350, 700), 5, 1)
        sys.set_pulse_width(3, 100 + sweep32(bg_step, 0, 40))
    elif p == 5
        -- Doorsky: filter opens/closes like breathing through vacuum
        sys.set_filter(sweep32(bg_step, 60, 500), 12, 1)
    elif p == 6
        -- Grafant: glacial bandpass sweep + subtle PWM shimmer
        sys.set_filter(sweep32(bg_step, 200, 900), 10, 2)
        sys.set_pulse_width(2, 25 + sweep32(bg_step, 0, 15))
        sys.set_pulse_width(3, 15 + sweep32(bg_step, 0, 12))
    elif p == 7
        -- Perilla: cave filter breathes + chant pulse width wobble
        sys.set_filter(sweep32(bg_step, 150, 500), 12, 1)
        sys.set_pulse_width(3, 20 + sweep32(bg_step, 0, 20))
    elif p == 8
        -- Gelgeel: energetic filter sweep + bass PWM grit
        sys.set_filter(sweep32(bg_step, 600, 1200), 6, 1)
        sys.set_pulse_width(2, 60 + sweep32(bg_step, 0, 40))
    elif p == 9
        -- Rastarl: subtle shimmer — no heavy modulation needed
        sys.set_pulse_width(2, 128)
    elif p == 10
        -- Neurali: lowpass sweep + PWM for mechanical pulse
        sys.set_filter(sweep32(bg_step, 300, 900), 7, 1)
        sys.set_pulse_width(2, 120 + sweep32(bg_step, 0, 40))
    elif p == 11
        -- Lua=Lua: gentle bandpass drift for moonlit shimmer
        sys.set_filter(sweep32(bg_step, 250, 550), 6, 2)
    elif p == 12
        -- Orkarol: warm cathedral filter drift
        sys.set_filter(sweep32(bg_step, 300, 500), 5, 1)
    elif p == 13
        -- Holonull: neon warp shimmer with pulse width breath
        sys.set_filter(sweep32(bg_step, 300, 650), 6, 2)
        sys.set_pulse_width(0, 100 + sweep32(bg_step, 0, 40))
        sys.set_pulse_width(1, 90 + sweep32(bg_step, 0, 30))
    elif p == 14
        -- Tekhnis: loom clockwork — narrow pulse width wobble + mechanical filter breath
        sys.set_filter(sweep32(bg_step, 350, 800), 7, 1)
        sys.set_pulse_width(3, 25 + sweep32(bg_step, 0, 15))
        sys.set_pulse_width(1, 35 + sweep32(bg_step, 0, 20))
    elif p == 15
        -- Belliko: war march — heavy filter surge + brass lead PWM
        sys.set_filter(sweep32(bg_step, 300, 900), 8, 1)
        sys.set_pulse_width(2, 170 + sweep32(bg_step, 0, 40))
    elif p == 16
        -- Gaussle: factory breath — mechanical filter + conveyor PWM
        sys.set_filter(sweep32(bg_step, 500, 1000), 6, 1)
        sys.set_pulse_width(0, 100 + sweep32(bg_step, 0, 40))
        sys.set_pulse_width(3, 60 + sweep32(bg_step, 0, 30))
    elif p == 17
        -- Metteor: wide filter sweep for dramatic boss intensity + lead PWM throb
        sys.set_filter(sweep32(bg_step, 400, 1200), 8, 1)
        sys.set_pulse_width(3, 150 + sweep32(bg_step, 0, 60))
;

-- ── Step playback per planet ────────────────────────────────────────────────

: step_ealthal(sys = vimana.system) (( -- ))
    let n0 = HTK_V0[bg_step]
    let n1 = HTK_V1[bg_step]
    let n2 = HTK_V2[bg_step]
    let n3 = HTK_V3[bg_step]
    let perc = HTK_PERC[bg_step]
    if n0 > 0
        sys.play_voice(0, n0, 2)
    if n1 > 0
        sys.play_voice(1, n1, 3)
    if n2 > 0
        sys.play_voice(2, n2, 4)
    if n3 > 0
        sys.play_voice(3, n3, 3)
    if perc > 0
        sys.play_voice(7, perc, 3)
;

