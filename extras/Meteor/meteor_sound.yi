-- Jingle percussion patterns (V7 PSG)
-- Win: kick-hat-snare-hat-kick-kick-snare-kick (triumphant march)
def W_JIN_PERC = [30, 95, 65, 95, 30, 30, 65, 30]
-- Lose: kick-0-0-tom-0-0-kick-0 (sparse funeral)
