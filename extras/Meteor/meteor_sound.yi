-- Is it a win jingle? (vs lose)
def ?jin_is_win = true

: setup_win_voices(sys = vimana.system) (( -- ))
    let p = meteor_model.get_planet()
    if p == 0
        -- Ealthal win: brass fanfare (V0/V1 saw) + snare drumset (V2/V3 pulse)
        sys.set_voice(0, vimana.wave_sawtooth)
        sys.set_envelope(0, 0, 7, 5, 7)
        sys.set_voice(1, vimana.wave_sawtooth)
        sys.set_envelope(1, 0, 7, 4, 7)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 2, 0, 1)
        sys.set_pulse_width(2, 15)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 0, 2, 0, 1)
        sys.set_pulse_width(3, 25)
    elif p == 1
        -- Sassazi win: twangy western pulse flourish
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 0, 8, 3, 7)
        sys.set_pulse_width(0, 50)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 0, 8, 2, 7)
        sys.set_pulse_width(1, 60)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 9, 4, 8)
        sys.set_pulse_width(2, 70)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 0, 7, 0, 5)
        sys.set_pulse_width(3, 50)
    elif p == 2
        -- Whaleen win: flowing triangles — ocean swell
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 2, 10, 6, 10)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 2, 10, 5, 10)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 1, 10, 7, 10)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 1, 9, 0, 9)
    elif p == 3
        -- Fiereem win: rock power — thick pulse + saw aggression
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 0, 8, 4, 7)
        sys.set_pulse_width(0, 180)
        sys.set_voice(1, vimana.wave_sawtooth)
        sys.set_envelope(1, 0, 8, 3, 7)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 9, 5, 8)
        sys.set_pulse_width(2, 200)
        sys.set_voice(3, vimana.wave_sawtooth)
        sys.set_envelope(3, 0, 7, 0, 5)
    elif p == 4
        -- Sernova win: crisp triangle dings — bossa celebration
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 0, 7, 3, 6)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 0, 7, 2, 6)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 0, 8, 4, 7)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 0, 5, 0, 3)
    elif p == 5
        -- Doorsky win: ghostly pulse + triangle — void clearing
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 4, 11, 4, 11)
        sys.set_pulse_width(0, 25)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 5, 11, 3, 11)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 3, 11, 5, 11)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 3, 10, 0, 10)
        sys.set_pulse_width(3, 20)
    elif p == 6
        -- Grafant win: icy narrow pulse — Phrygian frost breaking
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 0, 9, 3, 8)
        sys.set_pulse_width(0, 25)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 0, 9, 2, 8)
        sys.set_pulse_width(1, 30)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 10, 4, 9)
        sys.set_pulse_width(2, 35)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 0, 8, 0, 6)
        sys.set_pulse_width(3, 20)
    elif p == 7
        -- Perilla win: tribal chant — nasal pulse + stone thuds
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 1, 8, 4, 7)
        sys.set_pulse_width(0, 25)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 1, 8, 3, 7)
        sys.set_pulse_width(1, 30)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 0, 4, 0, 2)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 0, 4, 0, 2)
    elif p == 8
        -- Gelgeel win: liquid bloom — triangle drip celebration
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 1, 9, 4, 8)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 1, 9, 3, 8)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 2, 10, 5, 9)
        sys.set_pulse_width(2, 160)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 2, 8, 0, 6)
    elif p == 9
        -- Rastarl win: solar burst — bright triangle bells
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 0, 7, 3, 6)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 0, 7, 2, 6)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 0, 8, 4, 7)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 0, 5, 0, 3)
    elif p == 10
        -- Neurali win: system online — sharp pulse escalation
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 0, 6, 2, 5)
        sys.set_pulse_width(0, 100)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 0, 6, 1, 5)
        sys.set_pulse_width(1, 80)
        sys.set_voice(2, vimana.wave_sawtooth)
        sys.set_envelope(2, 0, 7, 3, 6)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 0, 5, 0, 3)
        sys.set_pulse_width(3, 120)
    elif p == 11
        -- Lua=Lua win: moonrise — ethereal triangle shimmer
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 1, 9, 4, 8)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 1, 9, 3, 8)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 2, 10, 5, 9)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 2, 8, 0, 6)
    elif p == 12
        -- Orkarol win: sacred triumph — warm organ voices
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 2, 10, 6, 9)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 2, 10, 5, 9)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 3, 11, 7, 10)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 3, 10, 0, 8)
    elif p == 13
        -- Holonull win: void revealed — neon pulse shimmer triumph
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 1, 9, 4, 8)
        sys.set_pulse_width(0, 150)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 1, 9, 3, 8)
        sys.set_pulse_width(1, 130)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 2, 10, 5, 9)
        sys.set_pulse_width(2, 120)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 2, 8, 0, 6)
        sys.set_pulse_width(3, 100)
    elif p == 14
        -- Tekhnis win: loom completion — narrow pulse mechanical triumph
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 0, 7, 3, 6)
        sys.set_pulse_width(0, 35)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 0, 7, 2, 6)
        sys.set_pulse_width(1, 45)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 0, 8, 4, 7)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 0, 6, 0, 4)
        sys.set_pulse_width(3, 30)
    elif p == 15
        -- Belliko win: war horn victory — sawtooth brass triumph
        sys.set_voice(0, vimana.wave_sawtooth)
        sys.set_envelope(0, 0, 8, 4, 7)
        sys.set_voice(1, vimana.wave_sawtooth)
        sys.set_envelope(1, 0, 8, 3, 7)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 9, 5, 8)
        sys.set_pulse_width(2, 160)
        sys.set_voice(3, vimana.wave_sawtooth)
        sys.set_envelope(3, 0, 7, 0, 5)
    elif p == 16
        -- Gaussle win: factory triumph — wide pulse fanfare + sawtooth grind
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 1, 8, 4, 7)
        sys.set_pulse_width(0, 160)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 1, 8, 3, 7)
        sys.set_pulse_width(1, 140)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 0, 9, 5, 8)
        sys.set_voice(3, vimana.wave_sawtooth)
        sys.set_envelope(3, 0, 7, 0, 5)
    elif p == 17
        -- Metteor win: boss defeated — aggressive saw + thick pulse
        sys.set_voice(0, vimana.wave_sawtooth)
        sys.set_envelope(0, 0, 8, 4, 7)
        sys.set_voice(1, vimana.wave_sawtooth)
        sys.set_envelope(1, 0, 8, 3, 7)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 9, 5, 8)
        sys.set_pulse_width(2, 180)
        sys.set_voice(3, vimana.wave_sawtooth)
        sys.set_envelope(3, 0, 7, 0, 5)
    -- V4: bright shimmer doubling melody octave up
    sys.set_voice(4, vimana.wave_sawtooth)
    sys.set_envelope(4, 0, 7, 3, 6)
    -- V5: warm mid fill reinforcing harmony
    sys.set_voice(5, vimana.wave_triangle)
    sys.set_envelope(5, 0, 7, 2, 6)
    -- V6: deep sub-bass reinforcement
    sys.set_voice(6, vimana.wave_triangle)
    sys.set_envelope(6, 0, 8, 4, 7)
    -- V7: PSG percussion hits
    sys.set_voice(7, vimana.wave_psg)
    sys.set_envelope(7, 0, 2, 0, 1)
    sys.set_filter(400, 5, 1)
    sys.set_filter_route(0, 1)
    sys.set_filter_route(1, 1)
    sys.set_filter_route(2, 1)
    sys.set_filter_route(3, 1)
    sys.set_filter_route(4, 1)
    sys.set_filter_route(5, 1)
;

: setup_lose_voices(sys = vimana.system) (( -- ))
    let p = meteor_model.get_planet()
    if p == 0
        -- Ealthal lose: drum roll cutting off — dismissed
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 0, 2, 0, 1)
        sys.set_pulse_width(0, 15)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 0, 2, 0, 1)
        sys.set_pulse_width(1, 25)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 3, 0, 2)
        sys.set_pulse_width(2, 200)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 0, 2, 0, 1)
        sys.set_pulse_width(3, 20)
    elif p == 1
        -- Sassazi lose: twangy droop — Morricone defeat
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 0, 10, 2, 9)
        sys.set_pulse_width(0, 50)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 0, 10, 1, 9)
        sys.set_pulse_width(1, 60)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 10, 3, 10)
        sys.set_pulse_width(2, 70)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 0, 9, 0, 9)
        sys.set_pulse_width(3, 50)
    elif p == 2
        -- Whaleen lose: ocean draining — triangle sinking
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 2, 11, 4, 11)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 2, 11, 3, 11)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 1, 11, 5, 11)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 1, 10, 0, 10)
    elif p == 3
        -- Fiereem lose: rock funeral — heavy and slow
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 0, 11, 2, 10)
        sys.set_pulse_width(0, 200)
        sys.set_voice(1, vimana.wave_sawtooth)
        sys.set_envelope(1, 0, 11, 1, 10)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 11, 3, 11)
        sys.set_pulse_width(2, 200)
        sys.set_voice(3, vimana.wave_sawtooth)
        sys.set_envelope(3, 0, 9, 0, 9)
    elif p == 4
        -- Sernova lose: sad triangle fading — bossa twilight
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 0, 10, 2, 9)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 0, 10, 1, 9)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 0, 10, 3, 10)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 0, 8, 0, 7)
    elif p == 5
        -- Doorsky lose: abyss swallowing — slow ghostly fade
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 4, 12, 2, 12)
        sys.set_pulse_width(0, 25)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 5, 12, 1, 12)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 3, 12, 3, 12)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 3, 11, 0, 11)
        sys.set_pulse_width(3, 20)
    elif p == 6
        -- Grafant lose: icy crush — hollow pulse grinding down
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 0, 11, 1, 10)
        sys.set_pulse_width(0, 25)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 0, 11, 1, 10)
        sys.set_pulse_width(1, 30)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 11, 2, 11)
        sys.set_pulse_width(2, 35)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 0, 10, 0, 10)
        sys.set_pulse_width(3, 20)
    elif p == 7
        -- Perilla lose: tribal death knell — chant dying out
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 1, 10, 2, 10)
        sys.set_pulse_width(0, 25)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 1, 10, 1, 10)
        sys.set_pulse_width(1, 30)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 0, 5, 0, 3)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 0, 5, 0, 3)
    elif p == 8
        -- Gelgeel lose: liquid drain — triangle sinking slowly
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 1, 11, 2, 11)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 1, 11, 1, 11)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 2, 11, 3, 11)
        sys.set_pulse_width(2, 160)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 2, 10, 0, 10)
    elif p == 9
        -- Rastarl lose: solar fade — triangle bells dimming
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 0, 10, 2, 9)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 0, 10, 1, 9)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 0, 10, 3, 10)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 0, 8, 0, 7)
    elif p == 10
        -- Neurali lose: system crash — pulse decay grinding down
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 0, 10, 1, 9)
        sys.set_pulse_width(0, 100)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 0, 10, 1, 9)
        sys.set_pulse_width(1, 80)
        sys.set_voice(2, vimana.wave_sawtooth)
        sys.set_envelope(2, 0, 11, 2, 10)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 0, 9, 0, 9)
        sys.set_pulse_width(3, 120)
    elif p == 11
        -- Lua=Lua lose: eclipse — triangle fading into silence
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 1, 11, 2, 11)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 1, 11, 1, 11)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 2, 11, 3, 11)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 2, 10, 0, 10)
    elif p == 12
        -- Orkarol lose: fading requiem — solemn triangle lament
        sys.set_voice(0, vimana.wave_triangle)
        sys.set_envelope(0, 2, 11, 2, 10)
        sys.set_voice(1, vimana.wave_triangle)
        sys.set_envelope(1, 2, 11, 1, 10)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 2, 11, 3, 11)
        sys.set_pulse_width(2, 120)
        sys.set_voice(3, vimana.wave_triangle)
        sys.set_envelope(3, 3, 10, 0, 10)
    elif p == 13
        -- Holonull lose: void collapse — neon pulse fading to silence
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 1, 11, 2, 11)
        sys.set_pulse_width(0, 150)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 1, 11, 1, 11)
        sys.set_pulse_width(1, 130)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 2, 11, 3, 11)
        sys.set_pulse_width(2, 120)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 2, 10, 0, 10)
        sys.set_pulse_width(3, 100)
    elif p == 14
        -- Tekhnis lose: loom shutdown — narrow pulse winding down
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 0, 11, 2, 10)
        sys.set_pulse_width(0, 35)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 0, 11, 1, 10)
        sys.set_pulse_width(1, 45)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 0, 11, 3, 11)
        sys.set_voice(3, vimana.wave_pulse)
        sys.set_envelope(3, 0, 10, 0, 10)
        sys.set_pulse_width(3, 30)
    elif p == 15
        -- Belliko lose: war horn fading — sawtooth defeat
        sys.set_voice(0, vimana.wave_sawtooth)
        sys.set_envelope(0, 0, 11, 2, 10)
        sys.set_voice(1, vimana.wave_sawtooth)
        sys.set_envelope(1, 0, 11, 1, 10)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 11, 3, 11)
        sys.set_pulse_width(2, 170)
        sys.set_voice(3, vimana.wave_sawtooth)
        sys.set_envelope(3, 0, 10, 0, 10)
    elif p == 16
        -- Gaussle lose: factory shutdown — conveyor grinding to halt
        sys.set_voice(0, vimana.wave_pulse)
        sys.set_envelope(0, 1, 11, 2, 11)
        sys.set_pulse_width(0, 160)
        sys.set_voice(1, vimana.wave_pulse)
        sys.set_envelope(1, 1, 11, 1, 11)
        sys.set_pulse_width(1, 140)
        sys.set_voice(2, vimana.wave_triangle)
        sys.set_envelope(2, 0, 11, 3, 11)
        sys.set_voice(3, vimana.wave_sawtooth)
        sys.set_envelope(3, 0, 10, 0, 10)
    elif p == 17
        -- Metteor lose: villain's demise — aggressive saw crumbling
        sys.set_voice(0, vimana.wave_sawtooth)
        sys.set_envelope(0, 0, 11, 2, 10)
        sys.set_voice(1, vimana.wave_sawtooth)
        sys.set_envelope(1, 0, 11, 1, 10)
        sys.set_voice(2, vimana.wave_pulse)
        sys.set_envelope(2, 0, 11, 3, 11)
        sys.set_pulse_width(2, 180)
        sys.set_voice(3, vimana.wave_sawtooth)
        sys.set_envelope(3, 0, 10, 0, 10)
    -- V4: fading echo doubling melody
    sys.set_voice(4, vimana.wave_triangle)
    sys.set_envelope(4, 1, 10, 1, 10)
    -- V5: hollow echo reinforcing harmony
    sys.set_voice(5, vimana.wave_pulse)
    sys.set_envelope(5, 1, 10, 1, 10)
    sys.set_pulse_width(5, 25)
    -- V6: dark drone sub-bass
    sys.set_voice(6, vimana.wave_triangle)
    sys.set_envelope(6, 2, 11, 2, 11)
    -- V7: PSG sparse funeral hits
    sys.set_voice(7, vimana.wave_psg)
    sys.set_envelope(7, 0, 2, 0, 1)
    sys.set_filter(1400, 5, 1)
    sys.set_filter_route(0, 1)
    sys.set_filter_route(1, 1)
    sys.set_filter_route(2, 1)
    sys.set_filter_route(3, 1)
    sys.set_filter_route(4, 1)
    sys.set_filter_route(5, 1)
;

: jin_note_at(idx = num) (( num, num, num, num ))
    let p = meteor_model.get_planet()
    if jin_is_win
        if p == 0
            <- W_HTK_V0[idx], W_HTK_V1[idx], W_HTK_V2[idx], W_HTK_V3[idx]
        elif p == 1
            <- W_SAS_V0[idx], W_SAS_V1[idx], W_SAS_V2[idx], W_SAS_V3[idx]
        elif p == 2
            <- W_WAL_V0[idx], W_WAL_V1[idx], W_WAL_V2[idx], W_WAL_V3[idx]
        elif p == 3
            <- W_FIR_V0[idx], W_FIR_V1[idx], W_FIR_V2[idx], W_FIR_V3[idx]
        elif p == 4
            <- W_SRN_V0[idx], W_SRN_V1[idx], W_SRN_V2[idx], W_SRN_V3[idx]
        elif p == 5
            <- W_DHV_V0[idx], W_DHV_V1[idx], W_DHV_V2[idx], W_DHV_V3[idx]
        elif p == 6
            <- W_GRF_V0[idx], W_GRF_V1[idx], W_GRF_V2[idx], W_GRF_V3[idx]
        elif p == 7
            <- W_PRL_V0[idx], W_PRL_V1[idx], W_PRL_V2[idx], W_PRL_V3[idx]
        elif p == 8
            <- W_GEL_V0[idx], W_GEL_V1[idx], W_GEL_V2[idx], W_GEL_V3[idx]
        elif p == 9
            <- W_RST_V0[idx], W_RST_V1[idx], W_RST_V2[idx], W_RST_V3[idx]
        elif p == 10
            <- W_NRL_V0[idx], W_NRL_V1[idx], W_NRL_V2[idx], W_NRL_V3[idx]
        elif p == 11
            <- W_LLA_V0[idx], W_LLA_V1[idx], W_LLA_V2[idx], W_LLA_V3[idx]
        elif p == 12
            <- W_ORK_V0[idx], W_ORK_V1[idx], W_ORK_V2[idx], W_ORK_V3[idx]
        elif p == 13
            <- W_HOL_V0[idx], W_HOL_V1[idx], W_HOL_V2[idx], W_HOL_V3[idx]
        elif p == 14
            <- W_TKS_V0[idx], W_TKS_V1[idx], W_TKS_V2[idx], W_TKS_V3[idx]
        elif p == 15
            <- W_BLK_V0[idx], W_BLK_V1[idx], W_BLK_V2[idx], W_BLK_V3[idx]
        elif p == 16
            <- W_GSS_V0[idx], W_GSS_V1[idx], W_GSS_V2[idx], W_GSS_V3[idx]
        <- W_MTR_V0[idx], W_MTR_V1[idx], W_MTR_V2[idx], W_MTR_V3[idx]
    -- lose
    if p == 0
        <- L_HTK_V0[idx], L_HTK_V1[idx], L_HTK_V2[idx], L_HTK_V3[idx]
    elif p == 1
        <- L_SAS_V0[idx], L_SAS_V1[idx], L_SAS_V2[idx], L_SAS_V3[idx]
    elif p == 2
        <- L_WAL_V0[idx], L_WAL_V1[idx], L_WAL_V2[idx], L_WAL_V3[idx]
    elif p == 3
        <- L_FIR_V0[idx], L_FIR_V1[idx], L_FIR_V2[idx], L_FIR_V3[idx]
    elif p == 4
        <- L_SRN_V0[idx], L_SRN_V1[idx], L_SRN_V2[idx], L_SRN_V3[idx]
    elif p == 5
        <- L_DHV_V0[idx], L_DHV_V1[idx], L_DHV_V2[idx], L_DHV_V3[idx]
    elif p == 6
        <- L_GRF_V0[idx], L_GRF_V1[idx], L_GRF_V2[idx], L_GRF_V3[idx]
    elif p == 7
        <- L_PRL_V0[idx], L_PRL_V1[idx], L_PRL_V2[idx], L_PRL_V3[idx]
    elif p == 8
        <- L_GEL_V0[idx], L_GEL_V1[idx], L_GEL_V2[idx], L_GEL_V3[idx]
    elif p == 9
        <- L_RST_V0[idx], L_RST_V1[idx], L_RST_V2[idx], L_RST_V3[idx]
    elif p == 10
        <- L_NRL_V0[idx], L_NRL_V1[idx], L_NRL_V2[idx], L_NRL_V3[idx]
    elif p == 11
        <- L_LLA_V0[idx], L_LLA_V1[idx], L_LLA_V2[idx], L_LLA_V3[idx]
    elif p == 12
        <- L_ORK_V0[idx], L_ORK_V1[idx], L_ORK_V2[idx], L_ORK_V3[idx]
    elif p == 13
        <- L_HOL_V0[idx], L_HOL_V1[idx], L_HOL_V2[idx], L_HOL_V3[idx]
    elif p == 14
        <- L_TKS_V0[idx], L_TKS_V1[idx], L_TKS_V2[idx], L_TKS_V3[idx]
    elif p == 15
        <- L_BLK_V0[idx], L_BLK_V1[idx], L_BLK_V2[idx], L_BLK_V3[idx]
    elif p == 16
        <- L_GSS_V0[idx], L_GSS_V1[idx], L_GSS_V2[idx], L_GSS_V3[idx]
    <- L_MTR_V0[idx], L_MTR_V1[idx], L_MTR_V2[idx], L_MTR_V3[idx]
;

: step_jingle(sys = vimana.system) (( -- ))
    let ?n0 = jin_note_at(jin_step)
    let ?n1 = jin_note_at(jin_step)
    let ?n2 = jin_note_at(jin_step)
    let ?n3 = jin_note_at(jin_step)
    if n0 > 0
        sys.play_voice(0, n0, 10)
    if n1 > 0
        sys.play_voice(1, n1, 8)
    if n2 > 0
        sys.play_voice(2, n2, 7)
    if n3 > 0
        sys.play_voice(3, n3, 6)
    -- V4: octave-up shimmer of melody
    if n0 > 0
        sys.play_voice(4, n0 + 12, 5)
    -- V5: harmony reinforcement (different timbre)
    if n1 > 0
        sys.play_voice(5, n1, 4)
    -- V6: deep sub-bass (octave below bass)
    if n2 > 12
        sys.play_voice(6, n2 - 12, 3)
    -- V7: PSG percussion
    let ?perc = 0
    if jin_is_win
        perc = W_JIN_PERC[jin_step]
    if !jin_is_win
        perc = L_JIN_PERC[jin_step]
    if perc > 0
        sys.play_voice(7, perc, 3)
;

: modulate_jingle(sys = vimana.system) (( -- ))
    if jin_is_win
        sys.set_filter(sweep8(jin_step, 400, 1800), 5, 1)
    if !jin_is_win
        sys.set_filter(sweep8(jin_step, 1400, 200), 5, 1)
;

:: play_win(sys = vimana.system) (( -- ))
    jin_is_win = true
    jin_step = 0
    jin_frame = 0
    jin_playing = true
    sys.begin_audio()
    setup_win_voices(sys)
    step_jingle(sys)
    sys.end_audio()
;

:: play_lose(sys = vimana.system) (( -- ))
    jin_is_win = false
    jin_step = 0
    jin_frame = 0
    jin_playing = true
    sys.begin_audio()
    setup_lose_voices(sys)
    step_jingle(sys)
    sys.end_audio()
;

:: stop_jingle(sys = vimana.system) (( -- ))
    jin_playing = false
    sys.begin_audio()
    sys.stop_voice(0)
    sys.stop_voice(1)
    sys.stop_voice(2)
    sys.stop_voice(3)
    sys.stop_voice(4)
    sys.stop_voice(5)
    sys.stop_voice(6)
    sys.stop_voice(7)
    sys.set_filter_route(0, 0)
    sys.set_filter_route(1, 0)
    sys.set_filter_route(2, 0)
    sys.set_filter_route(3, 0)
    sys.set_filter_route(4, 0)
    sys.set_filter_route(5, 0)
    sys.set_ring_mod(0, 0)
    sys.end_audio()
;

:: tick_jingle(sys = vimana.system) (( -- ))
    if !jin_playing
        <-
    jin_frame = jin_frame + 1
    if jin_frame < JIN_TEMPO
        <-
    jin_frame = 0
    jin_step = jin_step + 1
    if jin_step >= JIN_LEN
        jin_playing = false
        sys.begin_audio()
        sys.stop_voice(0)
        sys.stop_voice(1)
        sys.stop_voice(2)
        sys.stop_voice(3)
        sys.stop_voice(4)
        sys.stop_voice(5)
        sys.stop_voice(6)
        sys.stop_voice(7)
        sys.set_filter_route(0, 0)
        sys.set_filter_route(1, 0)
        sys.set_filter_route(2, 0)
        sys.set_filter_route(3, 0)
        sys.set_filter_route(4, 0)
        sys.set_filter_route(5, 0)
        sys.set_ring_mod(0, 0)
        sys.end_audio()
        <-
    sys.begin_audio()
    step_jingle(sys)
    modulate_jingle(sys)
    sys.end_audio()
;
