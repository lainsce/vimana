            <- ORK_S0_V1[idx]
        if sfx_tier == 1
            <- ORK_S1_V1[idx]
        <- ORK_S2_V1[idx]
    elif p == 13
        if sfx_tier == 0
            <- HOL_S0_V1[idx]
        if sfx_tier == 1
            <- HOL_S1_V1[idx]
        <- HOL_S2_V1[idx]
    elif p == 14
        if sfx_tier == 0
            <- TKS_S0_V1[idx]
        if sfx_tier == 1
            <- TKS_S1_V1[idx]
        <- TKS_S2_V1[idx]
    elif p == 15
        if sfx_tier == 0
            <- BLK_S0_V1[idx]
        if sfx_tier == 1
            <- BLK_S1_V1[idx]
        <- BLK_S2_V1[idx]
    elif p == 16
        if sfx_tier == 0
            <- GSS_S0_V1[idx]
        if sfx_tier == 1
            <- GSS_S1_V1[idx]
        <- GSS_S2_V1[idx]
    elif p == 17
        if sfx_tier == 0
            <- MTR_S0_V1[idx]
        if sfx_tier == 1
            <- MTR_S1_V1[idx]
        <- MTR_S2_V1[idx]
    <- 0
;

: step_sfx(sys = vimana.system) (( -- ))
    let n0 = sfx_v0_at(sfx_step)
    let n1 = sfx_v1_at(sfx_step)
    let ?vol = 8
    if sfx_tier == 1
        vol = 10
    if sfx_tier >= 2
        vol = 12
    if n0 > 0
        sys.play_voice(4, n0, vol)
    if n1 > 0
        sys.play_voice(5, n1, vol - 2)
    if n0 > 12
        sys.play_voice(6, n0 - 12, vol - 3)
;

-- ── SFX public API ──────────────────────────────────────────────────────────

:: play_match(sys = vimana.system, run = num) (( -- ))
    sfx_oneshot = false
    sfx_tier = 0
    if run == 4
        sfx_tier = 1
    if run >= 5
        sfx_tier = 2
    sfx_step = 0
    sfx_frame = 0
    sfx_playing = true
    sys.begin_audio()
    setup_sfx_voices(sys)
    step_sfx(sys)
    sys.end_audio()
;

:: play_flick(sys = vimana.system) (( -- ))
    sfx_oneshot = true
    sfx_step = 4
    sfx_frame = 0
    sfx_playing = true
    sys.begin_audio()
    sys.set_voice(4, vimana.wave_triangle)
    sys.set_envelope(4, 0, 3, 0, 1)
    sys.play_voice(4, 80, 8)
    sys.end_audio()
;

:: play_clear(sys = vimana.system) (( -- ))
    sfx_oneshot = true
    sfx_step = 0
    sfx_frame = 0
    sfx_playing = true
    sys.begin_audio()
    sys.set_voice(4, vimana.wave_triangle)
    sys.set_envelope(4, 0, 9, 4, 8)
    sys.set_voice(5, vimana.wave_triangle)
    sys.set_envelope(5, 0, 9, 4, 8)
    sys.set_voice(6, vimana.wave_triangle)
    sys.set_envelope(6, 0, 9, 4, 8)
    sys.play_voice(4, 72, 12)
    sys.play_voice(5, 76, 10)
    sys.play_voice(6, 79, 8)
    sys.end_audio()
;

:: tick_sfx(sys = vimana.system) (( -- ))
    if !sfx_playing
        <-
    sfx_frame = sfx_frame + 1
    if sfx_frame < SFX_TEMPO
        <-
    sfx_frame = 0
    sfx_step = sfx_step + 1
    if sfx_step >= SFX_LEN
        sfx_playing = false
        sfx_oneshot = false
        sys.begin_audio()
        sys.stop_voice(4)
        sys.stop_voice(5)
        sys.stop_voice(6)
        sys.set_ring_mod(4, 0)
        sys.end_audio()
        <-
    if !sfx_oneshot
        step_sfx(sys)
;

