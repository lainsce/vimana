cask meteor_sound

bring stdr
bring vimana

bring meteor_model

-- ─────────────────────────────────────────────────────────────────────────────
-- Helpers
-- ─────────────────────────────────────────────────────────────────────────────

-- Triangle sweep over 32 steps (0→peak at 15→back to 0 at 31)
: sweep32(step = num, lo = num, hi = num) (( num ))
    let ?t = step
    if t >= 16
        t = 31 - t
    <- lo + t * (hi - lo) / 15
;

-- Linear sweep over 8 steps
: sweep8(step = num, lo = num, hi = num) (( num ))
    <- lo + step * (hi - lo) / 7
;

-- ─────────────────────────────────────────────────────────────────────────────
