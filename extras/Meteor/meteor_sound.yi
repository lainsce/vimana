-- ── Voice setup per planet ──────────────────────────────────────────────────

: setup_ealthal_bg(sys = vimana.system) (( -- ))
    -- V0: sustained Em pad — warm bed beneath march
    sys.set_voice(0, vimana.wave_triangle)
    sys.set_envelope(0, 4, 10, 8, 7)
    -- V2: warm triangle bass — round march foundation
    sys.set_voice(2, vimana.wave_triangle)
    sys.set_envelope(2, 1, 8, 4, 6)
    -- V3: bugle melody — pulse with moderate width
    sys.set_voice(3, vimana.wave_pulse)
    sys.set_envelope(3, 0, 6, 2, 4)
    sys.set_pulse_width(3, 100)
    -- V1: warm triangle arp — steady background
    sys.set_voice(1, vimana.wave_triangle)
    sys.set_envelope(1, 1, 6, 3, 5)
    sys.set_filter(500, 5, 1)
    sys.set_filter_route(0, 1)
    sys.set_filter_route(1, 1)
    sys.set_filter_route(2, 1)
    sys.set_filter_route(3, 1)
    -- V7: PSG percussion
    sys.set_voice(7, vimana.wave_psg)
    sys.set_envelope(7, 0, 2, 0, 1)
;

: setup_fiereem_bg(sys = vimana.system) (( -- ))
    -- V0: heavy Em power pad — sawtooth sustain
    sys.set_voice(0, vimana.wave_sawtooth)
    sys.set_envelope(0, 2, 10, 6, 8)
    -- V2: thick pulse bass — wide width for weight
    sys.set_voice(2, vimana.wave_pulse)
    sys.set_envelope(2, 0, 7, 3, 5)
    sys.set_pulse_width(2, 200)
    -- V3: gritty sawtooth lead stabs — filtered
    sys.set_voice(3, vimana.wave_sawtooth)
    sys.set_envelope(3, 0, 5, 1, 3)
    -- V1: gritty sawtooth power arp
    sys.set_voice(1, vimana.wave_sawtooth)
    sys.set_envelope(1, 0, 5, 2, 3)
    sys.set_filter(600, 7, 1)
    sys.set_filter_route(0, 1)
    sys.set_filter_route(1, 1)
    sys.set_filter_route(3, 1)
    -- V7: PSG percussion
    sys.set_voice(7, vimana.wave_psg)
    sys.set_envelope(7, 0, 2, 0, 1)
;

: setup_whaleen_bg(sys = vimana.system) (( -- ))
