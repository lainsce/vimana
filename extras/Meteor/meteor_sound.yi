-- ── Tempo & length ──────────────────────────────────────────────────────────

: get_bg_tempo() (( num ))
    let p = meteor_model.get_planet()
    if p == 0
        <- 15
    elif p == 1
        <- 15
    elif p == 2
        <- 16
    elif p == 3
        <- 14
    elif p == 4
        <- 15
    elif p == 5
        <- 18
    elif p == 6
        <- 15
    elif p == 7
        <- 15
    elif p == 8
        <- 13
    elif p == 9
        <- 15
    elif p == 10
        <- 14
    elif p == 11
        <- 16
    elif p == 12
        <- 16
    elif p == 13
        <- 20
    elif p == 14
        <- 15
    elif p == 15
        <- 14
    elif p == 16
        <- 15
    elif p == 17
        <- 14
    <- 15
;

-- ── Public BGM API ──────────────────────────────────────────────────────────

:: start_music(sys = vimana.system) (( -- ))
    bg_frame = 0
    bg_step = 0
    bg_playing = true
    let p = meteor_model.get_planet()
    sys.begin_audio()
    if p == 0
        setup_ealthal_bg(sys)
    elif p == 1
        setup_sasazi_bg(sys)
    elif p == 2
        setup_whaleen_bg(sys)
    elif p == 3
        setup_fiereem_bg(sys)
    elif p == 4
        setup_sernova_bg(sys)
    elif p == 5
        setup_doorsky_bg(sys)
    elif p == 6
        setup_grafant_bg(sys)
    elif p == 7
        setup_perilla_bg(sys)
    elif p == 8
        setup_gelgeel_bg(sys)
    elif p == 9
        setup_rastarl_bg(sys)
    elif p == 10
        setup_neurali_bg(sys)
    elif p == 11
        setup_lualua_bg(sys)
    elif p == 12
        setup_orkarol_bg(sys)
    elif p == 13
        setup_holonull_bg(sys)
    elif p == 14
        setup_tekhnis_bg(sys)
    elif p == 15
        setup_belliko_bg(sys)
    elif p == 16
        setup_gaussle_bg(sys)
    elif p == 17
        setup_meteor_bg(sys)
    sys.end_audio()
;

:: stop_music(sys = vimana.system) (( -- ))
    bg_playing = false
    sys.begin_audio()
    sys.stop_voice(0)
    sys.stop_voice(1)
    sys.stop_voice(2)
    sys.stop_voice(3)
    sys.stop_voice(7)
    sys.set_filter_route(0, 0)
    sys.set_filter_route(1, 0)
    sys.set_filter_route(2, 0)
    sys.set_filter_route(3, 0)
    sys.end_audio()
;

:: tick_music(sys = vimana.system) (( -- ))
    if !bg_playing
        <-
    if meteor_model.get_scene() != meteor_model.SCENE_PLAY
        stop_music(sys)
        <-
    bg_frame = bg_frame + 1
    if bg_frame < get_bg_tempo()
        <-
    bg_frame = 0
    let p = meteor_model.get_planet()
    sys.begin_audio()
    if p == 0
        step_ealthal(sys)
    elif p == 1
        step_sasazi(sys)
    elif p == 2
        step_whaleen(sys)
    elif p == 3
        step_fiereem(sys)
    elif p == 4
        step_sernova(sys)
    elif p == 5
        step_doorsky(sys)
    elif p == 6
        step_grafant(sys)
    elif p == 7
        step_perilla(sys)
    elif p == 8
        step_gelgeel(sys)
    elif p == 9
        step_rastarl(sys)
    elif p == 10
        step_neurali(sys)
    elif p == 11
        step_lualua(sys)
    elif p == 12
        step_orkarol(sys)
    elif p == 13
        step_holonull(sys)
    elif p == 14
        step_tekhnis(sys)
    elif p == 15
        step_belliko(sys)
    elif p == 16
        step_gaussle(sys)
    elif p == 17
        step_meteor(sys)
    modulate_bg(sys)
    sys.end_audio()
    bg_step = bg_step + 1
    if bg_step >= 32
        bg_step = 0
;

