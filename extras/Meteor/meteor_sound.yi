    -- V3: triangle melody, gentle attack for flowing feel
    sys.set_voice(3, vimana.wave_triangle)
    sys.set_envelope(3, 1, 8, 5, 7)
    -- V1: flowing triangle arp
    sys.set_voice(1, vimana.wave_triangle)
    sys.set_envelope(1, 2, 8, 4, 6)
    sys.set_filter(400, 5, 2)
    sys.set_filter_route(0, 1)
