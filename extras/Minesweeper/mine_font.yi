    --    ##....##
    --    ##.##.##
    --    ########
    --    ###..###
    --    ##....##
    scr.set_font(0x57, [
        0xc3c3, 0xc3db, 0xffe7, 0xc300,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])

    -- P  .#####.
    --    .#...#.
    --    .#...#.
    --    .#####.
    --    .#.....
    --    .#.....
    --    .#.....
    scr.set_font(0x50, [
        0x7e66, 0x667e, 0x6060, 0x6000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
