:: draw_volume(scr = vimana.screen, x = num, y = num, level = num, fg = num, bg = num) (( -- ))
    let ?step = level
    if step < 0
        step = 0
    if step > 6
        step = 6
    let addr = VOL_ADDR + step * 0x20
    draw_icon16(scr, x, y, addr, 0x01)
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Button frame (32×32, 2bpp CHR from @button-icn in m291.tal)
-- Tiles pre-loaded in setup(): normal at addr 128, active at addr 384.
-- auto=0x36: 4 tiles per call, x-advance within, addr+16/tile, y+8 after call.
-- ─────────────────────────────────────────────────────────────────────────────

:: draw_button_frame(scr = vimana.screen, x = num, y = num, _fg = num, _bg = num) (( -- ))
    scr.set_auto(0x36)
    scr.set_x(x)
    scr.set_y(y)
    if musi_model.paused
        scr.set_addr(0x380)
    else
        scr.set_addr(0x280)
    scr.sprite(0x81)
    scr.sprite(0x81)
    scr.sprite(0x81)
    scr.sprite(0x81)
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Progress bar (2bpp CHR + 1bpp fill from m291.tal)
-- fp = sec_prog (elapsed pixel width, 0..PROG_W).
-- auto=0x15: 2 tiles per call (stacked 8+8px tall), addr+, x+8 after each call.
-- ─────────────────────────────────────────────────────────────────────────────

:: draw_progress(scr = vimana.screen, fp = num) (( -- ))
    scr.set_auto(0x15)
    scr.set_y(musi_model.PROG_Y*8)
    scr.set_x(musi_model.PROG_X*8)
    -- Background pill: left cap + 28 middle + right cap
    scr.set_addr(0)
    scr.sprite(0x81)
    let ?mi = 0
    for (; mi < 28; mi += 1)
        scr.set_addr(0x20)
        scr.sprite(0x81)
    scr.set_addr(0x40)
    scr.sprite(0x81)
    -- Elapsed fill: draw fill sprite for each 8-pixel chunk
    let ?fi = 0
    let max_fill = stdr.floor(fp / 8)
    for (; fi < max_fill; fi += 1)
        scr.set_x(fi * 8 + musi_model.PROG_X * 8)
        scr.set_addr(0x60)
        scr.sprite(0x0A)
        scr.sprite(0x0A)
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Font setup: load the Chicago bitmap font (8×16 glyphs, variable width)
-- and switch Vimana to 16-pixel font rendering.
-- Call once after creating the screen.
-- ─────────────────────────────────────────────────────────────────────────────

:: setup(scr = vimana.screen) (( -- ))
    scr.set_font_size(2)

    -- ASCII 0x20–0x7f glyphs (16 UFX words each = 8×16 pixels, plane 0)
    -- 32 = Blank
    scr.set_font(0x20, [
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 33 = Exclamation mark (!)
    scr.set_font(0x21, [
        0x0000, 0x0030, 0x3030, 0x3030,
        0x3000, 0x3030, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 34 = Quotation mark (")
    scr.set_font(0x22, [
        0x0000, 0x0028, 0x2828, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 35 = Number sign (#)
    scr.set_font(0x23, [
        0x0000, 0x0909, 0x3f12, 0x127f,
        0x2424, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 36 = Dollar sign ($)
    scr.set_font(0x24, [
        0x0000, 0x1038, 0x5470, 0x7038,
        0x1c1c, 0x5438, 0x1000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 37 = Percent sign (%)
    scr.set_font(0x25, [
        0x0000, 0x3749, 0x4a32, 0x0404,
        0x090a, 0x1211, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 38 = Ampersand (&)
    scr.set_font(0x26, [
        0x0000, 0x003c, 0x6666, 0x3067,
        0x6666, 0x663c, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 39 = Apostrophe (')
    scr.set_font(0x27, [
        0x0000, 0x0040, 0x4040, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 40 = Left parenthesis (()
    scr.set_font(0x28, [
        0x0000, 0x1020, 0x6060, 0x6060,
        0x6060, 0x2010, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 41 = Right parenthesis ())
    scr.set_font(0x29, [
        0x0000, 0x4020, 0x3030, 0x3030,
        0x3030, 0x2040, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 42 = Asterisk (*)
    scr.set_font(0x2A, [
        0x0000, 0x0010, 0x5438, 0x5410,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 43 = Plus sign (+)
    scr.set_font(0x2B, [
        0x0000, 0x0000, 0x0010, 0x107c,
        0x1010, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 44 = Comma (,)
    scr.set_font(0x2C, [
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x6060, 0x2040, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 45 = Hyphen (-)
    scr.set_font(0x2D, [
        0x0000, 0x0000, 0x0000, 0x007c,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 46 = Period (.)
    scr.set_font(0x2E, [
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x6060, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 47 = Slash (/)
    scr.set_font(0x2F, [
        0x0000, 0x0404, 0x0808, 0x1010,
        0x2020, 0x4040, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])

    -- 48–57 = Digits 0–9
    scr.set_font(0x30, [
        0x0000, 0x003c, 0x6666, 0x6666,
        0x6666, 0x663c, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    scr.set_font(0x31, [
        0x0000, 0x0018, 0x3818, 0x1818,
        0x1818, 0x1818, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    scr.set_font(0x32, [
        0x0000, 0x003c, 0x4606, 0x060c,
        0x1830, 0x607e, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    scr.set_font(0x33, [
        0x0000, 0x007e, 0x0c18, 0x3c06,
        0x0606, 0x463c, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    scr.set_font(0x34, [
        0x0000, 0x0006, 0x0e16, 0x2646,
        0x7f06, 0x0606, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    scr.set_font(0x35, [
        0x0000, 0x007e, 0x6060, 0x7c06,
        0x0606, 0x463c, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    scr.set_font(0x36, [
        0x0000, 0x001c, 0x3060, 0x7c66,
        0x6666, 0x663c, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    scr.set_font(0x37, [
        0x0000, 0x007e, 0x0606, 0x060c,
        0x1818, 0x1818, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    scr.set_font(0x38, [
        0x0000, 0x003c, 0x6666, 0x663c,
        0x6666, 0x663c, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    scr.set_font(0x39, [
        0x0000, 0x003c, 0x6666, 0x6666,
        0x3e06, 0x0c38, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])

    -- 58 = Colon (:)
    scr.set_font(0x3A, [
        0x0000, 0x0000, 0x0060, 0x6000,
        0x0000, 0x6060, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 59 = Semicolon (;)
    scr.set_font(0x3B, [
        0x0000, 0x0000, 0x0060, 0x6000,
        0x0000, 0x6060, 0x2040, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
    ])
    -- 60 = Less-than sign (<)
    scr.set_font(0x3C, [
        0x0000, 0x0000, 0x1830, 0x60c0,
        0x6030, 0x1800, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
