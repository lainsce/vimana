    -- 61 = Equals sign (=)
    scr.set_font(0x3D, [
        0x0000, 0x0000, 0x0000, 0x7e00,
        0x7e00, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
