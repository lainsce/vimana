cask musi_assets

bring vimana

-- ─────────────────────────────────────────────────────────────────────────────
-- Sprite addresses copied from m291.tal
-- ─────────────────────────────────────────────────────────────────────────────

def RPT_OFF_ADDR  = 0x500
def RPT_ON_ADDR   = 0x520
def SHF_OFF_ADDR  = 0x540
def SHF_ON_ADDR   = 0x560
def PLAY_ADDR     = 0x580
def PAUSE_ADDR    = 0x5A0
def NEXT_ADDR     = 0x5C0
def VOL_ADDR      = 0x5E0
def PREV_ADDR     = 0x6C0
def POKE_ADDR     = 0x6E0

-- Draw a 16×16 control icon as two rows, using the same x-reset pattern
-- used by other sprite-grid helpers in the repo.
: draw_icon16(scr = vimana.screen, x = num, y = num, addr = num, ctrl = num) (( -- ))
    scr.set_auto(0x16)
       .set_addr(addr)
       .set_x(x)
       .set_y(y)
       .sprite(ctrl)
       .set_x(x)
       .sprite(ctrl)
       .set_auto(0x00)
;

: draw_icon8(scr = vimana.screen, x = num, y = num, addr = num, ctrl = num) (( -- ))
    scr.set_auto(0x00)
       .set_addr(addr)
       .set_x(x)
       .set_y(y)
       .sprite(ctrl)
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Control art copied from m291.tal
-- ─────────────────────────────────────────────────────────────────────────────

def RPT_OFF = [
    0x0000, 0x000F, 0x1F18, 0x1000, 0x0010, 0x18FC, 0xFC18, 0x1000,
    0x0008, 0x183F, 0x3F18, 0x0800, 0x0008, 0x18F8, 0xF000, 0x0000,
]

def RPT_ON = [
    0x0000, 0x000F, 0x1F18, 0x1818, 0x0010, 0x18FC, 0xFC18, 0x1008,
    0x1818, 0x181F, 0x0F00, 0x0000, 0x1818, 0x18F8, 0xF000, 0x0000,
]

:: draw_repeat(scr = vimana.screen, x = num, y = num, on = bool, fg = num, bg = num) (( -- ))
    let ?addr = RPT_OFF_ADDR
    if on
        addr = RPT_ON_ADDR
    draw_icon16(scr, x, y, addr, 0x01)
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Shuffle icon (off / on)
-- ─────────────────────────────────────────────────────────────────────────────

def SHF_OFF = [
    0x0000, 0x001F, 0x1F00, 0x0000, 0x0010, 0x18FC, 0xFC18, 0x1000,
    0x0000, 0x001F, 0x1F00, 0x0000, 0x0010, 0x18FC, 0xFC18, 0x1000,
]

def SHF_ON = [
    0x0000, 0x001F, 0x1F01, 0x0101, 0x0010, 0x187C, 0xBC98, 0x9080,
    0x0101, 0x011D, 0x1E00, 0x0000, 0x8090, 0x98FC, 0xFC18, 0x1000,
]

:: draw_shuffle(scr = vimana.screen, x = num, y = num, on = bool, fg = num, bg = num) (( -- ))
    let ?addr = SHF_OFF_ADDR
    if on
        addr = SHF_ON_ADDR
    draw_icon16(scr, x, y, addr, 0x01)
;

