    -- 62 = Greater-than sign (>)
    scr.set_font(0x3E, [
        0x0000, 0x0000, 0xc060, 0x3018,
        0x3060, 0xc000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000,
        0x0000, 0x0000, 0x0000, 0x0000
