-- Play (›) / Pause (‖) icon
-- ─────────────────────────────────────────────────────────────────────────────

def PLAY_ICN = [
    0x0000, 0x001E, 0x1E1E, 0x1E1E, 0x0000, 0x0078, 0x7878, 0x7878,
    0x1E1E, 0x1E1E, 0x1E00, 0x0000, 0x7878, 0x7878, 0x7800, 0x0000,
]

def PAUSE_ICN = [
    0x0000, 0x000C, 0x0F0F, 0x0F0F, 0x0000, 0x0000, 0x00C0, 0xF0FC,
    0x0F0F, 0x0F0F, 0x0C00, 0x0000, 0xFCF0, 0xC000, 0x0000, 0x0000,
]

-- Show play arrow when paused, pause bars when playing
:: draw_play(scr = vimana.screen, x = num, y = num, paused = bool, fg = num, bg = num) (( -- ))
    if paused
        draw_icon16(scr, x, y, PLAY_ADDR, 0x05)
    else
        draw_icon16(scr, x, y, PAUSE_ADDR, 0x05)
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Now-playing indicator: right-pointing triangle (poke-icn, 8×8)
-- ─────────────────────────────────────────────────────────────────────────────

def POKE_ICN = [0x0000, 0x0000, 0x80C0, 0xE0F0, 0xE0C0, 0x8000, 0x0000, 0x0000]

:: draw_poke(scr = vimana.screen, y = num, fg = num, bg = num) (( -- ))
    draw_icon8(scr, 0, y, POKE_ADDR, 0x00)
;

