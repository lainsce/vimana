cask nekotokei_data

bring stdr


--| Body |--

--| Eyes |--

--| Tail Left |--

--| Tail Right |--

-- Eye frame lookup: tick 0-7 → frame 0-7, tick 8-15 → frame 7-0
:: eye_frame(tick = num) (( num ))
    let t = tick % 16
    if t < 8
        <- t
    <- 15 - t
;

-- Tail frame: same mirror logic
:: tail_frame(tick = num) (( num ))
    let t = tick % 16
    <- t % 8
;

-- Whether to draw right-side tail (tick 0-7) or left-side (tick 8-15)
:: tail_is_right(tick = num) (( bool ))
    <- (tick % 16) < 8
;

:: head(idx = num) (( string ))
    let d = ""
    <- stdr.substring_len(d, idx * 16, 16)
;

:: body(idx = num) (( string ))
    let d = ""
    <- stdr.substring_len(d, idx * 16, 16)
;

:: eyes(idx = num) (( string ))
    let d = ""
    <- stdr.substring_len(d, idx * 16, 16)
