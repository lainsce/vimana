cask neralie_assets

bring vimana

-- Glyph data from neralie.tal: each character is 4 words (8 rows × 1 byte/row packed
-- as 2 rows per 16-bit word), padded to the 16-word Vimana set_font() format.

:: setup(scr = vimana.screen) (( -- ))
    -- Digits 0-9 (ASCII 0x30-0x39) from font-numbers
    scr.set_font(0x30, [0x7cc6, 0xced6, 0xe6c6, 0x7c00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x31, [0x1838, 0x1818, 0x1818, 0x7e00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x32, [0x3c66, 0x063c, 0x6066, 0x7e00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x33, [0x3c66, 0x061c, 0x0666, 0x3c00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x34, [0x1c3c, 0x6ccc, 0xfe0c, 0x1e00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x35, [0x7e62, 0x607c, 0x0666, 0x3c00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x36, [0x3c66, 0x607c, 0x6666, 0x3c00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x37, [0x7e66, 0x060c, 0x1818, 0x1800, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x38, [0x3c66, 0x663c, 0x6666, 0x3c00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x39, [0x3c66, 0x663e, 0x0666, 0x3c00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])

    -- Colon ':' (ASCII 0x3A), index 11 in font-numbers
    scr.set_font(0x3a, [0x0018, 0x1800, 0x1818, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])

    -- Letters A-Z (ASCII 0x41-0x5A) from font-letters
    scr.set_font(0x41, [0x183c, 0x6666, 0x7e66, 0x6600, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x42, [0xfc66, 0x667c, 0x6666, 0xfc00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x43, [0x3c66, 0xc0c0, 0xc066, 0x3c00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x44, [0xf86c, 0x6666, 0x666c, 0xf800, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x45, [0xfe62, 0x6878, 0x6862, 0xfe00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x46, [0xfe62, 0x6878, 0x6860, 0xf000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x47, [0x3c66, 0xc0c0, 0xce66, 0x3e00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x48, [0x6666, 0x667e, 0x6666, 0x6600, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x49, [0x7e18, 0x1818, 0x1818, 0x7e00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x4a, [0x1e0c, 0x0c0c, 0xcccc, 0x7800, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x4b, [0xe666, 0x6c78, 0x6c66, 0xe600, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x4c, [0xf060, 0x6060, 0x6266, 0xfe00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x4d, [0xc6ee, 0xfefe, 0xd6c6, 0xc600, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x4e, [0xc6e6, 0xf6de, 0xcec6, 0xc600, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x4f, [0x386c, 0xc6c6, 0xc66c, 0x3800, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x50, [0xfc66, 0x667c, 0x6060, 0xf000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x51, [0x386c, 0xc6c6, 0xdacc, 0x7600, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x52, [0xfc66, 0x667c, 0x6c66, 0xe600, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x53, [0x3c66, 0x603c, 0x0666, 0x3c00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x54, [0x7e5a, 0x1818, 0x1818, 0x3c00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x55, [0x6666, 0x6666, 0x6666, 0x3c00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x56, [0x6666, 0x6666, 0x663c, 0x1800, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x57, [0xc6c6, 0xc6d6, 0xfeee, 0xc600, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x58, [0xc66c, 0x3838, 0x6cc6, 0xc600, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x59, [0x6666, 0x663c, 0x1818, 0x3c00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])
    scr.set_font(0x5a, [0xfec6, 0x8c18, 0x3266, 0xfe00, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])

    -- '+' (ASCII 0x2B), the 27th entry in font-letters (extra Arvelie period)
    scr.set_font(0x2b, [0x0018, 0x187e, 0x1818, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])

    -- Space ' ' (ASCII 0x20)
    scr.set_font(0x20, [0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000, 0x0000])

    -- Monospace widths
    scr.set_font_width(0x20, 8)
    scr.set_font_width(0x2b, 8)
    scr.set_font_width(0x3a, 8)
    for (let ?c = 0x30; c <= 0x39; c += 1)
        scr.set_font_width(c, 8)
    for (let ?c = 0x41; c <= 0x5a; c += 1)
        scr.set_font_width(c, 8)
;
