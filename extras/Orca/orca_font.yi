cask orca_font

bring vimana

-- 8x16 monospace font (UF2) for the Orca grid.
-- Each glyph is 16 bytes (one per row, 8 pixels wide, MSB = leftmost pixel).
-- ASCII glyphs are the 8x8 UF1 designs scaled up by doubling each row.
:: load_font(scr = vimana.screen) (( -- ))
    scr.set_font_size(2)
    -- Volume bar glyphs 0x01–0x08: fill from bottom, 2 rows per level
    scr.set_font_chr(0x01, [0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xFF, 0xFF])
    scr.set_font_chr(0x02, [0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xFF, 0xFF, 0xFF, 0xFF])
    scr.set_font_chr(0x03, [0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF])
    scr.set_font_chr(0x04, [0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF])
    scr.set_font_chr(0x05, [0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF])
    scr.set_font_chr(0x06, [0x00, 0x00, 0x00, 0x00, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF])
    scr.set_font_chr(0x07, [0x00, 0x00, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF])
    scr.set_font_chr(0x08, [0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF])
    -- Beat indicator glyphs: 0x09 = filled circle, 0x0A = hollow circle
    scr.set_font_chr(0x09, [0x00, 0x00, 0x00, 0x1C, 0x3E, 0x7F, 0x7F, 0x7F, 0x7F, 0x7F, 0x7F, 0x3E, 0x1C, 0x00, 0x00, 0x00])
    scr.set_font_chr(0x0A, [0x00, 0x00, 0x00, 0x1C, 0x22, 0x41, 0x41, 0x41, 0x41, 0x41, 0x41, 0x22, 0x1C, 0x00, 0x00, 0x00])
    -- ASCII printable range 0x21–0x7E (each row doubled from the 8x8 design)
    scr.set_font_chr(0x21, [0x10, 0x10, 0x10, 0x10, 0x10, 0x10, 0x10, 0x10, 0x10, 0x10, 0x00, 0x00, 0x10, 0x10, 0x00, 0x00]) -- !
    scr.set_font_chr(0x22, [0x28, 0x28, 0x28, 0x28, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00]) -- "
    scr.set_font_chr(0x23, [0x28, 0x28, 0x7C, 0x7C, 0x28, 0x28, 0x28, 0x28, 0x7C, 0x7C, 0x28, 0x28, 0x00, 0x00, 0x00, 0x00]) -- #
    scr.set_font_chr(0x24, [0x10, 0x10, 0x3C, 0x3C, 0x50, 0x50, 0x38, 0x38, 0x14, 0x14, 0x78, 0x78, 0x10, 0x10, 0x00, 0x00]) -- $
    scr.set_font_chr(0x25, [0x44, 0x44, 0x08, 0x08, 0x10, 0x10, 0x10, 0x10, 0x20, 0x20, 0x44, 0x44, 0x00, 0x00, 0x00, 0x00]) -- %
    scr.set_font_chr(0x26, [0x30, 0x30, 0x48, 0x48, 0x30, 0x30, 0x50, 0x50, 0x4C, 0x4C, 0x34, 0x34, 0x00, 0x00, 0x00, 0x00]) -- &
    scr.set_font_chr(0x27, [0x10, 0x10, 0x10, 0x10, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00]) -- '
    scr.set_font_chr(0x28, [0x08, 0x08, 0x10, 0x10, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20, 0x10, 0x10, 0x08, 0x08, 0x00, 0x00]) -- (
    scr.set_font_chr(0x29, [0x20, 0x20, 0x10, 0x10, 0x08, 0x08, 0x08, 0x08, 0x08, 0x08, 0x10, 0x10, 0x20, 0x20, 0x00, 0x00]) -- )
