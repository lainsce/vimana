@diagnostics: warn

@fg: #000000
@bg: #EEEEEE
@accent1: #77DDCC
@muted: #AAAAAA

vstack
hstack
grid
zstack
fixed
scroller
content-list
window
  background: @bg

window_bar
  background: @bg
  color: @fg
  icon-color: @fg

label
  color: @fg
  font-family: "Input Mono"
  font-size: 16

appbar.right-appbar
  background: @bg
  color: @fg
  border: 0 solid transparent
  border-radius: 0
  min-height: 36
  max-height: 36

hstack.right-root
  background: @bg

vstack.right-editor-frame
  background: @bg
  border-radius: 0

drawing_area.right-editor-canvas
  background: #FFFFFF
  min-height: 280

vstack.right-sidebar
  border-radius: 0
  min-width: 300
  max-width: 300
  min-height: 520

label.right-outline-title
  font-family: "Input Mono"
  font-size: 16
  color: @fg

drawing_area.right-outline-canvas
  background: #FFFFFF
  min-height: 500

content_list
  color: @fg

@when dark
  @fg: #EEEEEE
  @bg: #000000
  @accent1: #77DDCC
  @muted: #AAAAAA
