cask right_bitmap_text

bring stdr
bring cogito

def CELL_W = 16
def CELL_H = 16
def ?GLYPH_16_CACHE = {}

def ICN_BLANK = [
    "00000000", "00000000", "00000000", "00000000",
    "00000000", "00000000", "00000000", "00000000"
]

def ICN_QUESTION = [
    "00111100", "01100110", "00000110", "00001100",
    "00011000", "00000000", "00011000", "00000000"
]

: icn_for_code(code = num) (( [any] ))
    if code == 32 <- ICN_BLANK

    if code == 65 <- ["00111100", "01100110", "11000011", "11111111", "11000011", "11000011", "11000011", "00000000"]
    if code == 66 <- ["11111100", "11000110", "11000110", "11111100", "11000110", "11000110", "11111100", "00000000"]
    if code == 67 <- ["00111110", "01100000", "11000000", "11000000", "11000000", "01100000", "00111110", "00000000"]
    if code == 68 <- ["11111100", "11000110", "11000011", "11000011", "11000011", "11000110", "11111100", "00000000"]
    if code == 69 <- ["11111111", "11000000", "11000000", "11111110", "11000000", "11000000", "11111111", "00000000"]
    if code == 70 <- ["11111111", "11000000", "11000000", "11111110", "11000000", "11000000", "11000000", "00000000"]
    if code == 71 <- ["00111110", "01100000", "11000000", "11001111", "11000011", "01100011", "00111110", "00000000"]
    if code == 72 <- ["11000011", "11000011", "11000011", "11111111", "11000011", "11000011", "11000011", "00000000"]
    if code == 73 <- ["00111100", "00011000", "00011000", "00011000", "00011000", "00011000", "00111100", "00000000"]
    if code == 74 <- ["00011111", "00000110", "00000110", "00000110", "00000110", "11000110", "01111100", "00000000"]
    if code == 75 <- ["11000110", "11001100", "11011000", "11110000", "11011000", "11001100", "11000110", "00000000"]
    if code == 76 <- ["11000000", "11000000", "11000000", "11000000", "11000000", "11000000", "11111111", "00000000"]
    if code == 77 <- ["11000011", "11100111", "11111111", "11011011", "11000011", "11000011", "11000011", "00000000"]
    if code == 78 <- ["11000011", "11100011", "11110011", "11011011", "11001111", "11000111", "11000011", "00000000"]
    if code == 79 <- ["00111100", "01100110", "11000011", "11000011", "11000011", "01100110", "00111100", "00000000"]
    if code == 80 <- ["11111100", "11000110", "11000110", "11111100", "11000000", "11000000", "11000000", "00000000"]
    if code == 81 <- ["00111100", "01100110", "11000011", "11000011", "11001011", "01100110", "00111101", "00000000"]
    if code == 82 <- ["11111100", "11000110", "11000110", "11111100", "11011000", "11001100", "11000110", "00000000"]
    if code == 83 <- ["00111110", "01100000", "01100000", "00111100", "00000110", "00000110", "01111100", "00000000"]
    if code == 84 <- ["11111111", "10011001", "00011000", "00011000", "00011000", "00011000", "00111100", "00000000"]
    if code == 85 <- ["11000011", "11000011", "11000011", "11000011", "11000011", "01100110", "00111100", "00000000"]
    if code == 86 <- ["11000011", "11000011", "11000011", "11000011", "01100110", "00111100", "00011000", "00000000"]
    if code == 87 <- ["11000011", "11000011", "11000011", "11011011", "11111111", "11100111", "11000011", "00000000"]
    if code == 88 <- ["11000011", "01100110", "00111100", "00011000", "00111100", "01100110", "11000011", "00000000"]
    if code == 89 <- ["11000011", "01100110", "00111100", "00011000", "00011000", "00011000", "00111100", "00000000"]
    if code == 90 <- ["11111111", "00000110", "00001100", "00011000", "00110000", "01100000", "11111111", "00000000"]

    if code == 48 <- ["00111100", "01100110", "11001111", "11011011", "11110011", "01100110", "00111100", "00000000"]
    if code == 49 <- ["00011000", "00111000", "00011000", "00011000", "00011000", "00011000", "01111110", "00000000"]
    if code == 50 <- ["00111100", "01100110", "00000110", "00001100", "00110000", "01100000", "01111110", "00000000"]
    if code == 51 <- ["00111100", "01100110", "00000110", "00011100", "00000110", "01100110", "00111100", "00000000"]
    if code == 52 <- ["00001100", "00011100", "00101100", "01001100", "11111110", "00001100", "00001100", "00000000"]
    if code == 53 <- ["01111110", "01100000", "01111100", "00000110", "00000110", "01100110", "00111100", "00000000"]
    if code == 54 <- ["00111100", "01100000", "01111100", "01100110", "01100110", "01100110", "00111100", "00000000"]
    if code == 55 <- ["01111110", "00000110", "00001100", "00011000", "00110000", "00110000", "00110000", "00000000"]
    if code == 56 <- ["00111100", "01100110", "01100110", "00111100", "01100110", "01100110", "00111100", "00000000"]
    if code == 57 <- ["00111100", "01100110", "01100110", "00111110", "00000110", "00001100", "00111000", "00000000"]

    if code == 91 <- ["00111100", "00110000", "00110000", "00110000", "00110000", "00110000", "00111100", "00000000"]
    if code == 93 <- ["00111100", "00001100", "00001100", "00001100", "00001100", "00001100", "00111100", "00000000"]
    if code == 40 <- ["00011100", "00110000", "01100000", "01100000", "01100000", "00110000", "00011100", "00000000"]
    if code == 41 <- ["00111000", "00001100", "00000110", "00000110", "00000110", "00001100", "00111000", "00000000"]
    if code == 58 <- ["00000000", "00011000", "00011000", "00000000", "00011000", "00011000", "00000000", "00000000"]
    if code == 59 <- ["00000000", "00011000", "00011000", "00000000", "00011000", "00011000", "00110000", "00000000"]
    if code == 46 <- ["00000000", "00000000", "00000000", "00000000", "00000000", "00011000", "00011000", "00000000"]
    if code == 44 <- ["00000000", "00000000", "00000000", "00000000", "00011000", "00011000", "00110000", "00000000"]
    if code == 95 <- ["00000000", "00000000", "00000000", "00000000", "00000000", "00000000", "11111111", "00000000"]
    if code == 45 <- ["00000000", "00000000", "00000000", "01111110", "00000000", "00000000", "00000000", "00000000"]
    if code == 43 <- ["00000000", "00011000", "00011000", "01111110", "00011000", "00011000", "00000000", "00000000"]
    if code == 47 <- ["00000011", "00000110", "00001100", "00011000", "00110000", "01100000", "11000000", "00000000"]
    if code == 92 <- ["11000000", "01100000", "00110000", "00011000", "00001100", "00000110", "00000011", "00000000"]
    if code == 39 <- ["00011000", "00011000", "00010000", "00000000", "00000000", "00000000", "00000000", "00000000"]
    if code == 34 <- ["01100110", "01100110", "00100100", "00000000", "00000000", "00000000", "00000000", "00000000"]
    if code == 61 <- ["00000000", "01111110", "00000000", "01111110", "00000000", "00000000", "00000000", "00000000"]
    if code == 33 <- ["00011000", "00011000", "00011000", "00011000", "00011000", "00000000", "00011000", "00000000"]

    <- ICN_QUESTION
;

: glyph_rows_16(ch = string) (( [any] ))
    let ?code = stdr.char_code(ch)
    if code >= 97 && code <= 122
        code = code - 32

    let key = str(code)
    let cached = GLYPH_16_CACHE[key]
    if cached != null
        <- cached

    let rows8 = icn_for_code(code)
    let ?rows16 = []: [any]
    for (let ?i = 0; i < 8; i += 1)
        let row = str(rows8[i] ?? "00000000")
        stdr.push(rows16, row)
        stdr.push(rows16, row)

    GLYPH_16_CACHE[key] = rows16
    <- rows16
;

:: glyph_width(scale = num) (( num ))
    let ?s = scale
    if s < 1
        s = 1
    <- CELL_W * s
;

:: glyph_height(scale = num) (( num ))
    let ?s = scale
    if s < 1
        s = 1
    <- CELL_H * s
;

:: glyph_advance(scale = num) (( num ))
    let ?s = scale
    if s < 1
        s = 1
    <- glyph_width(s) + s
;

:: draw_text(da = cogito.DrawingArea, x = num, y = num, text = string, color = string, scale = num, max_chars = num) (( -- ))
    let ?s = scale
    if s < 1
        s = 1

    let ?limit = max_chars
    let n = stdr.len(text)
    if limit < 0 || limit > n
        limit = n

    let step = glyph_advance(s)
    let px_w = 2 * s
    let src_cols = 8

    da.set_color(color)
    for (let ?i = 0; i < limit; i += 1)
        let c = stdr.slice(text, i, i + 1)
        let rows = glyph_rows_16(c)
        let ox = x + i * step
        for (let ?gy = 0; gy < CELL_H; gy += 1)
            let bits = str(rows[gy] ?? "00000000")
            for (let ?gx = 0; gx < src_cols; gx += 1)
                if stdr.slice(bits, gx, gx + 1) == "1"
                    da.fill_rect(ox + gx * px_w, y + gy * s, px_w, s)
;
