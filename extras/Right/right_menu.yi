        if idx == 4
            <- "Cmd+Q"
    if cat == CAT_EDIT
        if idx == 0
            <- "Cmd+C"
        if idx == 1
            <- "Cmd+V"
        if idx == 2
            <- "Cmd+X"
        if idx == 3
            <- "Del"
    if cat == CAT_SELECT
        if idx == 0
            <- "Cmd+A"
        if idx == 1
            <- "Cmd+W"
        if idx == 2
            <- "Cmd+L"
        if idx == 3
            <- "Esc"
    if cat == CAT_FIND
        if idx == 0
            <- "Cmd+F"
        if idx == 1
            <- "Cmd+G"
        if idx == 2
            <- "Cmd+Shift+G"
    if cat == CAT_FORMAT
        if idx == 0
