--| State queries and control |--

:: is_open() (( bool ))
    <- menu_open >= 0
;

:: close() (( -- ))
    menu_open = -1
    menu_hover = -1
;

--| Drawing |--

: draw_diamond (scr = vimana.screen, dx = num, dy = num, color = num) (( -- ))
    let bg = color + 64
    -- Row 0-1: 1px
    scr.set_x(dx + 6) scr.set_y(dy + 0) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 0) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 1) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 1) scr.pixel(bg)
    -- Row 2-3: 3px
    scr.set_x(dx + 5) scr.set_y(dy + 2) scr.pixel(color) scr.set_x(dx + 5) scr.set_y(dy + 2) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 2) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 2) scr.pixel(bg)
    scr.set_x(dx + 7) scr.set_y(dy + 2) scr.pixel(color) scr.set_x(dx + 7) scr.set_y(dy + 2) scr.pixel(bg)
    scr.set_x(dx + 5) scr.set_y(dy + 3) scr.pixel(color) scr.set_x(dx + 5) scr.set_y(dy + 3) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 3) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 3) scr.pixel(bg)
    scr.set_x(dx + 7) scr.set_y(dy + 3) scr.pixel(color) scr.set_x(dx + 7) scr.set_y(dy + 3) scr.pixel(bg)
    -- Row 4-5: 5px
    scr.set_x(dx + 4) scr.set_y(dy + 4) scr.pixel(color) scr.set_x(dx + 4) scr.set_y(dy + 4) scr.pixel(bg)
    scr.set_x(dx + 5) scr.set_y(dy + 4) scr.pixel(color) scr.set_x(dx + 5) scr.set_y(dy + 4) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 4) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 4) scr.pixel(bg)
    scr.set_x(dx + 7) scr.set_y(dy + 4) scr.pixel(color) scr.set_x(dx + 7) scr.set_y(dy + 4) scr.pixel(bg)
    scr.set_x(dx + 8) scr.set_y(dy + 4) scr.pixel(color) scr.set_x(dx + 8) scr.set_y(dy + 4) scr.pixel(bg)
    scr.set_x(dx + 4) scr.set_y(dy + 5) scr.pixel(color) scr.set_x(dx + 4) scr.set_y(dy + 5) scr.pixel(bg)
    scr.set_x(dx + 5) scr.set_y(dy + 5) scr.pixel(color) scr.set_x(dx + 5) scr.set_y(dy + 5) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 5) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 5) scr.pixel(bg)
    scr.set_x(dx + 7) scr.set_y(dy + 5) scr.pixel(color) scr.set_x(dx + 7) scr.set_y(dy + 5) scr.pixel(bg)
    scr.set_x(dx + 8) scr.set_y(dy + 5) scr.pixel(color) scr.set_x(dx + 8) scr.set_y(dy + 5) scr.pixel(bg)
    -- Row 6-7: 7px (widest)
    scr.set_x(dx + 3) scr.set_y(dy + 6) scr.pixel(color) scr.set_x(dx + 3) scr.set_y(dy + 6) scr.pixel(bg)
    scr.set_x(dx + 4) scr.set_y(dy + 6) scr.pixel(color) scr.set_x(dx + 4) scr.set_y(dy + 6) scr.pixel(bg)
    scr.set_x(dx + 5) scr.set_y(dy + 6) scr.pixel(color) scr.set_x(dx + 5) scr.set_y(dy + 6) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 6) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 6) scr.pixel(bg)
    scr.set_x(dx + 7) scr.set_y(dy + 6) scr.pixel(color) scr.set_x(dx + 7) scr.set_y(dy + 6) scr.pixel(bg)
    scr.set_x(dx + 8) scr.set_y(dy + 6) scr.pixel(color) scr.set_x(dx + 8) scr.set_y(dy + 6) scr.pixel(bg)
    scr.set_x(dx + 9) scr.set_y(dy + 6) scr.pixel(color) scr.set_x(dx + 9) scr.set_y(dy + 6) scr.pixel(bg)
    scr.set_x(dx + 3) scr.set_y(dy + 7) scr.pixel(color) scr.set_x(dx + 3) scr.set_y(dy + 7) scr.pixel(bg)
    scr.set_x(dx + 4) scr.set_y(dy + 7) scr.pixel(color) scr.set_x(dx + 4) scr.set_y(dy + 7) scr.pixel(bg)
    scr.set_x(dx + 5) scr.set_y(dy + 7) scr.pixel(color) scr.set_x(dx + 5) scr.set_y(dy + 7) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 7) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 7) scr.pixel(bg)
    scr.set_x(dx + 7) scr.set_y(dy + 7) scr.pixel(color) scr.set_x(dx + 7) scr.set_y(dy + 7) scr.pixel(bg)
    scr.set_x(dx + 8) scr.set_y(dy + 7) scr.pixel(color) scr.set_x(dx + 8) scr.set_y(dy + 7) scr.pixel(bg)
    scr.set_x(dx + 9) scr.set_y(dy + 7) scr.pixel(color) scr.set_x(dx + 9) scr.set_y(dy + 7) scr.pixel(bg)
    -- Row 8-9: 5px
    scr.set_x(dx + 4) scr.set_y(dy + 8) scr.pixel(color) scr.set_x(dx + 4) scr.set_y(dy + 8) scr.pixel(bg)
    scr.set_x(dx + 5) scr.set_y(dy + 8) scr.pixel(color) scr.set_x(dx + 5) scr.set_y(dy + 8) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 8) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 8) scr.pixel(bg)
    scr.set_x(dx + 7) scr.set_y(dy + 8) scr.pixel(color) scr.set_x(dx + 7) scr.set_y(dy + 8) scr.pixel(bg)
    scr.set_x(dx + 8) scr.set_y(dy + 8) scr.pixel(color) scr.set_x(dx + 8) scr.set_y(dy + 8) scr.pixel(bg)
    scr.set_x(dx + 4) scr.set_y(dy + 9) scr.pixel(color) scr.set_x(dx + 4) scr.set_y(dy + 9) scr.pixel(bg)
    scr.set_x(dx + 5) scr.set_y(dy + 9) scr.pixel(color) scr.set_x(dx + 5) scr.set_y(dy + 9) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 9) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 9) scr.pixel(bg)
    scr.set_x(dx + 7) scr.set_y(dy + 9) scr.pixel(color) scr.set_x(dx + 7) scr.set_y(dy + 9) scr.pixel(bg)
    scr.set_x(dx + 8) scr.set_y(dy + 9) scr.pixel(color) scr.set_x(dx + 8) scr.set_y(dy + 9) scr.pixel(bg)
    -- Row 10-11: 3px
    scr.set_x(dx + 5) scr.set_y(dy + 10) scr.pixel(color) scr.set_x(dx + 5) scr.set_y(dy + 10) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 10) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 10) scr.pixel(bg)
    scr.set_x(dx + 7) scr.set_y(dy + 10) scr.pixel(color) scr.set_x(dx + 7) scr.set_y(dy + 10) scr.pixel(bg)
    scr.set_x(dx + 5) scr.set_y(dy + 11) scr.pixel(color) scr.set_x(dx + 5) scr.set_y(dy + 11) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 11) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 11) scr.pixel(bg)
    scr.set_x(dx + 7) scr.set_y(dy + 11) scr.pixel(color) scr.set_x(dx + 7) scr.set_y(dy + 11) scr.pixel(bg)
    -- Row 12-13: 1px
    scr.set_x(dx + 6) scr.set_y(dy + 12) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 12) scr.pixel(bg)
    scr.set_x(dx + 6) scr.set_y(dy + 13) scr.pixel(color) scr.set_x(dx + 6) scr.set_y(dy + 13) scr.pixel(bg)
;

:: draw_menubar(scr = vimana.screen) (( -- ))
    -- Dotted border line at bottom of menubar area
    let bx = 0
    let by = right_model.CONTENT_Y - 1
    for (let ?col = 0; col < right_model.screen_w; col += 2)
        scr.set_x(col)
        scr.set_y(by)
        scr.pixel(right_model.C_FG)

    -- Diamond save indicator: saved = C_FG on BG, unsaved = C_BG on accent
    let dx = 1
    let dy = MENUBAR_Y + 6
    if right_model.dirty
        -- Accent background behind diamond area
        fill(scr, 0, 0, 14, MENUBAR_H + 3, right_model.C_ACCENT)
        draw_diamond(scr, dx, dy, right_model.C_BG)
    else
        draw_diamond(scr, dx, dy, right_model.C_FG)

    -- Category labels
    let ty = MENUBAR_Y + 2
    let ?fg = right_model.C_FG
    let ?bg = right_model.C_BG
    if menu_open == CAT_FILE
        fg = right_model.C_BG
        bg = right_model.C_FG
        fill(scr, CAT_FILE_X, MENUBAR_Y, CAT_FILE_W, MENUBAR_H, bg)
    scr.put_text(CAT_FILE_X, ty, "File", fg, bg)

    fg = right_model.C_FG
    bg = right_model.C_BG
    if menu_open == CAT_EDIT
        fg = right_model.C_BG
        bg = right_model.C_FG
        fill(scr, CAT_EDIT_X, MENUBAR_Y, CAT_EDIT_W, MENUBAR_H, bg)
    scr.put_text(CAT_EDIT_X, ty, "Edit", fg, bg)

    fg = right_model.C_FG
    bg = right_model.C_BG
    if menu_open == CAT_SELECT
        fg = right_model.C_BG
        bg = right_model.C_FG
        fill(scr, CAT_SELECT_X, MENUBAR_Y, CAT_SELECT_W, MENUBAR_H, bg)
    scr.put_text(CAT_SELECT_X, ty, "Select", fg, bg)

    fg = right_model.C_FG
    bg = right_model.C_BG
    if menu_open == CAT_FIND
        fg = right_model.C_BG
        bg = right_model.C_FG
        fill(scr, CAT_FIND_X, MENUBAR_Y, CAT_FIND_W, MENUBAR_H, bg)
    scr.put_text(CAT_FIND_X, ty, "Find", fg, bg)

    fg = right_model.C_FG
    bg = right_model.C_BG
    if menu_open == CAT_FORMAT
        fg = right_model.C_BG
        bg = right_model.C_FG
        fill(scr, CAT_FORMAT_X, MENUBAR_Y, CAT_FORMAT_W, MENUBAR_H, bg)
    scr.put_text(CAT_FORMAT_X, ty, "Format", fg, bg)

    fg = right_model.C_FG
    bg = right_model.C_BG
    if menu_open == CAT_VIEW
        fg = right_model.C_BG
        bg = right_model.C_FG
        fill(scr, CAT_VIEW_X, MENUBAR_Y, CAT_VIEW_W, MENUBAR_H, bg)
    scr.put_text(CAT_VIEW_X, ty, "View", fg, bg)

    fg = right_model.C_FG
    bg = right_model.C_BG
    if menu_open == CAT_INSERT
        fg = right_model.C_BG
        bg = right_model.C_FG
        fill(scr, CAT_INSERT_X, MENUBAR_Y, CAT_INSERT_W, MENUBAR_H, bg)
    scr.put_text(CAT_INSERT_X, ty, "Insert", fg, bg)
;

-- Draw a key-cap bordered glyph for a single key
: draw_key_cap(scr = vimana.screen, x = num, y = num, text = string, fg = num, bg = num) (( num ))
    let tw = stdr.len(text) * right_model.FONT_W
    let kw = tw + 6
    let kh = right_model.ROW_H - 4
    let ky = y + 2
    -- Border rectangle
    fill(scr, x, ky, kw, 1, fg)
    fill(scr, x, ky + kh - 1, kw, 1, fg)
    fill(scr, x, ky, 1, kh, fg)
    fill(scr, x + kw - 1, ky, 1, kh, fg)
    -- Fill inside
    fill(scr, x + 1, ky + 1, kw - 2, kh - 2, bg)
    -- Text
    scr.put_text(x + 3, y, text, fg, bg)
    <- kw
;

-- Draw shortcut like "Cmd+S" as bordered key caps, right-aligned ending at rx
: draw_key_shortcut(scr = vimana.screen, rx = num, y = num, shortcut = string, fg = num, bg = num) (( -- ))
    -- Split on "+"
    let slen = stdr.len(shortcut)
    -- First count total width
    let ?total_w = 0
    let ?part_start = 0
    let ?parts = 0
    for (let ?k = 0; k <= slen; k += 1)
        let at_end = k >= slen
        let is_plus = !at_end && stdr.slice(shortcut, k, k + 1) == "+"
        if at_end || is_plus
            let part = stdr.slice(shortcut, part_start, k)
            let pw = stdr.len(part) * right_model.FONT_W + 6
            total_w += pw
            if parts > 0
                total_w += 4
            parts += 1
            part_start = k + 1
    -- Draw from left
    let ?cx = rx - total_w
    part_start = 0
    let ?drawn = 0
    for (let ?k = 0; k <= slen; k += 1)
        let at_end = k >= slen
        let is_plus = !at_end && stdr.slice(shortcut, k, k + 1) == "+"
        if at_end || is_plus
            let part = stdr.slice(shortcut, part_start, k)
            if drawn > 0
                cx += 4
            let w = draw_key_cap(scr, cx, y, part, fg, bg)
            cx += w
            drawn += 1
            part_start = k + 1
;

:: draw_submenu(scr = vimana.screen) (( -- ))
    if menu_open < 0
        <-

    let cat = menu_open
    let count = item_count(cat)
    let sx = cat_x(cat)
    let sy = MENUBAR_H
    let sw = submenu_width(cat)
    let sh = count * SUBMENU_ITEM_H
    let th = sh + 1

    -- Submenu background (includes border area to fully cover content below)
    fill(scr, sx, sy, sw + 1, th, right_model.C_FG)

    -- Border (left, right, bottom — no top, glued to menubar)
    fill(scr, sx, sy + th - 1, sw + 1, 1, right_model.C_BG)
    fill(scr, sx, sy, 1, th, right_model.C_BG)
    fill(scr, sx + sw, sy, 1, th, right_model.C_BG)

    -- Items (inset by 1px for border)
    for (let ?i = 0; i < count; i += 1)
        let iy = sy + i * SUBMENU_ITEM_H
        let label = item_label(cat, i)
        let shortcut = item_shortcut(cat, i)
        let ?bg_c = right_model.C_FG
        let ?fg_c = right_model.C_BG
        let ?sc_c = right_model.C_SEL

        if i == menu_hover
            bg_c = right_model.C_ACCENT
            fg_c = right_model.C_FG
            sc_c = right_model.C_FG
            fill(scr, sx + 1, iy, sw - 2, SUBMENU_ITEM_H, bg_c)

        scr.put_text(sx + 8, iy, label, fg_c, bg_c)

        -- Key glyphs: draw each key part in a bordered cap
        if stdr.len(shortcut) > 0
            draw_key_shortcut(scr, sx + sw - 8, iy, shortcut, sc_c, bg_c)
;

--| Interaction |--

: cat_from_x(mx = num) (( num ))
    if mx >= CAT_FILE_X && mx < CAT_FILE_X + CAT_FILE_W
        <- CAT_FILE
    if mx >= CAT_EDIT_X && mx < CAT_EDIT_X + CAT_EDIT_W
        <- CAT_EDIT
    if mx >= CAT_SELECT_X && mx < CAT_SELECT_X + CAT_SELECT_W
        <- CAT_SELECT
    if mx >= CAT_FIND_X && mx < CAT_FIND_X + CAT_FIND_W
        <- CAT_FIND
    if mx >= CAT_FORMAT_X && mx < CAT_FORMAT_X + CAT_FORMAT_W
        <- CAT_FORMAT
    if mx >= CAT_VIEW_X && mx < CAT_VIEW_X + CAT_VIEW_W
        <- CAT_VIEW
    if mx >= CAT_INSERT_X && mx < CAT_INSERT_X + CAT_INSERT_W
        <- CAT_INSERT
    <- -1
;

:: handle_click(mx = num, my = num) (( string ))
    -- Click in menubar area (between titlebar and content)
    if my >= MENUBAR_Y && my < right_model.CONTENT_Y
        let cat = cat_from_x(mx)
        if cat >= 0
            if menu_open == cat
                close()
            else
                menu_open = cat
                menu_hover = -1
            <- ""
        close()
        <- ""

    -- Click in open submenu
    if menu_open >= 0
        let cat = menu_open
        let sx = cat_x(cat)
        let sy = MENUBAR_H
        let sw = submenu_width(cat)
        let count = item_count(cat)
        let sh = count * SUBMENU_ITEM_H

        if mx >= sx && mx < sx + sw && my >= sy && my < sy + sh
            let idx = stdr.floor((my - sy) / SUBMENU_ITEM_H)
            let action = item_action(cat, idx)
            close()
            <- action

        -- Clicked outside submenu → close
        close()
        <- ""

    <- "pass"
;

:: handle_hover(mx = num, my = num) (( -- ))
    if menu_open < 0
        <-

    -- Hover over category bar → switch category
    if my >= MENUBAR_Y && my < right_model.CONTENT_Y
        let cat = cat_from_x(mx)
        if cat >= 0 && cat != menu_open
            menu_open = cat
            menu_hover = -1
        <-

    -- Hover over submenu items
    let cat = menu_open
    let sx = cat_x(cat)
    let sy = MENUBAR_H
    let sw = submenu_width(cat)
    let count = item_count(cat)
    let sh = count * SUBMENU_ITEM_H

    if mx >= sx && mx < sx + sw && my >= sy && my < sy + sh
        menu_hover = stdr.floor((my - sy) / SUBMENU_ITEM_H)
    else
        menu_hover = -1
;
