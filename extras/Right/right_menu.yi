cask right_menu

bring stdr
bring vimana
bring right_model

--| Menu state |--
def ?menu_open = -1
def ?menu_hover = -1

-- Menu bar geometry
def MENUBAR_Y = 0
def MENUBAR_H = 24
def MENU_START_X = 16
def MENU_GAP = 8
def SUBMENU_PAD = 16
def SUBMENU_ITEM_H = 24

-- Category positions (x start of each label)
def CAT_FILE_X = 16
def CAT_FILE_W = 80
def CAT_EDIT_X = 96
def CAT_EDIT_W = 80
def CAT_SELECT_X = 176
def CAT_SELECT_W = 112
def CAT_FIND_X = 288
def CAT_FIND_W = 80
def CAT_FORMAT_X = 368
def CAT_FORMAT_W = 112
def CAT_VIEW_X = 480
def CAT_VIEW_W = 80
def CAT_INSERT_X = 560
def CAT_INSERT_W = 112

-- Category count
def CAT_FILE = 0
def CAT_EDIT = 1
def CAT_SELECT = 2
def CAT_FIND = 3
def CAT_FORMAT = 4
def CAT_VIEW = 5
def CAT_INSERT = 6

-- Item counts per category
def FILE_COUNT = 5
def EDIT_COUNT = 4
def SELECT_COUNT = 4
def FIND_COUNT = 3
def FORMAT_COUNT = 4
def VIEW_COUNT = 4
def INSERT_COUNT = 3

--| Helpers |--

: fill(scr = vimana.screen, x = num, y = num, w = num, h = num, c = num) (( -- ))
    scr.set_auto(1)
    for (let ?row = 0; row < h; row += 1)
        scr.set_y(y + row)
        scr.set_x(x)
        for (let ?col = 0; col < w; col += 1)
            scr.pixel(c)
        scr.set_y(y + row)
        scr.set_x(x)
        for (let ?col = 0; col < w; col += 1)
            scr.pixel(c + 64)
    scr.set_auto(0)
;

: item_count(cat = num) (( num ))
    if cat == CAT_FILE
        <- FILE_COUNT
    if cat == CAT_EDIT
        <- EDIT_COUNT
    if cat == CAT_SELECT
        <- SELECT_COUNT
    if cat == CAT_FIND
        <- FIND_COUNT
    if cat == CAT_FORMAT
        <- FORMAT_COUNT
    if cat == CAT_VIEW
        <- VIEW_COUNT
    if cat == CAT_INSERT
        <- INSERT_COUNT
    <- 0
;

: cat_x(cat = num) (( num ))
    if cat == CAT_FILE
        <- CAT_FILE_X
    if cat == CAT_EDIT
        <- CAT_EDIT_X
    if cat == CAT_SELECT
        <- CAT_SELECT_X
    if cat == CAT_FIND
        <- CAT_FIND_X
    if cat == CAT_FORMAT
        <- CAT_FORMAT_X
    if cat == CAT_VIEW
        <- CAT_VIEW_X
    if cat == CAT_INSERT
        <- CAT_INSERT_X
    <- 0
;

-- Compute pixel width of a key shortcut string rendered as key caps
: shortcut_px(shortcut = string) (( num ))
    let slen = stdr.len(shortcut)
    if slen == 0
        <- 0
    let ?total = 0
    let ?part_start = 0
    let ?parts = 0
    for (let ?k = 0; k <= slen; k += 1)
        let at_end = k >= slen
        let is_plus = !at_end && stdr.slice(shortcut, k, k + 1) == "+"
        if at_end || is_plus
            let part = stdr.slice(shortcut, part_start, k)
            let pw = stdr.len(part) * right_model.FONT_W + 6
            total += pw
            if parts > 0
                total += 4
            parts += 1
            part_start = k + 1
    <- total
;

-- Compute the required submenu width for a category
: submenu_width(cat = num) (( num ))
    let count = item_count(cat)
    let ?max_w = 0
    for (let ?i = 0; i < count; i += 1)
        let label = item_label(cat, i)
        let shortcut = item_shortcut(cat, i)
        let lw = stdr.len(label) * right_model.FONT_W
        let sw = shortcut_px(shortcut)
        let ?row_w = lw + SUBMENU_PAD * 2
        if sw > 0
            row_w = lw + sw + SUBMENU_PAD * 3
        if row_w > max_w
            max_w = row_w
    <- max_w
;

: item_label(cat = num, idx = num) (( string ))
    if cat == CAT_FILE
        if idx == 0
            <- "New"
        if idx == 1
            <- "Open"
        if idx == 2
            <- "Save"
        if idx == 3
            <- "Rename"
        if idx == 4
            <- "Exit"
    if cat == CAT_EDIT
        if idx == 0
            <- "Copy"
        if idx == 1
            <- "Paste"
        if idx == 2
            <- "Cut"
        if idx == 3
            <- "Delete"
    if cat == CAT_SELECT
        if idx == 0
            <- "All"
        if idx == 1
            <- "Word"
        if idx == 2
            <- "Line"
        if idx == 3
            <- "Reset"
    if cat == CAT_FIND
        if idx == 0
            <- "Find"
        if idx == 1
            <- "Find Next"
        if idx == 2
            <- "Find Prev"
    if cat == CAT_FORMAT
        if idx == 0
            <- "Strip"
        if idx == 1
            <- "Trim"
        if idx == 2
            <- "Tab"
        if idx == 3
            <- "Untab"
    if cat == CAT_VIEW
        if idx == 0
            <- "Sidebar"
        if idx == 1
            <- "Highlight"
        if idx == 2
            <- "Line Ends"
        if idx == 3
            <- "Tabs"
    if cat == CAT_INSERT
        if idx == 0
            <- "Date"
        if idx == 1
            <- "Path"
        if idx == 2
            <- "Section"
    <- ""
;

: item_shortcut(cat = num, idx = num) (( string ))
