@diagnostics: warn

; ── Base transparent backgrounds ──────────────────────────────

hstack
grid
fixed
zstack
scroller
content-list
  background: transparent

content_list=selected
  background: rgba(124, 92, 252, 0.08)
  border-radius: 12

; ── DrawingArea overlay ───────────────────────────────────────

drawing_area.slide-canvas-overlay
  background: transparent

; ── Welcome startup screen ───────────────────────────────────

vstack.slides-welcome
vstack.slides-welcome-root
  padding: 24 24 24 24

hstack.slides-welcome-shell
  background: transparent

vstack.slides-welcome-left
  min-width: 470
  max-width: 470
  padding: 18 14 0 10

label.slides-welcome-title
  font-size: 32
  font-variation: wdth 151
  font-weight: 500
  color: #14131A

vstack.slides-welcome-actions
  padding: 70 0 0 0

hstack.slides-welcome-action-row
  min-height: 108
  max-height: 108
  min-width: 280
  max-width: 280
  background: transparent

card.slides-welcome-action-card
  background: transparent
  border: 0 solid #00000000
  border-radius: 12
  padding-top: 0
  padding-right: 0
  padding-bottom: 0
  padding-left: 0
  min-height: 108
  max-height: 108
  min-width: 280
  max-width: 280

image.slides-welcome-action-icon
  background: transparent
  border: 0 solid #00000000
  color: #0E0E14
  min-width: 72
  max-width: 72
  min-height: 72
  max-height: 72

label.slides-welcome-action-text
  color: #111017
  font-size: 16
  font-weight: 500

divider.slides-welcome-divider
  min-width: 1
  max-width: 1
  background: #D9D7E3
  border: 0
  margin: 24 0 24 0

vstack.slides-welcome-right
  min-width: 430
  padding: 18 0 0 12

label.slides-welcome-right-title
  font-size: 24
  font-variation: wdth 151
  font-weight: 500
  color: #14131A

label.slides-welcome-right-sub
  font-size: 16
  color: #23222E
  opacity: 0.9

grid.slides-welcome-template-grid
  padding: 24 0 0 0

card.slides-welcome-template
  min-width: 154
  max-width: 154
  min-height: 100
  max-height: 100
  border-radius: 14
  border: 1 solid #B7B2CB
  padding-top: 0
  padding-right: 0
  padding-bottom: 0
  padding-left: 0
  background: transparent

vstack.slides-welcome-template-bg-0
  background: #FFFFFF
  border-radius: 14

vstack.slides-welcome-template-bg-1
  background: #D7D4EA
  border-radius: 14

vstack.slides-welcome-template-bg-2
  background: #2A2B3D
  border-radius: 14

vstack.slides-welcome-template-bg-3
  background: #6A4700
  border-radius: 14

vstack.slides-welcome-template-bg-4
  background: #F0D41A
  border-radius: 14

vstack.slides-welcome-template-bg-5
  background: #D9D7E1
  border-radius: 14

vstack.slides-welcome-template-bg-6
  background: #48D6C3
  border-radius: 14

vstack.slides-welcome-template-bg-7
  background: #000000
  border-radius: 14

label.slides-welcome-template-title
  font-size: 16
  font-weight: 600
  color: #1D1B24

label.slides-welcome-template-subtitle
  font-size: 10
  color: #2B2936

label.slides-welcome-template-title-dark
  font-size: 16
  font-weight: 600
  color: #F2F2F7

label.slides-welcome-template-subtitle-dark
  font-size: 10
  color: #DEDEF0

label.slides-welcome-template-title-accent
  font-size: 16
  font-weight: 600
  color: #F8E34A

label.slides-welcome-template-subtitle-accent
  font-size: 10
  color: #F8E34A
  opacity: 0.95

@when dark
  vstack.slides-welcome
  vstack.slides-welcome-root
    background: #1F1B2C
  label.slides-welcome-title
    color: #F3EEFF
  button.slides-welcome-action-icon
    color: #E4DEFF
  label.slides-welcome-action-text
    color: #ECE5FF
  divider.slides-welcome-divider
    background: #4F4965
  label.slides-welcome-right-title
    color: #F3EEFF
  label.slides-welcome-right-sub
    color: #D2C9E6
  card.slides-welcome-template
    border: 1 solid #6D6785

; ── Slide panel (left sidebar) ────────────────────────────────

vstack.slide-panel
  min-width: 250
  max-width: 250
  background: #EFEDF7

vstack.slide-editor
  background: transparent

@when dark
  vstack.slide-panel
    background: #2A2640

; ── Thumbnail cards in content list ──────────────────────────

zstack.slide-thumb-card
  min-height: 100
  max-height: 100
  min-width: 154
  max-width: 154
  border-radius: 12
  padding: 0
  background: #FFFFFF
  border: 1 solid #E0DCF0

zstack.slide-thumb-card-selected
  background: transparent
  border: 3 solid #7C5CFC

@when dark
  zstack.slide-thumb-card
    background: #2A2640
    border: 1 solid #3A3650
  zstack.slide-thumb-card-selected
    background: transparent
    border: 3 solid #A996FF

fixed.slide-thumb-preview
  min-height: 100
  max-height: 100
  min-width: 154
  max-width: 154
  background: transparent

shape.slide-thumb-clip
  background: transparent
  min-height: 99
  max-height: 99
  min-width: 153
  max-width: 153
  border: 0

shape.slide-thumb-clip-selected
  min-height: 97
  max-height: 97
  min-width: 151
  max-width: 151

label.slide-thumb-node-title
label.slide-thumb-node-title-dark
label.slide-thumb-node-title-light
label.slide-thumb-node-title-accent
  font-weight: 700

label.slide-thumb-node-title
label.slide-thumb-node-title-dark
  color: #2D2B36

label.slide-thumb-node-title-light
  color: #F2F2F7

label.slide-thumb-node-title-accent
  color: #F8E34A

label.slide-thumb-node-body
label.slide-thumb-node-body-dark
label.slide-thumb-node-body-light
label.slide-thumb-node-body-accent
  opacity: 0.88

label.slide-thumb-node-body
label.slide-thumb-node-body-dark
  color: #4A4757

label.slide-thumb-node-body-light
  color: #DEDEF0

label.slide-thumb-node-body-accent
  color: #F8E34A

label.slide-thumb-node-text
  color: #393847

label.slide-thumb-node-link
  color: #345FAE
  font-weight: 500

label.slide-thumb-node-comment
  color: #6B5A2F
  background: #F7EDCB
  border-radius: 3
  padding: 0 2 0 2

label.slide-thumb-node-chart-title
  color: #4B4961
  font-weight: 600

label.slide-thumb-node-image
  color: #5E6672

image.slide-thumb-image
  border-radius: 4
  border: 1 solid #BAC0CC

vstack.slide-thumb-image-box
  background: #E8EDF8
  border: 1 solid #BAC0CC
  border-radius: 4

button.slide-thumb-elem-icon
  background: transparent
  border: 0 solid #00000000
  color: #5A5770
  min-width: 18
  max-width: 18
  min-height: 18
  max-height: 18
  padding: 0

vstack.slide-thumb-chart-box
  background: #F3F3F6
  border: 1 solid #C9CDD6
  border-radius: 4

@when dark
  label.slide-thumb-node-title
    color: #F2EEFF
  label.slide-thumb-node-body
    color: #D6CEE8
    opacity: 0.95
  label.slide-thumb-node-text
    color: #E2DCF2
  label.slide-thumb-node-link
    color: #8FB0EA
  label.slide-thumb-node-comment
    color: #D2C08D
    background: #4A4129
  label.slide-thumb-node-chart-title
    color: #CBC2E6
  label.slide-thumb-node-image
    color: #C5CDDB
  image.slide-thumb-image
    border: 1 solid #646C7B
  vstack.slide-thumb-image-box
    background: #3A3550
    border: 1 solid #646C7B
  button.slide-thumb-elem-icon
    color: #CFC7E8
  vstack.slide-thumb-chart-box
    background: #373447
    border: 1 solid #63607A

label.slide-thumb-title
  font-size: 10
  font-weight: 600

label.slide-thumb-body
  font-size: 8
  opacity: 0.6

label.slide-thumb-meta
  font-size: 9
  opacity: 0.72

label.slide-thumb-more
  font-size: 9
  font-weight: 600
  opacity: 0.72

button.slide-remove-btn
  background: #333333
  color: #FFFFFF
  border-radius: 99
  min-width: 24
  max-width: 24
  min-height: 24
  max-height: 24

@when dark
  button.slide-remove-btn
    background: #CCCCCC
    color: #222222

; ── Add slide button ─────────────────────────────────────────

button.slide-add-btn
  min-height: 100
  max-height: 100
  min-width: 154
  max-width: 154
  border-radius: 12
  border: 2 dashed #B0A4D8
  background: transparent
  color: #7C5CFC
  font-size: 24

@when dark
  button.slide-add-btn
    border: 2 dashed #6B5FA0
    color: #B0A4D8

; ── Toolbar ───────────────────────────────────────────────────

toolbar.slide-toolbar
  background: transparent
  border: 0
  border-radius: 0
  min-height: 80
  max-height: 80
  min-width: 726
  max-width: 726

@when dark
  toolbar.slide-toolbar
    background: #2A2640

; ── Canvas ────────────────────────────────────────────────────

vstack.slide-canvas
  background: #FFFFFF
  border-radius: 16
  border: 1 solid #E0DCF0
  padding: 1 0 0 1
  min-height: 426
  max-height: 426
  min-width: 726
  max-width: 726

@when dark
  vstack.slide-canvas
    background: #1E1B2E
    border: 1 solid #3A3650

; ── Slide text elements ──────────────────────────────────────

label.slide-title-text
label.slide-title-text-dark
label.slide-title-text-light
label.slide-title-text-accent
  font-size: 36
  font-variation: wdth 120, opsz 18
  font-weight: 700

label.slide-body-text
label.slide-body-text-dark
label.slide-body-text-light
label.slide-body-text-accent
  font-size: 18
  opacity: 0.8

label.slide-title-text
label.slide-title-text-dark
  color: #1D1B24

label.slide-title-text-light
  color: #F2F2F7

label.slide-title-text-accent
  color: #F8E34A

label.slide-body-text
label.slide-body-text-dark
  color: #2B2936

label.slide-body-text-light
  color: #DEDEF0
  opacity: 0.92

label.slide-body-text-accent
  color: #F8E34A
  opacity: 0.95

; ── Extra element styles ─────────────────────────────────────

label.slide-text-elem
  font-size: 16

label.slide-link-text
  font-size: 16
  color: #3366CC

@when dark
  label.slide-link-text
    color: #6699FF

button.slide-link-btn
  background: transparent
  border: 0 solid #00000000
  color: #3366CC
  font-size: 16
  padding: 0 0 0 0

@when dark
  button.slide-link-btn
    color: #6699FF

label.slide-image-text
  font-size: 14
  color: #666666
  font-weight: 500

@when dark
  label.slide-image-text
    color: #AAAAAA

label.slide-chart-text
  font-size: 14
  color: #336633
  font-weight: 500

@when dark
  label.slide-chart-text
    color: #88BB88

label.slide-comment-text
  font-size: 14
  color: #886600
  font-weight: 500
  background: #FFF4CC
  border: 1 solid #E6D08A
  border-radius: 10
  padding: 6 10 6 10

@when dark
  label.slide-comment-text
    color: #CCAA44
    background: #3B3420
    border: 1 solid #6D5A2F

; ── Selection tooltip ─────────────────────────────────────────

hstack.slide-tooltip
vstack.slide-tooltip
  background: #333333
  border-radius: 12
  min-width: 240
  max-width: 240

@when dark
  hstack.slide-tooltip
  vstack.slide-tooltip
    background: #1A1A2E

dropdown.slide-tooltip-dd
  background: #444444
  color: #FFFFFF
  border-radius: 8
  min-width: 104
  max-width: 104

@when dark
  dropdown.slide-tooltip-dd
    background: #2A2650
    color: #FFFFFF

button.slide-tooltip-btn
  background: #444444
  color: #FFFFFF
  border-radius: 8
  font-size: 13

@when dark
  button.slide-tooltip-btn
    background: #2A2650
    color: #FFFFFF

button.slide-tooltip-del
  background: #CC3333
  color: #FFFFFF
  border-radius: 8
  font-size: 13

; ── Speaker notes ─────────────────────────────────────────────

label.slide-notes-label
  font-size: 16
  font-weight: 500
  opacity: 0.66

; ── Slide color dialog swatches ──────────────────────────────

button.slide-color-swatch
  min-width: 44
  max-width: 44
  min-height: 30
  max-height: 30
  border-radius: 999
  padding: 0
  font-size: 0
  border: 1 solid #D6D0E8

label.slide-color-swatch-label
  font-size: 11
  text-align: center
  opacity: 0.74

button.scs-0
  background: #FFFFFF
  border: 1 solid #DAD3EC

button.scs-1
  background: #F5F7FA

button.scs-2
  background: #F4F0FA

button.scs-3
  background: #EAF2FF

button.scs-4
  background: #EAF8F1

button.scs-5
  background: #FFF1E8

button.scs-6
  background: #FFF9E5

button.scs-7
  background: #FFEFF3

button.scs-8
  background: #F5EADB

button.scs-9
  background: #EEF1F6

shape.slide-color-gradient-clip
  min-width: 44
  max-width: 44
  min-height: 30
  max-height: 30
  border: 1 solid #D6D0E8
  background: transparent

drawing_area.slide-color-gradient-da
  min-width: 44
  max-width: 44
  min-height: 30
  max-height: 30
  background: transparent

textfield.slide-notes
  border-radius: 8
  min-height: 56
  min-width: 600
  max-width: 600

textfield.slide-inline-edit
  border-radius: 8
  min-height: 38
  background: #FFFFFF

@when dark
  textfield.slide-inline-edit
    background: #2A2640

@when dark
  button.slide-color-swatch
    border: 1 solid #5A5478
  shape.slide-color-gradient-clip
    border: 1 solid #5A5478
  label.slide-color-swatch-label
    opacity: 0.84

; ── Presenter view ────────────────────────────────────────────

label.presenter-slide-title
label.presenter-slide-title-dark
label.presenter-slide-title-light
label.presenter-slide-title-accent
  font-size: 42
  font-variation: wdth 125, opsz 20
  font-weight: 700

label.presenter-slide-body-dark
label.presenter-slide-body-light
label.presenter-slide-body-accent
  font-size: 18

label.presenter-slide-title
label.presenter-slide-title-dark
  color: #1D1B24

label.presenter-slide-title-light
  color: #F2F2F7

label.presenter-slide-title-accent
  color: #F8E34A

label.presenter-slide-body-dark
  color: #2B2936
  opacity: 0.82

label.presenter-slide-body-light
  color: #DEDEF0
  opacity: 0.95

label.presenter-slide-body-accent
  color: #F8E34A
  opacity: 0.96

label.presenter-notes-label
  font-size: 14
  font-weight: 600
  opacity: 0.5

label.presenter-counter
  font-size: 14
  font-weight: 500
  opacity: 0.6

; ── AppBar ────────────────────────────────────────────────────

appbar.slides-bar
  background: transparent
