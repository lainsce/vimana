@diagnostics: warn

; ── Base transparent backgrounds ──────────────────────────────

vstack
hstack
zstack
grid
  background: transparent

; ── AppBars ───────────────────────────────────────────────────

appbar.solar-cal-bar
appbar.solar-evt-bar
  background: transparent

appbar.solar-cal-bar
  min-height: 106
  max-height: 106

label.solar-appbar-title
  font-size: 20
  font-weight: bold

label.solar-evt-title
  font-size: 22
  font-weight: bold

label.solar-evt-subtitle
  font-size: 13
  opacity: 0.6

; ── Calendar grid ─────────────────────────────────────────────

grid.solar-grid
  border-radius: 12

label.solar-weekday
  font-size: 12
  font-weight: bold
  opacity: 0.66
  max-width: 128
  min-width: 128
  max-height: 16
  min-height: 16

; ── Day cells ─────────────────────────────────────────────────

hstack.solar-day-cell
  border-radius: 0
  border: 1 solid #00000020
  min-width: 128
  max-width: 128

hstack.solar-trailing
  border-radius: 0
  border: 1 solid #00000010
  min-width: 128
  max-width: 128
  opacity: 0.45

label.solar-day-num
  font-size: 14

label.solar-trailing-day
  min-width: 0
  min-height: 0
  max-width: 24
  max-height: 24
  padding: 4 4 4 4
  font-size: 16
  opacity: 0.45

button.day-pill
  min-width: 0
  min-height: 0
  max-width: 24
  max-height: 24
  padding: 4 4 4 4
  border-radius: 999
  font-size: 16

; ── Event pills in day cells ─────────────────────────────────

label.solar-event-pill
  min-height: 18
  max-height: 18
  border-radius: 4
  font-size: 10
  padding: 0 4 0 4

; ── Event list panel ──────────────────────────────────────────

content_list.solar-event-list
  background: transparent
  border-radius: 0

hstack.solar-event-row
  border-radius: 8
  border: 1 solid #00000010

label.solar-event-time
  font-size: 12
  opacity: 0.6

label.solar-event-title
  font-size: 15
  font-weight: bold

label.solar-event-desc
  font-size: 12
  opacity: 0.5
