    -- clock.tal draw-text advances by a fixed glyph width; keep all loaded chars monospace.
    scr.set_font_width(32, 8)
    scr.set_font_width(47, 8)
    scr.set_font_width(58, 8)
    for (let ?code = 48; code <= 57; code += 1)
        scr.set_font_width(code, 8)
    for (let ?code = 65; code <= 90; code += 1)
        scr.set_font_width(code, 8)
    for (let ?code = 97; code <= 122; code += 1)
        scr.set_font_width(code, 8)
;
