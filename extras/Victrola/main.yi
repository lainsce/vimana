}

: build_player_panel(root = cogito.HStack) (( -- )) {
    player_panel
    .set_hexpand(false)
    .set_vexpand(true)
    .set_class("victrola-player")

    let player_tint = cogito.bin()
    .set_vexpand(true)

    player_tint_bin = player_tint
    player_tint.add(player_panel)

    let player_bar = cogito.appbar("Now Playing", "")
    .set_hexpand(true)
    .set_class("small victrola-player-bar")
    player_bar_ref = player_bar

    let now_revealer = cogito.revealer()
    .set_show_children(true)
    .set_hexpand(true)
    .set_vexpand(true)
    now_revealer_ref = now_revealer

    let lyrics_revealer = cogito.revealer()
    .set_show_children(false)
    .set_hexpand(true)
    .set_vexpand(false)
    lyrics_revealer_ref = lyrics_revealer

    lyrics_btn = player_bar.add_trailing_menu_button("sf:quote.bubble")
    lyrics_btn.on_click((b = any) => {
        if ui_ready && !is_null(b) {
            set_player_lyrics_visible(!lyrics_view_visible)
            if lyrics_view_visible {
                fetch_lyrics_for_track(selected_track)
            }
        }
    })
    lyrics_btn.set_visible(false)
    lyrics_spacer = player_bar.add_trailing_menu_button("sf:quote.bubble")
    lyrics_spacer.set_disabled(true)

    player_back_btn = player_bar.leading_button("sf:chevron.left", (b = any) => {
        if ui_ready && !is_null(b) {
            close_compact_player()
        }
    })
    player_back_btn.set_visible(false)

    player_panel.add(player_bar)

    let player_info = cogito.vstack()
    .set_padding(0, 16, 0, 16)
    .set_gap(6)

    player_info.add(cover_art
        .set_halign(1)
    )

    let song_box = cogito.vstack()
    .set_gap(4)
    .set_hexpand(true)
    .set_padding(6, 0, 6, 0)
    .add(now_title)
    .add(now_artist)

    player_info.add(song_box)

    let seek_row = cogito.hstack()
    .set_hexpand(true)
    .set_align(1)
    .add(seek_slider)

    player_info.add(seek_row)

    let time_row = cogito.hstack()
    .set_hexpand(true)
    .add(time_left.set_hexpand(true))
    .add(time_right)

    player_info.add(time_row)

    let player_controls = cogito.vstack()
    .set_align(1)
    .set_padding(6, 16, 16, 16)
    .set_hexpand(true)

    let controls = cogito.hstack()
    .set_gap(12)
    .set_hexpand(true)
    .add(repeat_btn
        .set_align(4)
        .on_click((b = cogito.IconButton) => {
            repeat_one = !repeat_one
            sync_repeat_button()
        })
    )
    .add(cogito.iconbtn("sf:backward")
        .set_class("tonal")
        .set_width(0)
        .set_shape(1)
        .set_align(4)
        .on_click((b = cogito.IconButton) => {
            play_prev()
        })
    )
    .add(play_pause_btn
        .on_click((b = cogito.IconButton) => {
            if is_playing {
                pause_playback()
            } else {
                play_selected()
            }
        })
    )
    .add(cogito.iconbtn("sf:forward")
        .set_class("tonal")
        .set_width(0)
        .set_shape(1)
        .set_align(4)
        .on_click((b = cogito.IconButton) => {
            play_next()
        })
    )
    .add(queue_toggle_btn)
    player_controls.add(controls)

    let now_page = cogito.vstack()
    .set_gap(0)
    .set_hexpand(true)
    .set_vexpand(true)
    .add(player_info)
    .add(player_controls)

    now_revealer.add(now_page)

    let lyrics_page = cogito.vstack()
    .set_gap(0)
    .set_hexpand(true)
    .set_vexpand(true)
    .set_padding(6, 16, 16, 16)
    .set_class("victrola-lyrics-page")

    lyrics_scroll.set_hexpand(true)
    .set_vexpand(true)
    .set_min_content_width(320)
    .set_min_content_height(220)
    .set_class("victrola-lyrics-scroll")
    .set_padding(0,0,0,0)
    .add(lyrics_grid)

    let lyrics_toolbar = cogito.toolbar()
    .set_class("floating compact")
    .set_vibrant(true)
    .set_hexpand(true)
    .add(lyrics_time_left)
    .add(lyrics_seek_slider)
    .add(lyrics_play_btn
        .on_click((b = cogito.IconButton) => {
            if is_playing {
                pause_playback()
            } else {
                play_selected()
            }
        })
    )

    lyrics_page.add(lyrics_scroll)
    lyrics_page.add(lyrics_toolbar)
    lyrics_revealer.add(lyrics_page)

    player_panel.add(now_revealer)
    player_panel.add(lyrics_revealer)

    player_panel.add(poll_anchor)

    root.add(player_tint)
}

: build_mini_player(outer = cogito.VStack) (( -- )) {
    let mini_meta = cogito.vstack()
    .set_gap(4)
    .set_hexpand(true)
    .add(mini_title_lbl)
    .add(mini_artist_lbl)

    let mini_row = cogito.hstack()
    .set_gap(12)
    .set_hexpand(true)
    .set_align(3)
    .add(mini_cover)
    .add(mini_meta)
    .add(mini_play_btn)

    mini_player_card
    .set_class("filled victrola-mini-player")
    .set_gap(0)
    .set_padding(16, 16, 0, 16)
    .set_hexpand(true)
    .set_visible(false)
    .add(mini_row)
    .on_click((c = cogito.Card) => {
        if is_compact_mode && ui_ready {
            open_compact_player()
        }
    })

    outer.add(mini_player_card)
}

: build_bottom_nav(outer = cogito.VStack) (( -- )) {
    bottom_nav
    .set_items(["Your Mix", "Titles", "Artists", "Albums"], ["sf:sparkles", "sf:music.note", "sf:person.2", "sf:square.stack"])
    .set_selected(0)
    .set_visible(false)
    .set_hexpand(true)

    outer.add(bottom_nav)
}

: wire_library_events() (( -- )) {
    library_rail.on_change((idx = num) => {
        if !is_null(idx) {
            if is_compact_mode {
                close_compact_player()
                query_text = ""
                search_input.set_text("")
                if idx != 1 {
                    set_search_visible(false)
                }
                view_mode = idx
                bottom_nav.set_selected(idx)

                close_artist_detail()
                if idx != 3 {
                    close_album_detail()
                }
                refresh_library_list()
            } else {
                bottom_nav.set_selected(idx)
                view_mode = idx

                query_text = ""
                search_input.set_text("")
                if view_mode != 1 {
                    set_search_visible(false)
                }

                close_artist_detail()
                if view_mode != 3 {
                    close_album_detail()
                }

                if view_mode == 0 {
                    library_bar_ref.set_title("Your Mix")
                } elif view_mode == 1 {
                    library_bar_ref.set_title("Titles")
                } elif view_mode == 2 {
                    library_bar_ref.set_title("Artists")
                } else {
                    library_bar_ref.set_title("Albums")
                    if !album_detail_open {
                        set_album_detail_visible(false)
                    }
                }

                refresh_library_list()
            }
        }
    })

    library_list.on_select((idx = num) => {
        let songs_view = is_library_songs_view()
        if songs_view {
            if idx >= 0 && idx < len(visible_track_indexes) {
                selected_track = visible_track_indexes[idx] ?? -1

                if selected_track >= 0 {
                    let mode = current_library_mode()
                    if mode == 0 {
                        add_titles_track_to_queue_and_play(selected_track)
                    } elif mode == 1 && artist_detail_open {
                        let artist_queue = build_queue_for_artist(artist_detail_key)
                        set_queue_and_play(artist_queue, selected_track, 3)
                    } elif mode == 2 && album_detail_open {
                        let album_queue = build_queue_for_album(album_detail_key)
                        set_queue_and_play(album_queue, selected_track, 4)
                    } else {
                        clear_queue_context()
                        refresh_queue_sheet()
                        if selected_track != playing_track || !is_playing {
                            play_track(selected_track)
                        } else {
                            set_now_playing(selected_track)
                        }
                    }
                }
            }
        }
    })

    library_list.on_activate((idx = num) => {
    })

    search_input.on_change((tf = cogito.SearchField) => {
        if !is_null(tf) {
            query_text = stdr.trim(tf.text())
            refresh_library_list()
        }
    })

    bottom_nav.on_change((idx = num) => {
        if !is_null(idx) {
            query_text = ""
            search_input.set_text("")
            if idx != 1 {
                set_search_visible(false)
            }
            close_compact_player()
            view_mode = idx
            library_rail.set_selected(idx)

            close_artist_detail()
            if idx != 3 {
                close_album_detail()
            }

            let is_mix = idx == 0
            library_center.set_visible(!is_mix)
            library_center.set_hexpand(!is_mix)
            mix_panel.set_visible(is_mix)

            if view_mode == 0 {
                library_bar_ref.set_title("Your Mix")
            } elif view_mode == 1 {
                library_bar_ref.set_title("Titles")
            } elif view_mode == 2 {
                library_bar_ref.set_title("Artists")
            } else {
                library_bar_ref.set_title("Albums")
                if !album_detail_open {
                    set_album_detail_visible(false)
                }
            }

            refresh_library_list()
            library_grid.set_cols(1)
        }
    })
}

: wire_seek_events() (( -- )) {
    seek_slider.on_change((sl = cogito.Slider) => {
        if !suspend_seek_callback {
            let dur = gst.duration_ms()
            if dur > 0 {
                let value = sl.value()
                let ?target = (value * dur) / 1000
                if target < 0 {
                    target = 0
                }
                if target > dur {
                    target = dur
                }
                gst.seek_ms(target)
                if lyrics_synced {
                    update_lyrics_position(target)
                }
            }
        }
    })

    lyrics_seek_slider.on_change((sl = cogito.Slider) => {
        if !suspend_seek_callback {
            let dur = gst.duration_ms()
            if dur > 0 {
                let value = sl.value()
                let ?target = (value * dur) / 1000
                if target < 0 {
                    target = 0
                }
                if target > dur {
                    target = dur
                }
                gst.seek_ms(target)
                if lyrics_synced {
                    update_lyrics_position(target)
                }
            }
        }
    })
}

entry() (( -- )) {
    let app = cogito.app()
    .set_appid("com.fyralabs.Victrola")
    .set_app_name("Victrola")
    .set_accent_color(APP_ACCENT, true)

    app_ref = app

    if !gst.init() {
    }

    let win = cogito.window_size("Victrola", 900, 680)
    .set_resizable(true)
    .set_size_request(412, 294)

    cogito.load_sum("victrola.sum")

    configure_widgets()

    let root = cogito.hstack()
    .set_hexpand(true)
    .set_vexpand(true)

    build_sidebar(root)
    build_library_center(root)
    build_mix_panel(root)
    build_player_panel(root)

    wire_library_events()
    wire_seek_events()

    gst.set_volume(main_volume)

    win.on_resize((node = any) => {
        let compact = win.is_compact()
        if compact != is_compact_mode {
            apply_compact_layout(compact)
        }
    })

    load_state()
    if len(current_folder) > 0 {
        scan_folder(current_folder)
    }

    let outer = cogito.vstack()
    .set_hexpand(true)
    .set_vexpand(true)
    .add(root)

    build_mini_player(outer)
    build_bottom_nav(outer)

    win.add(outer)

    ui_ready = true

    app.run(win)

    stop_poll_loop()
    gst.shutdown()
}
