    library_scroll.set_hexpand(true).set_vexpand(true).set_min_content_width(360).set_min_content_height(294)
    lyrics_grid.set_gap(0, 20).set_padding(12, 12, 12, 12).set_hexpand(true).set_class("victrola-lyrics-grid")
