: album_cover_for(album = string, artist = string) (( string )) {
    return model.album_cover_for(album_cover_map, album, artist)
}

: album_artist_for(album = string) (( string )) {
    return model.album_artist_for(album_artist_map, album)
}

: show_lyrics_btn(show = bool) (( -- )) {
    lyrics_btn.set_visible(show)
    lyrics_spacer.set_visible(!show)
}

: ensure_state_path() (( string )) {
    if stdr.len(STATE_PATH) > 0 { return STATE_PATH }
    let run = stdr.run_command("echo $HOME")
    let ?home = stdr.trim(stdr.str(run[1] ?? ""))
    if stdr.len(home) == 0 { home = "/tmp" }
    let dir = stdr.join_path(home, ".cache/victrola")
    let qdir = stdr.shell_quote(dir)
    stdr.run_command("mkdir -p $$qdir$$")
    STATE_PATH = stdr.join_path(dir, "state.json")
    return STATE_PATH
}

: save_state() (( -- )) {
    state.save_state(ensure_state_path(), current_folder, tracks, album_cover_map, track_meta_map, artist_image_map, play_counts, play_count_artists, track_play_counts)
}

: load_state() (( -- )) {
    let loaded = state.load_state(ensure_state_path())
    album_cover_map = loaded["covers"] ?? []: [string => any]
    track_meta_map = loaded["track_meta"] ?? []: [string => any]
    artist_image_map = loaded["artist_images"] ?? []: [string => any]
    play_counts = loaded["play_counts"] ?? []: [string => any]
    play_count_artists = loaded["play_count_artists"] ?? []: [string]
    track_play_counts = loaded["track_play_counts"] ?? []: [string => any]
    let folder = stdr.str(loaded["folder"] ?? "")
    if stdr.len(folder) > 0 {
        current_folder = folder
    }
}

: is_library_songs_view() (( bool )) {
    if view_mode == 0 {
        return false
    }

    let mode = view_mode - 1
    return mode == 0 || (mode == 2 && album_detail_open) || (mode == 1 && artist_detail_open && album_detail_open)
}

: current_library_mode() (( num )) {
    if view_mode <= 0 {
        return 0
    }
    return view_mode - 1
}

: get_top_artists(limit = num) (( any )) {
    return mix.get_top_artists(play_counts, play_count_artists, tracks, limit)
}

: collect_mix_covers(artists = any, limit = num) (( any )) {
    return mix.collect_mix_covers(tracks, album_cover_map, artists, limit)
}

: refresh_mix_view() (( -- )) {
    let artist_limit = if is_compact_mode { 3 } else { 6 }
    let top_artists = get_top_artists(artist_limit)
    let covers = collect_mix_covers(top_artists, artist_limit)

    if !is_compact_mode {
        mix_panel.set_visible(view_mode == 0)
        library_center.set_visible(view_mode != 0)
        library_center.set_hexpand(view_mode != 0)
        player_tint_bin.set_visible(view_mode != 0)
        player_panel.set_visible(view_mode != 0)
    }

    mix_title.set_text("Your Mix")
    if len(top_artists) == 0 {
        mix_subtitle.set_text("Play a few songs to generate a queue from your favorites.")
        mix_empty.set_visible(true)
        mix_collage.set_visible(false)
        mix_play_btn.set_disabled(true)
        return
    }

    mix_empty.set_visible(false)
    mix_collage.set_visible(true)
    mix_play_btn.set_disabled(false)
    mix_subtitle.set_text(mix.top_artist_subtitle(top_artists, 3))

    let ?c1 = str(covers[0] ?? "")
    if len(c1) == 0 { c1 = "sf:music.note" }
    let ?c2 = str(covers[1] ?? "")
    if len(c2) == 0 { c2 = c1 }
    let ?c3 = str(covers[2] ?? "")
    if len(c3) == 0 { c3 = c2 }
    let ?c4 = str(covers[3] ?? "")
    if len(c4) == 0 { c4 = c3 }
    let ?c5 = str(covers[4] ?? "")
    if len(c5) == 0 { c5 = c4 }
    let ?c6 = str(covers[5] ?? "")
    if len(c6) == 0 { c6 = c5 }

    mix_art_1.set_source(c1)
    mix_art_2.set_source(c2)
    mix_art_3.set_source(c3)
    mix_art_4.set_source(c4)
    mix_art_5.set_source(c5)
    mix_art_6.set_source(c6)
}

: note_artist_play(track = any) (( -- )) {
    let result = mix.note_artist_play(track, play_counts, play_count_artists, track_play_counts)
    play_counts = result["play_counts"] ?? []: [string => any]
    play_count_artists = result["play_count_artists"] ?? []: [string]
    track_play_counts = result["track_play_counts"] ?? []: [string => any]
    save_state()
    refresh_mix_view()
}

: apply_mix_collage_compact(compact = bool) (( -- )) {
    if compact {
        -- 3-shape collage: circle, pill, circle
        mix_clip_1.set_size(150).set_preset(0).set_padding(0, 0, 0, 0)
        mix_clip_2.set_size(320).set_preset(6).set_padding(0, 0, 0, 0)
        mix_clip_3.set_size(115).set_preset(0).set_padding(0, 0, 0, 0)
        mix_clip_4.set_visible(false)
        mix_clip_5.set_visible(false)
        mix_clip_6.set_visible(false)
        mix_collage.set_pos(mix_clip_1, 0, 0)
        mix_collage.set_pos(mix_clip_2, 62, 91)
        mix_collage.set_pos(mix_clip_3, 0, 365)
        mix_collage.set_class("victrola-mix-collage-compact")

        mix_title.set_class("view-title-expressive")
        mix_play_btn.set_visible(false)
        mix_play_btn_compact.set_visible(true)
        mix_collage.set_pos(mix_play_btn_compact, 300, 383)
    } else {
        mix_clip_1.set_size(165).set_preset(0)
        mix_clip_2.set_size(150).set_preset(6)
        mix_clip_3.set_size(294).set_preset(6)
        mix_clip_4.set_visible(true).set_size(283).set_preset(6)
        mix_clip_5.set_visible(true).set_size(140).set_preset(0)
        mix_clip_6.set_visible(true).set_size(177).set_preset(0)
        mix_collage.set_pos(mix_clip_1, 0, 0)
        mix_collage.set_pos(mix_clip_2, 207, 0)
        mix_collage.set_pos(mix_clip_3, 361, 15)
        mix_collage.set_pos(mix_clip_4, 29, 154)
        mix_collage.set_pos(mix_clip_5, 319, 312)
        mix_collage.set_pos(mix_clip_6, 564, 272)
        mix_collage.set_class("victrola-mix-collage")

        mix_title.set_class("big-display-expressive")
        mix_play_btn.set_visible(true)
        mix_play_btn.set_xl()
        mix_play_btn_compact.set_visible(false)
    }
}

: open_compact_player() (( -- )) {
    if !is_compact_mode || compact_player_open {
        return
    }
    compact_player_open = true
    player_tint_bin.set_hexpand(true)
    player_panel.set_hexpand(true)
    player_panel.set_visible(true)
    player_panel.set_class("victrola-player-compact")
    player_tint_bin.set_visible(true)
    mini_player_card.set_visible(false)
    library_center.set_visible(false)
    library_center.set_hexpand(false)
    mix_panel.set_visible(false)
    player_back_btn.set_visible(true)
    bottom_nav.set_visible(false)
}

: close_compact_player() (( -- )) {
    if !is_compact_mode || !compact_player_open {
        return
    }
    compact_player_open = false
    player_tint_bin.set_hexpand(false)
    player_panel.set_hexpand(false)
    player_panel.set_visible(false)
    player_panel.set_class("victrola-player")
    player_tint_bin.set_visible(false)
    mini_player_card.set_visible(playing_track >= 0)
    player_back_btn.set_visible(false)
    bottom_nav.set_visible(true)

    let is_mix = view_mode == 0
    library_center.set_visible(!is_mix)
    library_center.set_hexpand(!is_mix)
    mix_panel.set_visible(is_mix)

    refresh_library_list()
    library_grid.set_cols(1)
}

: apply_compact_layout(compact = bool) (( -- )) {
    if queue_sheet_open {
        close_queue_sheet()
    }
    is_compact_mode = compact
    sidebar.set_visible(!compact)

    if compact {
        compact_player_open = false
        apply_mix_collage_compact(true)

        -- Set up compact Level 1 view
        player_tint_bin.set_hexpand(false)
        player_panel.set_hexpand(false)
        player_panel.set_visible(false)
        player_panel.set_class("victrola-player")
        player_tint_bin.set_visible(false)
        player_back_btn.set_visible(false)
        mini_player_card.set_visible(playing_track >= 0)
        bottom_nav.set_visible(true)

        let is_mix = view_mode == 0
        library_center.set_visible(!is_mix)
        library_center.set_hexpand(!is_mix)
        mix_panel.set_visible(is_mix)

        refresh_library_list()
        library_grid.set_cols(1)
    } else {
        compact_player_open = false
        player_back_btn.set_visible(false)
        player_tint_bin.set_hexpand(false)
        player_panel.set_hexpand(false)
        player_panel.set_visible(view_mode != 0)
        player_panel.set_class("victrola-player")
        player_tint_bin.set_visible(view_mode != 0)
        mini_player_card.set_visible(false)
        bottom_nav.set_visible(false)
        apply_mix_collage_compact(false)
        refresh_library_list()
    }
}

: clear_queue_context() (( -- )) {
    queue_active = false
    queue_source = 0
    mix_queue = []: [num]
    mix_queue_pos = -1
}

: find_mix_queue_index(track_idx = num) (( num )) {
    return queue.find_queue_index(mix_queue, track_idx)
}

: build_mix_queue(top_artists = any) (( any )) {
    return mix.build_mix_queue(tracks, top_artists, track_play_counts)
}

: refresh_queue_button() (( -- )) {
    if queue_sheet_open || queue_active {
        queue_toggle_btn.set_shape(1)
    } else {
        queue_toggle_btn.set_shape(0)
    }
}

: refresh_queue_sheet_open() (( -- )) {
    if !queue_sheet_open {
        return
    }
    let win = queue_toggle_btn.window()
    if is_null(win) {
        return
    }
    if is_compact_mode {
        win.set_dialog(build_queue_bottom_sheet())
    } else {
        win.set_side_sheet(build_queue_sheet())
    }
}

: sync_queue_playing_position() (( -- )) {
    mix_queue_pos = queue.sync_playing_position(mix_queue, playing_track, mix_queue_pos)
}

: queue_remove_at(queue_pos = num) (( -- )) {
    mix_queue = queue.queue_remove(mix_queue, queue_pos)

    if len(mix_queue) == 0 {
        clear_queue_context()
    } else {
        sync_queue_playing_position()
    }

    refresh_queue_sheet_open()
    refresh_queue_button()
}

: queue_move_up(queue_pos = num) (( -- )) {
    if queue_pos <= 0 || queue_pos >= len(mix_queue) {
        return
    }
    mix_queue = queue.queue_swap(mix_queue, queue_pos - 1, queue_pos)
    sync_queue_playing_position()
    refresh_queue_sheet_open()
    refresh_queue_button()
}

: queue_move_down(queue_pos = num) (( -- )) {
    if queue_pos < 0 || queue_pos >= len(mix_queue) - 1 {
        return
    }
    mix_queue = queue.queue_swap(mix_queue, queue_pos, queue_pos + 1)
    sync_queue_playing_position()
    refresh_queue_sheet_open()
    refresh_queue_button()
}

: build_queue_row(track_idx = num, queue_pos = num) (( any )) {
    let is_current = queue_pos == mix_queue_pos && (queue_active || track_idx == playing_track)
    return queue.build_queue_row(tracks, track_idx, queue_pos, is_current,
        (pos = num) => { queue_move_up(pos) },
        (pos = num) => { queue_move_down(pos) },
        (pos = num) => { queue_remove_at(pos) }
    )
}

: refresh_queue_sheet() (( -- )) {
    refresh_queue_button()
}

: play_mix_queue_at(queue_pos = num) (( -- )) {
    if queue_pos < 0 || queue_pos >= len(mix_queue) {
        return
    }

    let track_idx = mix_queue[queue_pos] ?? -1
    if track_idx < 0 {
        return
    }

    mix_queue_pos = queue_pos
    queue_active = len(mix_queue) > 0

    selected_track = track_idx
    refresh_queue_sheet_open()
    refresh_queue_button()
    play_track(track_idx)
    refresh_queue_sheet()
}

: build_queue_content() (( any )) {
    return queue.build_queue_content(tracks, mix_queue, mix_queue_pos, queue_active, playing_track,
        (pos = num) => { queue_move_up(pos) },
        (pos = num) => { queue_move_down(pos) },
        (pos = num) => { queue_remove_at(pos) },
        (pos = num) => { play_mix_queue_at(pos) }
    )
}

: build_queue_sheet() (( any )) {
    let sheet = cogito.side_sheet("Queue")
    .set_mode(2)
    sheet.add(build_queue_content())
    return sheet
}

: build_queue_bottom_sheet() (( any )) {
    let sheet = cogito.bottom_sheet("Queue")
    sheet.add(build_queue_content())
    return sheet
}

: open_queue_sheet() (( -- )) {
    let win = queue_toggle_btn.window()
    if is_null(win) {
        return
    }
    queue_sheet_open = true
    if is_compact_mode {
        win.set_dialog(build_queue_bottom_sheet())
    } else {
        win.set_side_sheet(build_queue_sheet())
    }
    refresh_queue_button()
}

: close_queue_sheet() (( -- )) {
    queue_sheet_open = false
    let win = queue_toggle_btn.window()
    if !is_null(win) {
        if is_compact_mode {
            win.clear_dialog()
        } else {
            win.clear_side_sheet()
        }
    }
    refresh_queue_button()
}

: start_mix_playback() (( -- )) {
    let top_artists = get_top_artists(5)
    let queue = build_mix_queue(top_artists)
    if len(queue) == 0 {
        return
    }

    -- In compact mode, switch to titles tab
    if is_compact_mode {
        close_compact_player()
        view_mode = 1
        bottom_nav.set_selected(1)
        library_rail.set_selected(1)
        library_center.set_visible(true)
        library_center.set_hexpand(true)
        mix_panel.set_visible(false)
    }

    mix_queue = queue
    queue_active = true
    queue_source = 1
    mix_queue_pos = 0

    if !is_compact_mode {
        view_mode = 1
        library_rail.set_selected(1)
    }

    refresh_library_list()
    play_mix_queue_at(0)
}

: build_queue_for_artist(artist = string) (( any )) {
    return queue.build_queue_for_artist(tracks, artist)
}

: build_queue_for_album(album = string) (( any )) {
    return queue.build_queue_for_album(tracks, album)
}

: set_queue_and_play(queue = any, track_idx = num, source = num) (( -- )) {
    if track_idx < 0 {
        return
    }

    mix_queue = queue
    queue_active = len(mix_queue) > 0
    queue_source = source
    mix_queue_pos = find_mix_queue_index(track_idx)
    if queue_active && mix_queue_pos < 0 {
        mix_queue_pos = 0
    }

    selected_track = track_idx
    refresh_queue_sheet_open()
    refresh_queue_button()

    if selected_track != playing_track || !is_playing {
        play_track(selected_track)
    } else {
        set_now_playing(selected_track)
    }
}

: add_titles_track_to_queue_and_play(track_idx = num) (( -- )) {
    if track_idx < 0 {
        return
    }

    if !queue_active || queue_source != 2 {
        mix_queue = []: [num]
        stdr.push(mix_queue, track_idx)
        queue_active = true
        queue_source = 2
    } else {
        let existing = find_mix_queue_index(track_idx)
        if existing < 0 {
            stdr.push(mix_queue, track_idx)
        }
    }

    mix_queue_pos = find_mix_queue_index(track_idx)
    selected_track = track_idx
    refresh_queue_sheet_open()
    refresh_queue_button()

    if selected_track != playing_track || !is_playing {
        play_track(selected_track)
    } else {
        set_now_playing(selected_track)
    }
}

: set_player_lyrics_visible(show_lyrics = bool) (( -- )) {
    lyrics_view_visible = show_lyrics
    if show_lyrics {
        player_bar_ref.set_title("Lyrics")
        now_revealer_ref.set_show_children(false)
        now_revealer_ref.set_vexpand(false)
        lyrics_revealer_ref.set_show_children(true)
        lyrics_revealer_ref.set_vexpand(true)
    } else {
        player_bar_ref.set_title("Now Playing")
        lyrics_revealer_ref.set_show_children(false)
        lyrics_revealer_ref.set_vexpand(false)
        now_revealer_ref.set_show_children(true)
        now_revealer_ref.set_vexpand(true)
    }
}

: sync_play_pause_button() (( -- )) {
    playback.sync_play_pause(is_playing, playing_track, play_pause_btn, lyrics_play_btn, mini_play_btn, seek_slider, lyrics_seek_slider)
}

: sync_repeat_button() (( -- )) {
    playback.sync_repeat(repeat_one, repeat_btn)
}

: next_shuffle_pick(limit = num) (( num )) {
    let result = playback.next_shuffle_pick(shuffle_seed, len(tracks), limit)
    shuffle_seed = stdr.num(result["seed"] ?? 0)
    return stdr.num(result["pick"] ?? -1)
}

: set_search_visible(visible = bool) (( -- )) {
    search_revealer.set_show_children(visible)
    search_input.set_visible(visible)
    search_input_visible = visible
}

: set_artist_detail_visible(visible = bool) (( -- )) {
    artist_detail_revealer.set_show_children(visible)
    artist_detail_open = visible
    if !visible {
        artist_detail_key = ""
        close_album_detail()
    }
}

: close_artist_detail() (( -- )) {
    set_artist_detail_visible(false)
}

: open_artist_detail(artist = string) (( -- )) {
    artist_detail_key = artist

    let cover = str(artist_image_map[artist] ?? "")
    if len(cover) > 0 && stdr.file_exists(cover) {
        artist_detail_art.set_source(cover)
    } else {
        artist_detail_art.set_source("sf:person")
    }

    artist_detail_name.set_text(artist)
    set_artist_detail_visible(true)
    refresh_library_list()
}

: set_album_detail_visible(visible = bool) (( -- )) {
    album_detail_revealer.set_show_children(visible)
    album_detail_open = visible
    if !visible {
        album_detail_key = ""
    }
}

: close_album_detail() (( -- )) {
    set_album_detail_visible(false)
}

: open_album_detail(album = string) (( -- )) {
    album_detail_key = album

    let artist = album_artist_for(album)

    let cover = album_cover_for(album, artist)
    if len(cover) > 0 {
        album_detail_art.set_source(cover)
    } else {
        album_detail_art.set_source("sf:square.stack")
    }

    album_detail_title.set_text(album)
    album_detail_artist.set_text(artist)
    set_album_detail_visible(true)
    refresh_library_list()
}

: set_now_playing(idx = num) (( -- )) {
    if idx < 0 || idx >= len(tracks) {
        now_title.set_text("No Title")
        now_artist.set_text("No Artist")
        mini_title_lbl.set_text("No Title")
        mini_artist_lbl.set_text("No Artist")
        mini_cover.set_source("sf:music.note")
        if is_compact_mode && !compact_player_open {
            mini_player_card.set_visible(false)
        }
        apply_cover_art("")
        set_lyrics_placeholder("Lyrics will appear here when available.")
        show_lyrics_btn(false)
        return
    }

    let t = tracks[idx] ?? []: [string => any]
    let title = str(t["title"] ?? "")
    let artist = str(t["artist"] ?? "")
    now_title.set_text(title)
    now_artist.set_text(artist)
    mini_title_lbl.set_text(title)
    mini_artist_lbl.set_text(artist)
    if is_compact_mode && !compact_player_open {
        mini_player_card.set_visible(true)
    }
}

: clear_now_playing_tint() (( -- )) {
    current_tint_source = ""
    player_tint_bin.set_accent_color(null)
    app_ref.set_accent_color(APP_ACCENT, true)
}

: apply_now_playing_tint(path = string) (( -- )) {
    let clean = util.sanitize_cover_path(path)
    if len(clean) == 0 {
        clear_now_playing_tint()
        return
    }

    if clean == current_tint_source {
        return
    }

    let accent = app_ref.set_accent_from_image(clean, false)

    -- Ensure source-color extraction does not permanently retint the whole app.
    app_ref.set_accent_color(APP_ACCENT, true)

    if len(accent) > 0 {
        current_tint_source = clean
        player_tint_bin.set_accent_color(accent)
    } else {
        current_tint_source = ""
        player_tint_bin.set_accent_color(null)
    }
}

: apply_cover_art(path = string) (( -- )) {
    let clean = util.sanitize_cover_path(path)

    if clean == current_cover_path {
        return
    }

    if len(clean) > 0 && !stdr.file_exists(clean) {
        return
    }

    if len(clean) > 0 && cover_locked_for_track {
        return
    }

    if len(clean) > 0 {
        current_cover_path = clean
        cover_locked_for_track = true
        cover_art.set_source(clean)
        mini_cover.set_source(clean)
        if playing_track >= 0 && playing_track < len(tracks) {
            let t = tracks[playing_track] ?? []: [string => any]
            let album = str(t["album"] ?? "Unknown Album")
            let artist = str(t["artist"] ?? "Unknown Artist")
            let key = model.album_cover_key(album, artist)
            if len(album) > 0 && len(str(album_cover_map[key] ?? "")) == 0 {
                album_cover_map[key] = clean
                save_state()
            }
            if album_detail_open && album == album_detail_key {
                album_detail_art.set_source(clean)
            }
        }
        apply_now_playing_tint(clean)
    } else {
        current_cover_path = ""
        cover_locked_for_track = false
        cover_art.set_source("sf:music.note")
        mini_cover.set_source("sf:music.note")
        clear_now_playing_tint()
    }
}

: refresh_library_list() (( -- )) {
    let mode = current_library_mode()

    refresh_mix_view()

    set_album_detail_visible((view_mode != 0 && (mode == 2 || (mode == 1 && artist_detail_open))) && album_detail_open)
    artist_detail_revealer.set_show_children(view_mode != 0 && mode == 1 && artist_detail_open && !album_detail_open)

    let show_back = artist_detail_open || album_detail_open
    back_btn.set_visible(show_back)

    let result = library.refresh_library_list(
        library_list,
        library_grid,
        groups_revealer,
        titles_revealer,
        tracks,
        mode,
        query_text,
        playing_track,
        album_detail_open,
        album_detail_key,
        artist_detail_open,
        artist_detail_key,
        album_artist_map,
        album_cover_map,
        artist_image_map,
        (artist = string) => {
            open_artist_detail(artist)
        },
        (album = string) => {
            open_album_detail(album)
        }
    )

    visible_track_indexes = result["track_indexes"] ?? []: [num]
    visible_group_keys = result["group_keys"] ?? []: [string]

    let songs_view = is_library_songs_view()
    if songs_view && len(visible_track_indexes) == 0 {
        selected_track = -1
        set_now_playing(-1)
    }

    if is_compact_mode {
        library_grid.set_cols(1)
    }
}

: collect_artist_names() (( any )) {
    let ?names = []: [string]
    let ?seen = []: [string => any]
    for (let ?i = 0; i < len(tracks); i = i + 1) {
        let t = tracks[i] ?? []: [string => any]
        let artist = str(t["artist"] ?? "")
        if len(artist) > 0 && artist != "Unknown Artist" && stdr.is_null(seen[artist]) {
            seen[artist] = true
            names[len(names)] = artist
        }
    }
    return names
}

: fetch_artist_images() (( -- )) {
    let names = collect_artist_names()
    artist_image_map = artist_images.fetch_missing(names, artist_image_map)
    save_state()
    refresh_library_list()
}

: scan_folder(folder = string) (( -- )) {
    let chosen = stdr.trim(folder)
    if len(chosen) == 0 {
        return
    }

    let folder_changed = chosen != current_folder
    if folder_changed {
        album_cover_map = []: [string => any]
        lyrics_cache = []: [string => any]
    }

    current_folder = chosen
    save_state()

    let lines = scanner.scan_folder(current_folder, AUDIO_EXTS)
    tracks = []: [any]
    for (let ?i = 0; i < len(lines); i = i + 1) {
        let p = lines[i] ?? ""
        if len(p) > 0 {
            tracks[len(tracks)] = model.make_track(p)
        }
    }

    model.apply_saved_meta(tracks, track_meta_map)

    let rebuilt = model.rebuild_album_indexes(tracks, album_cover_map)
    album_cover_map = rebuilt["covers"] ?? []: [string => any]
    album_artist_map = rebuilt["artists"] ?? []: [string => any]
    save_state()

    playing_track = -1
    selected_track = -1
    is_playing = false
    sync_play_pause_button()
    close_album_detail()
    apply_cover_art("")
    seek_slider.set_value(0)
    lyrics_seek_slider.set_value(0)
    time_left.set_text("00:00")
    time_right.set_text("00:00")
    lyrics_time_left.set_text("00:00")

    refresh_library_list()
    let n = len(tracks)

    fetch_artist_images()
}

: choose_and_scan() (( -- )) {
    let folder = scanner.pick_folder_macos()
    if len(folder) == 0 {
        return
    }
    scan_folder(folder)
}

: find_visible_index(track_idx = num) (( num )) {
    for (let ?i = 0; i < len(visible_track_indexes); i = i + 1) {
        if visible_track_indexes[i] == track_idx {
            return i
        }
    }
    return -1
}

: play_track(track_idx = num) (( -- )) {
    if track_idx < 0 || track_idx >= len(tracks) {
        return
    }

    let t = tracks[track_idx] ?? []: [string => any]
    let path = str(t["path"] ?? "")
    if len(path) == 0 {
        return
    }

    stop_poll_loop()
    gst.stop()
    apply_cover_art("")

    if !gst.load(path) {
        is_playing = false
        sync_play_pause_button()
        let err = gst.last_error()
        if len(err) > 0 {
        } else {
        }
        stop_poll_loop()
        return
    }
    if !gst.play() {
        is_playing = false
        sync_play_pause_button()
        let err = gst.last_error()
        if len(err) > 0 {
        } else {
        }
        stop_poll_loop()
        return
    }

    playing_track = track_idx
    selected_track = track_idx
    is_playing = true
    note_artist_play(t)
    sync_play_pause_button()
    seek_slider.set_value(0)
    lyrics_seek_slider.set_value(0)
    set_now_playing(track_idx)
    refresh_library_list()

    let known_cover = album_cover_for(str(t["album"] ?? "Unknown Album"), str(t["artist"] ?? "Unknown Artist"))
    if len(known_cover) > 0 {
        apply_cover_art(known_cover)
    }

    check_lyrics_for_track(track_idx)
    if lyrics_view_visible {
        fetch_lyrics_for_track(track_idx)
    }

    start_poll_loop()
    poll_playback()
}

: play_selected() (( -- )) {
    if selected_track >= 0 {
        if !is_playing && selected_track == playing_track {
            if gst.play() {
                is_playing = true
                sync_play_pause_button()
                start_poll_loop()
                return
            }
        }
        clear_queue_context()
        refresh_queue_sheet()
        play_track(selected_track)
    }
}

: play_next() (( -- )) {
    if queue_active && len(mix_queue) > 0 {
        let ?next_pos = mix_queue_pos
        if next_pos < 0 {
            next_pos = find_mix_queue_index(playing_track)
        }
        if next_pos < 0 {
            next_pos = 0
        } else {
            next_pos = next_pos + 1
        }
        if next_pos >= len(mix_queue) {
            next_pos = 0
        }
        play_mix_queue_at(next_pos)
        return
    }

    if len(visible_track_indexes) == 0 {
        return
    }

    if playing_track < 0 {
        play_track(visible_track_indexes[0] ?? -1)
        return
    }

    let pos = find_visible_index(playing_track)
    if pos < 0 {
        play_track(visible_track_indexes[0] ?? -1)
        return
    }

    let ?next_pos = pos + 1
    if next_pos >= len(visible_track_indexes) {
        next_pos = 0
    }
    play_track(visible_track_indexes[next_pos] ?? -1)
}

: play_prev() (( -- )) {
    if queue_active && len(mix_queue) > 0 {
        let ?prev_pos = mix_queue_pos
        if prev_pos < 0 {
            prev_pos = find_mix_queue_index(playing_track)
        }
        if prev_pos < 0 {
            prev_pos = 0
        } else {
            prev_pos = prev_pos - 1
        }
        if prev_pos < 0 {
            prev_pos = len(mix_queue) - 1
        }
        play_mix_queue_at(prev_pos)
        return
    }

    if len(visible_track_indexes) == 0 {
        return
    }

    if playing_track < 0 {
        play_track(visible_track_indexes[0] ?? -1)
        return
    }

    let pos = find_visible_index(playing_track)
    if pos < 0 {
        play_track(visible_track_indexes[0] ?? -1)
        return
    }

    let ?prev_pos = pos - 1
    if prev_pos < 0 {
        prev_pos = len(visible_track_indexes) - 1
    }
    play_track(visible_track_indexes[prev_pos] ?? -1)
}

: play_shuffled_track() (( -- )) {
    let ?candidates = []: [num]

    for (let ?i = 0; i < len(tracks); i = i + 1) {
        let t = tracks[i] ?? []: [string => any]
        if library.track_matches_query(t, query_text) {
            candidates[len(candidates)] = i
        }
    }

    let total = len(candidates)
    if total == 0 {
        return
    }

    let ?pick = next_shuffle_pick(total)
    if pick < 0 {
        return
    }

    if total > 1 && (candidates[pick] ?? -1) == playing_track {
        pick = (pick + 1 + (shuffle_seed % (total - 1))) % total
    }

    let idx = candidates[pick] ?? -1
    if idx < 0 {
        return
    }

    clear_queue_context()
    selected_track = idx
    refresh_queue_sheet()
    play_track(idx)
}

: pause_playback() (( -- )) {
    if gst.pause() {
        is_playing = false
        sync_play_pause_button()
        stop_poll_loop()
    } else {
    }
}

: stop_playback() (( -- )) {
    if gst.stop() {
        is_playing = false
        playing_track = -1
        sync_play_pause_button()
        stop_poll_loop()
        apply_cover_art("")
        playback.reset_playback_ui(seek_slider, lyrics_seek_slider, time_left, time_right, lyrics_time_left)
        refresh_library_list()
        refresh_queue_sheet()
    } else {
    }
}

: set_lyrics_placeholder(text = string) (( -- )) {
    lyrics.set_placeholder(lyrics_grid, text)
    lyrics_line_labels = []: [any]
    lyrics_timestamps = []: [num]
    lyrics_current_line = -1
    lyrics_synced = false
}

: populate_lyrics(text = string) (( -- )) {
    let result = lyrics.populate_lyrics_grid(lyrics_grid, lyrics_scroll, text)
    lyrics_line_labels = result["line_labels"] ?? []: [any]
    lyrics_timestamps = result["timestamps"] ?? []: [num]
    lyrics_synced = result["synced"] ?? false
    lyrics_current_line = -1
}

: update_lyrics_position(elapsed_ms = num) (( -- )) {
    if !lyrics_synced { return }
    lyrics_current_line = lyrics.update_lyrics_scroll(lyrics_timestamps, lyrics_line_labels, lyrics_scroll, elapsed_ms, lyrics_current_line)
}

: lyrics_cache_key(track_idx = num) (( string )) {
    return lyrics.cache_key(tracks, track_idx)
}

: check_lyrics_for_track(track_idx = num) (( -- )) {
    let result = lyrics.check_lyrics_cached(tracks, track_idx, lyrics_cache)
    lyrics_cache = result["lyrics_cache"] ?? lyrics_cache
    show_lyrics_btn(result["has_lyrics"] ?? false)
}

: fetch_lyrics_for_track(track_idx = num) (( -- )) {
    let result = lyrics.fetch_and_cache(tracks, track_idx, lyrics_cache)
    lyrics_cache = result["lyrics_cache"] ?? lyrics_cache
    let has = result["has_lyrics"] ?? false
    show_lyrics_btn(has)
    populate_lyrics(str(result["text"] ?? ""))
}

: apply_tag_metadata() (( -- )) {
    let result = playback.apply_tag_update(playing_track, tracks, track_meta_map)
    if result["changed"] ?? false {
        tracks = result["tracks"] ?? tracks
        track_meta_map = result["track_meta_map"] ?? track_meta_map
        let path = str(result["path"] ?? "")
        if len(path) > 0 {
            save_state()
        }
        set_now_playing(playing_track)
        refresh_library_list()
    }
}

: poll_playback() (( -- )) {
    let ev = gst.poll()
    if ev == gst.EVENT_EOS {
        if repeat_one && playing_track >= 0 {
            play_track(playing_track)
        } else {
            play_next()
        }
    } elif ev == gst.EVENT_ERROR {
        is_playing = false
        sync_play_pause_button()
        let err = gst.last_error()
        if len(err) > 0 {
        } else {
        }
        stop_poll_loop()
        apply_cover_art("")
    } elif ev == gst.EVENT_TAG {
        apply_cover_art(gst.last_cover_path())
        apply_tag_metadata()
    }

    let pos = gst.position_ms()
    let dur = gst.duration_ms()

    let seek_result = playback.update_seek_ui(pos, dur, seek_slider, lyrics_seek_slider, time_left, time_right, lyrics_time_left)
    let scaled = stdr.num(seek_result["scaled"] ?? -1)
    if scaled >= 0 {
        suspend_seek_callback = true
        seek_slider.set_value(scaled)
        lyrics_seek_slider.set_value(scaled)
        suspend_seek_callback = false

        let elapsed = stdr.num(seek_result["elapsed"] ?? 0)
        if lyrics_synced && lyrics_view_visible {
            update_lyrics_position(elapsed)
        }
    }
}

: poll_tick() (( -- )) {
    poll_playback()
}

: start_poll_loop() (( -- )) {
    if poll_timer_id > 0 {
        cogito.clear_timer(poll_timer_id)
        poll_timer_id = 0
    }
    poll_timer_id = cogito.set_interval_for(poll_anchor, 250, () => {
        poll_tick()
    })
    poll_tick()
}

: stop_poll_loop() (( -- )) {
    if poll_timer_id > 0 {
        cogito.clear_timer(poll_timer_id)
        poll_timer_id = 0
    }
}

: configure_widgets() (( -- )) {
    album_detail_art.set_size(128, 128).set_radius(26).set_hexpand(false).set_class("surface-container")
    album_detail_artist.set_class("caption").set_hexpand(true).set_text_align(0).set_max_width_chars(40)
    album_detail_revealer.set_show_children(false).set_hexpand(true).set_padding(0, 0, 0, 0)
    album_detail_title.set_class("view-title-expressive").set_hexpand(true).set_text_align(0).set_max_width_chars(40)
    artist_detail_art.set_size(128, 128).set_hexpand(false)
    artist_detail_clip.set_size(128).set_clip(true).add(artist_detail_art)
    artist_detail_name.set_class("view-title-expressive").set_hexpand(true).set_text_align(0).set_max_width_chars(40)
    artist_detail_revealer.set_show_children(false).set_hexpand(true).set_padding(0, 0, 0, 0)
    cover_art.set_radius(26).set_blur(6).set_class("surface-container victrola-cover-art")
    groups_revealer.set_show_children(false).set_hexpand(true).set_vexpand(true).set_padding(0, 0, 0, 0)
