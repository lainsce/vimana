    mini_cover.set_size(96, 96).set_radius(12)
    mini_title_lbl.set_class("emphasized").set_text_align(0).set_max_width_chars(30).set_hexpand(true)
    mini_artist_lbl.set_class("caption").set_text_align(0).set_max_width_chars(40).set_hexpand(true)
    mini_play_btn.set_class("tonal").set_align(4).on_click((b = cogito.IconButton) => {
        if is_playing {
            pause_playback()
        } else {
            play_selected()
        }
    })
}

: build_sidebar(root = cogito.HStack) (( -- )) {
    let rail_bar = cogito.appbar("", "")
    .set_small()
    .set_hexpand(false)
    .set_class("victrola-rail-controls")

    sidebar
    .set_vexpand(true)
    .set_class("victrola-sidebar")
    .add(rail_bar)

    library_rail
    .set_vexpand(true)
    .set_class("victrola-navrail")
    .set_centered(true)
    .add(cogito.fab("sf:shuffle")
        .set_color(3)
        .on_click((f = cogito.FAB) => {
            if ui_ready && !is_null(f) {
                play_shuffled_track()
            }
        })
    )
    sidebar.add(library_rail)
    root.add(sidebar)
}

: build_library_center(root = cogito.HStack) (( -- )) {
    library_center.set_hexpand(true).set_vexpand(true)
    let center = library_center

    let library_bar = cogito.appbar("Your Mix", "")
    library_bar_ref = library_bar
    library_bar
    .set_hexpand(true)
    .set_class("small victrola-library-bar")
    .add_trailing_button("sf:folder.badge.gearshape", (b = any) => {
        if ui_ready && !is_null(b) {
            choose_and_scan()
        }
    })
    .add_trailing_button("sf:magnifyingglass", (b = any) => {
        if ui_ready && !is_null(b) {
            set_search_visible(!search_input_visible)
            search_input.set_text("")
            query_text = ""
            refresh_library_list()
        }
    })

    back_btn = library_bar.leading_button("sf:chevron.left", (b = any) => {
        if ui_ready && !is_null(b) {
            if album_detail_open {
                close_album_detail()
            } elif artist_detail_open {
                close_artist_detail()
            }
            refresh_library_list()
        }
    })
    back_btn.set_visible(false)

    center.add(library_bar)
    search_revealer.add(search_input)
    center.add(search_revealer)

    let artist_header = cogito.hstack()
    .set_gap(12)
    .set_hexpand(true)
    .set_padding(0, 16, 12, 16)
    .set_class("victrola-album-header")
    .add(artist_detail_clip)

    let artist_meta = cogito.vstack()
    .set_gap(4)
    .set_hexpand(true)
    .set_align(3)
    .add(artist_detail_name)

    artist_header.add(artist_meta)
    artist_detail_revealer.add(artist_header)
    center.add(artist_detail_revealer)

    let album_header = cogito.hstack()
    .set_gap(12)
    .set_hexpand(true)
    .set_padding(0, 16, 12, 16)
    .set_class("victrola-album-header")
    .add(album_detail_art)

    let album_meta = cogito.vstack()
    .set_gap(12)
    .set_hexpand(true)
    .set_align(3)
    .add(album_detail_title)
    .add(album_detail_artist)

    album_header.add(album_meta)
    album_detail_revealer.add(album_header)
    center.add(album_detail_revealer)

    library_bar.pair_with_scroller(library_scroll)

    let library_stack = cogito.vstack()
    .set_hexpand(true)
    .set_vexpand(true)
    .set_padding(0, 16, 12, 16)

    titles_revealer.add(library_list
        .set_hexpand(true)
        .set_vexpand(true)
    )
    groups_revealer.add(library_grid
        .set_gap(8, 8)
        .set_hexpand(true)
        .set_class("victrola-group-grid")
        .set_cols(2)
    )

    library_stack.add(titles_revealer)
    library_stack.add(groups_revealer)
    library_scroll.add(library_stack)
    center.add(library_scroll)
    root.add(center)
}

: build_mix_panel(root = cogito.HStack) (( -- )) {
    mix_panel
    .add(
        cogito.hstack()
        .set_hexpand(true)
        .set_padding(0, 16, 0, 16)
        .add(
            cogito.vstack()
            .set_gap(6)
