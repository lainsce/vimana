cask scanner

bring stdr

:: pick_folder(prompt = string) (( string ))
    let picked = stdr.open_folder_dialog(prompt)
    if stdr.is_null(picked)
        <- ""
    let out = stdr.trim(stdr.str(picked))
    if stdr.len(out) > 0
        <- out
    <- ""
;

:: scan_folder(folder = string, audio_exts = any) (( any ))
    let chosen = stdr.trim(folder)
    if stdr.len(chosen) == 0
        <- []: [string]
    <- stdr.find_files(chosen, audio_exts)
;
