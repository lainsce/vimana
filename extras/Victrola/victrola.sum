@diagnostics: warn

appbar.victrola-rail-controls
  min-width: 96
  max-width: 96
  min-height: 28
  max-height: 28
  background: transparent

vstack.victrola-sidebar
  background: transparent

appbar.victrola-library-bar
  background: transparent

appbar.victrola-player-bar
  background: transparent
  border-width: 0

grid.victrola-group-grid
  background: transparent

card.victrola-artist-card
  min-height: 256
  min-width: 256
  border-radius: 12

card.victrola-album-card
  min-height: 256
  min-width: 256
  border-radius: 12

image.victrola-album-art
  min-width: 320
  min-height: 320
  max-width: 320
  max-height: 320
  border-radius: 26

image.victrola-cover-art
  min-width: 320
  min-height: 320
  max-width: 320
  max-height: 320
  border-radius: 26

label.victrola-album-title-expressive
  text-overflow: fade
  font-variation: wdth 132, opsz 14
  font-weight: 600
  font-size: 18

label.view-title-expressive
  text-overflow: fade
  font-variation: wdth 132, opsz 14
  font-weight: 600
  font-size: 32
  max-width: 360

label.victrola-now-title
  text-overflow: marquee
  font-variation: wdth 132, opsz 14
  font-weight: 600
  font-size: 32
  max-width: 320

label.victrola-album-meta
  font-size: 14

hstack.victrola-album-header
  background: transparent

vstack.victrola-player
  background: transparent
  min-width: 360
  max-width: 360

hstack.victrola-seek-row
hstack.victrola-duration
hstack.victrola-main-controls
hstack.victrola-secondary-controls
  min-width: 320
  max-width: 320
  background: transparent

slider.victrola-seek
  min-width: 320
  max-width: 320

hstack.victrola-song-row
vstack.victrola-song-row
  background: transparent

textview.victrola-lyrics
  background: transparent
  border-radius: 18
  padding: 12

vstack.victrola-lyrics-page
  background: transparent

scroller.victrola-lyrics-scroll
  background: transparent
  padding: 0