;

def EMPTY  = [0, 0, 0, 0, 0, 0, 0, 0]

:: draw_filled_rect(scr = vimana.screen, x = num, y = num, w = num, h = num, c = num) (( -- ))
    for (let ?cy = 0; cy < h; cy += 8)
        for (let ?cx = 0; cx < w; cx += 8)
            scr.put_icn(x + cx, y + cy, EMPTY, c, c)
;

