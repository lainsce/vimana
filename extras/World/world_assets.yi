def SWATCH_TL = [0, 0x7F, 0x7F, 0x60, 0x60, 0x60, 0x63, 0x63]
def SWATCH_TR = [0, 0xC0, 0xC0, 0xC0, 0xC0, 0xC0, 0xFE, 0xFE]
def SWATCH_BL = [0x7F, 0x7F, 0x03, 0x03, 0x03, 0x03, 0x03, 0]
def SWATCH_BR = [0xC6, 0xC6, 0x06, 0x06, 0x06, 0x06, 0xFE, 0]

:: draw_swatch(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
