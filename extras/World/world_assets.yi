cask world_assets

bring vimana

-- 2x2 icon helper (16x16 from four 8x8 tiles)
:: draw_icn(scr = vimana.screen, x = num, y = num, tl = any, tr = any, bl = any, br = any, fg = num, bg = num) (( -- ))
    scr.put_icn(x,     y,     tl, fg, bg)
    scr.put_icn(x + 1, y,     tr, fg, bg)
    scr.put_icn(x,     y + 1, bl, fg, bg)
    scr.put_icn(x + 1, y + 1, br, fg, bg)
;

-- Undo arrow (left-pointing arrow)
def UNDO_TL = [0, 0, 1, 3, 7, 15, 31, 63]
def UNDO_TR = [0, 0, 0, 0, 0, 254, 254, 254]
def UNDO_BL = [31, 15, 7, 3, 1, 0, 0, 0]
def UNDO_BR = [254, 254, 0, 0, 0, 0, 0, 0]

:: draw_undo(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, UNDO_TL, UNDO_TR, UNDO_BL, UNDO_BR, fg, bg)
;

-- Redo arrow (right-pointing arrow)
def REDO_TL = [0, 0, 0, 0, 0, 127, 127, 127]
def REDO_TR = [0, 0, 128, 192, 224, 240, 248, 252]
def REDO_BL = [127, 127, 0, 0, 0, 0, 0, 0]
def REDO_BR = [248, 240, 224, 192, 128, 0, 0, 0]

:: draw_redo(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, REDO_TL, REDO_TR, REDO_BL, REDO_BR, fg, bg)
;

-- Grid icon (3x3 grid)
def GRID_TL = [255, 132, 132, 132, 132, 255, 132, 132]
def GRID_TR = [255, 33, 33, 33, 33, 255, 33, 33]
def GRID_BL = [132, 132, 255, 132, 132, 132, 132, 255]
def GRID_BR = [33, 33, 255, 33, 33, 33, 33, 255]

:: draw_grid(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, GRID_TL, GRID_TR, GRID_BL, GRID_BR, fg, bg)
;

-- Text mode icon (seriffed "T")
def TEXT_TL = [0, 127, 127, 1, 1, 1, 1, 1]
def TEXT_TR = [0, 254, 254, 128, 128, 128, 128, 128]
def TEXT_BL = [1, 1, 1, 1, 1, 3, 7, 0]
def TEXT_BR = [128, 128, 128, 128, 128, 192, 224, 0]

:: draw_text(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, TEXT_TL, TEXT_TR, TEXT_BL, TEXT_BR, fg, bg)
;

-- Ding mode icon (starburst)
def DING_TL = [0, 1, 33, 17, 9, 5, 3, 127]
def DING_TR = [0, 128, 132, 136, 144, 160, 192, 254]
def DING_BL = [127, 3, 5, 9, 17, 33, 1, 0]
def DING_BR = [254, 192, 160, 144, 136, 132, 128, 0]

:: draw_ding(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, DING_TL, DING_TR, DING_BL, DING_BR, fg, bg)
;

-- Clear icon (X)
def CLR_TL = [0, 96, 48, 24, 12, 6, 3, 1]
def CLR_TR = [0, 6, 12, 24, 48, 96, 192, 128]
def CLR_BL = [1, 3, 6, 12, 24, 48, 96, 0]
