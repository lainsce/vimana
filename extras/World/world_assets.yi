def GRID_BR = [0x21, 0x21, 0xFF, 0x21, 0x21, 0x21, 0x21, 0xFF]

:: draw_grid(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, GRID_TL, GRID_TR, GRID_BL, GRID_BR, fg, bg)
;

-- Text mode icon (seriffed "T")
def TEXT_TL = [0, 0x7F, 0x7F, 0x01, 0x01, 0x01, 0x01, 0x01]
def TEXT_TR = [0, 0xFE, 0xFE, 0x80, 0x80, 0x80, 0x80, 0x80]
