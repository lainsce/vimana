cask world_assets

bring vimana

-- 2x2 icon helper (16x16 from four 8x8 tiles)
:: draw_icn(scr = vimana.screen, x = num, y = num, tl = any, tr = any, bl = any, br = any, fg = num, bg = num) (( -- ))
    scr.put_icn(x,     y,     tl, fg, bg)
    scr.put_icn(x + 8, y,     tr, fg, bg)
    scr.put_icn(x,     y + 8, bl, fg, bg)
    scr.put_icn(x + 8, y + 8, br, fg, bg)
;

-- Undo arrow (left-pointing arrow)
def UNDO_TL = [0, 0, 0x01, 0x03, 0x07, 0x0F, 0x1F, 0x3F]
def UNDO_TR = [0, 0, 0, 0, 0, 0xFE, 0xFE, 0xFE]
def UNDO_BL = [0x1F, 0x0F, 0x07, 0x03, 0x01, 0, 0, 0]
def UNDO_BR = [0xFE, 0xFE, 0, 0, 0, 0, 0, 0]

:: draw_undo(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, UNDO_TL, UNDO_TR, UNDO_BL, UNDO_BR, fg, bg)
;

-- Redo arrow (right-pointing arrow)
def REDO_TL = [0, 0, 0, 0, 0, 0x7F, 0x7F, 0x7F]
def REDO_TR = [0, 0, 0x80, 0xC0, 0xE0, 0xF0, 0xF8, 0xFC]
def REDO_BL = [0x7F, 0x7F, 0, 0, 0, 0, 0, 0]
def REDO_BR = [0xF8, 0xF0, 0xE0, 0xC0, 0x80, 0, 0, 0]

:: draw_redo(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, REDO_TL, REDO_TR, REDO_BL, REDO_BR, fg, bg)
;

