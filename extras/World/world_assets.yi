-- Palette icon (4 color dots)
def PAL_TL = [0, 0, 60, 126, 126, 126, 60, 0]
def PAL_TR = [0, 0, 60, 126, 126, 126, 60, 0]
def PAL_BL = [0, 60, 126, 126, 126, 60, 0, 0]
def PAL_BR = [0, 60, 126, 126, 126, 60, 0, 0]

:: draw_palette(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
