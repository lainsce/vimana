-- Color swatch (two overlapping outlined squares)
def SWATCH_TL = [0, 127, 127, 96, 96, 96, 99, 99]
def SWATCH_TR = [0, 192, 192, 192, 192, 192, 254, 254]
def SWATCH_BL = [127, 127, 3, 3, 3, 3, 3, 0]
def SWATCH_BR = [198, 198, 6, 6, 6, 6, 254, 0]

:: draw_swatch(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, SWATCH_TL, SWATCH_TR, SWATCH_BL, SWATCH_BR, fg, bg)
;

def EMPTY  = [0, 0, 0, 0, 0, 0, 0, 0]

:: draw_filled_rect(scr = vimana.screen, x = num, y = num, w = num, h = num, c = num) (( -- ))
    let ?cy = 0
    for (; cy < h; cy += 1)
        let ?cx = 0
        for (; cx < w; cx += 1)
            scr.put_icn(x + cx, y + cy, EMPTY, c, c)
;

-- ─────────────────────────────────────────────────────────────────────────────
-- Font setup: load the Chicago bitmap font (8×16 glyphs, variable width)
-- Call once after creating the screen.
-- ─────────────────────────────────────────────────────────────────────────────

:: setup_font(scr = vimana.screen) (( -- ))
