-- Preset icon (rubber stamp)
def PRST_TL = [0, 7, 7, 7, 7, 15, 31, 63]
def PRST_TR = [0, 224, 224, 224, 224, 240, 248, 252]
def PRST_BL = [127, 127, 0, 0, 102, 102, 0, 0]
def PRST_BR = [254, 254, 0, 0, 102, 102, 0, 0]

:: draw_preset(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, PRST_TL, PRST_TR, PRST_BL, PRST_BR, fg, bg)
;

-- Brush size indicators (single 8x8 tiles for 1-5)
def BRUSH_1 = [0, 0, 0, 24, 24, 0, 0, 0]
def BRUSH_2 = [0, 0, 24, 60, 60, 24, 0, 0]
def BRUSH_3 = [0, 24, 60, 126, 126, 60, 24, 0]
def BRUSH_4 = [24, 60, 126, 255, 255, 126, 60, 24]
def BRUSH_5 = [60, 126, 255, 255, 255, 255, 126, 60]

:: draw_brush(scr = vimana.screen, x = num, y = num, size = num, fg = num, bg = num) (( -- ))
    if size == 1
        scr.put_icn(x, y, BRUSH_1, fg, bg)
    elif size == 2
        scr.put_icn(x, y, BRUSH_2, fg, bg)
    elif size == 3
        scr.put_icn(x, y, BRUSH_3, fg, bg)
    elif size == 4
        scr.put_icn(x, y, BRUSH_4, fg, bg)
    else
        scr.put_icn(x, y, BRUSH_5, fg, bg)
;

-- Home icon (house outline, 2px stroke)
def HOME_TL = [3, 6, 12, 24, 48, 96, 255, 255]
def HOME_TR = [192, 96, 48, 24, 12, 6, 255, 255]
def HOME_BL = [192, 192, 195, 195, 195, 255, 255, 0]
def HOME_BR = [3, 3, 195, 195, 195, 255, 255, 0]

:: draw_home(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, HOME_TL, HOME_TR, HOME_BL, HOME_BR, fg, bg)
;

-- Back arrow (left arrow)
def BACK_TL = [0, 0, 24, 60, 126, 255, 24, 24]
def BACK_TR = [0, 0, 0, 0, 0, 0, 0, 0]
def BACK_BL = [24, 24, 24, 24, 0, 0, 0, 0]
def BACK_BR = [0, 0, 0, 0, 0, 0, 0, 0]

:: draw_back(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, BACK_TL, BACK_TR, BACK_BL, BACK_BR, fg, bg)
