-- Preset icon (rubber stamp)
def PRST_TL = [0, 0x07, 0x07, 0x07, 0x07, 0x0F, 0x1F, 0x3F]
def PRST_TR = [0, 0xE0, 0xE0, 0xE0, 0xE0, 0xF0, 0xF8, 0xFC]
def PRST_BL = [0x7F, 0x7F, 0, 0, 0x66, 0x66, 0, 0]
def PRST_BR = [0xFE, 0xFE, 0, 0, 0x66, 0x66, 0, 0]

:: draw_preset(scr = vimana.screen, x = num, y = num, fg = num, bg = num) (( -- ))
    draw_icn(scr, x, y, PRST_TL, PRST_TR, PRST_BL, PRST_BR, fg, bg)
;

-- Brush size indicators (single 8x8 tiles for 1-5)
def BRUSH_1 = [0, 0, 0, 0x18, 0x18, 0, 0, 0]
def BRUSH_2 = [0, 0, 0x18, 0x3C, 0x3C, 0x18, 0, 0]
def BRUSH_3 = [0, 0x18, 0x3C, 0x7E, 0x7E, 0x3C, 0x18, 0]
def BRUSH_4 = [0x18, 0x3C, 0x7E, 0xFF, 0xFF, 0x7E, 0x3C, 0x18]
def BRUSH_5 = [0x3C, 0x7E, 0xFF, 0xFF, 0xFF, 0xFF, 0x7E, 0x3C]

:: draw_brush(scr = vimana.screen, x = num, y = num, size = num, fg = num, bg = num) (( -- ))
    if size == 1
        scr.put_icn(x, y, BRUSH_1, fg, bg)
    elif size == 2
        scr.put_icn(x, y, BRUSH_2, fg, bg)
    elif size == 3
        scr.put_icn(x, y, BRUSH_3, fg, bg)
    elif size == 4
        scr.put_icn(x, y, BRUSH_4, fg, bg)
    else
        scr.put_icn(x, y, BRUSH_5, fg, bg)
;

-- Home icon (house outline, 2px stroke)
def HOME_TL = [0x03, 0x06, 0x0C, 0x18, 0x30, 0x60, 0xFF, 0xFF]
def HOME_TR = [0xC0, 0x60, 0x30, 0x18, 0x0C, 0x06, 0xFF, 0xFF]
