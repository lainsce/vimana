: clamp_idx(idx = num) (( num ))
    let ?i = idx
    if i < 0
        i = 0
    let max_idx = len(DINGS) - 1
    if i > max_idx
        i = max_idx
    <- i
;

: glyph_ref(glyph_idx = num) (( [any] ))
    let i = clamp_idx(glyph_idx)
    <- DINGS[i] ?? DING_00
;

: row_bits(glyph_idx = num, row_idx = num) (( string ))
    if row_idx < 0
        <- "0000000000000000"
    if row_idx >= DINGS_SRC_H
        <- "0000000000000000"

    let rows = glyph_ref(glyph_idx)
    <- str(rows[row_idx] ?? "0000000000000000")
;

:: pixel_on(glyph_idx = num, x = num, y = num) (( bool ))
    if x < 0 || x >= DINGS_SRC_W || y < 0 || y >= DINGS_SRC_H
        <- false

    let bits = row_bits(glyph_idx, y)
    <- stdr.char_at(bits, x) == "1"
;

: draw_glyph_scaled(
    da = cogito.DrawingArea,
    x = num,
    y = num,
    glyph_idx = num,
    color = string,
    pixel_size = num,
    tile_w = num,
    tile_h = num
) (( -- ))
    if glyph_idx < 0
        <-
    if tile_w <= 0 || tile_h <= 0
        <-

    da.set_color(color)
    let rows = glyph_ref(glyph_idx)
    da.draw_bitmap(x, y, DINGS_SRC_W, DINGS_SRC_H, tile_w, tile_h, rows)
;

:: draw_glyph(
    da = cogito.DrawingArea,
    x = num,
    y = num,
    glyph_idx = num,
    color = string,
    pixel_size = num
) (( -- ))
    let ?s = pixel_size
    if s < 1
        s = 1

    draw_glyph_scaled(
        da,
        x,
        y,
        glyph_idx,
        color,
        s,
        world_model.tile_width(),
        world_model.tile_height()
    )
;

:: draw_glyph_ui(
    da = cogito.DrawingArea,
    x = num,
    y = num,
    glyph_idx = num,
    color = string,
    pixel_size = num
) (( -- ))
    let ?s = pixel_size
    if s < 1
        s = 1

    draw_glyph_scaled(
        da,
        x,
        y,
        glyph_idx,
        color,
        s,
        DINGS_UI_W,
        DINGS_UI_H
    )
;

:: draw_glyph_preview(
    da = cogito.DrawingArea,
    x = num,
    y = num,
    glyph_idx = num,
    color = string,
    pixel_size = num
) (( -- ))
    let ?s = pixel_size
    if s < 1
        s = 1

    draw_glyph_scaled(
        da,
        x,
        y,
        glyph_idx,
        color,
        s,
        12,
        15
    )
;
