def TEXT_GLYPHS = [
    TEXT_00,
    TEXT_01,
    TEXT_02,
    TEXT_03,
    TEXT_04,
    TEXT_05,
    TEXT_06,
    TEXT_07,
    TEXT_08,
    TEXT_09,
    TEXT_10,
    TEXT_11,
    TEXT_12,
    TEXT_13,
