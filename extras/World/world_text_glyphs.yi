    TEXT_49,
    TEXT_50,
    TEXT_51,
    TEXT_52,
    TEXT_53,
    TEXT_54,
    TEXT_55,
    TEXT_56
]

: text_clamp_idx(idx = num) (( num ))
    let ?i = idx
    if i < 0
        i = 0
    let max_idx = len(TEXT_GLYPHS) - 1
    if i > max_idx
        i = max_idx
    <- i
;

: text_glyph_ref(glyph_idx = num) (( [any] ))
    let i = text_clamp_idx(glyph_idx)
    <- TEXT_GLYPHS[i] ?? TEXT_00
;

: draw_text_glyph_scaled(
    da = cogito.DrawingArea,
    x = num,
    y = num,
    glyph_idx = num,
    color = string,
    pixel_size = num,
    tile_w = num,
    tile_h = num
) (( -- ))
    if glyph_idx < 0
        <-
    if tile_w <= 0 || tile_h <= 0
        <-

    da.set_color(color)
    let rows = text_glyph_ref(glyph_idx)
    da.draw_bitmap(x, y, TEXT_SRC_W, TEXT_SRC_H, tile_w, tile_h, rows)
;

:: draw_text_glyph(
    da = cogito.DrawingArea,
    x = num,
    y = num,
    glyph_idx = num,
    color = string,
    pixel_size = num
) (( -- ))
    let ?s = pixel_size
    if s < 1
        s = 1

    draw_text_glyph_scaled(
        da,
        x,
        y,
        glyph_idx,
        color,
        s,
        world_model.tile_width(),
        world_model.tile_height()
    )
;

:: draw_text_glyph_ui(
    da = cogito.DrawingArea,
    x = num,
    y = num,
    glyph_idx = num,
    color = string,
    pixel_size = num
) (( -- ))
    let ?s = pixel_size
    if s < 1
        s = 1

    draw_text_glyph_scaled(
        da,
        x,
        y,
        glyph_idx,
        color,
        s,
        12,
        15
    )
;
