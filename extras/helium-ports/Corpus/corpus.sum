@diagnostics: warn

; ── Base resets ───────────────────────────────────────────────

vstack
hstack
zstack
grid
  background: transparent

content_list
  background: transparent
  border-radius: 0

; ── Sidebar ───────────────────────────────────────────────────

vstack.corpus-sidebar
  min-width: 240
  max-width: 240
  border-right: 1 solid rgba(0, 0, 0, 0.08)

appbar.corpus-sidebar-bar
  background: transparent
  font-size: 28
  font-weight: bold
  font-variation: wdth 125, opsz 20

hstack.corpus-tag-row
  border-radius: 16
  background: rgba(0, 0, 0, 0.04)
  min-height: 44

hstack.corpus-tag-row-selected
  border-radius: 16
  min-height: 44

label.corpus-tag-label
  font-size: 14
  font-weight: 500

; ── Home panel ────────────────────────────────────────────────

vstack.corpus-home
  background: transparent

appbar.corpus-home-bar
  background: transparent

label.corpus-home-title
  font-size: 28
  font-weight: bold
  font-variation: wdth 120, opsz 20

searchfield.corpus-search
  min-width: 180
  max-width: 220
  border-radius: 24

; ── Section labels ────────────────────────────────────────────

label.corpus-section-label
  font-size: 13
  font-weight: 600
  font-variation: wdth 105, opsz 12
  opacity: 0.55

; ── Continue Reading cards ────────────────────────────────────

scroller.corpus-continue-scroll
  min-height: 148

card.corpus-continue-card
  min-width: 180
  max-width: 180
  min-height: 132
  border-radius: 16

; ── Divider indicator ─────────────────────────────────────────

divider.corpus-indicator
  max-width: 40
  min-height: 3
  border-radius: 2
  opacity: 0.2

; ── Recents grid ──────────────────────────────────────────────

grid.corpus-recents-grid
  border-radius: 0

card.corpus-recent-card
  min-height: 180
  border-radius: 12

card.corpus-recent-card-highlight
  min-height: 180
  border-radius: 12

; ── Viewer panel (full page) ──────────────────────────────────

vstack.corpus-viewer
  background: @surface

appbar.corpus-viewer-bar
  background: transparent
  font-variation: wdth 90, opsz 14

image.corpus-page-image
  border-radius: 4
  background: white
  min-height: 400

; ── Zoom controls (floating) ─────────────────────────────────

fab.corpus-zoom-fab
  min-width: 44
  min-height: 44
  border-radius: 14

; ── Page navigation (floating toolbar) ────────────────────────

toolbar.corpus-page-nav
  max-width: 480

label.corpus-page-label
  font-size: 13
  font-weight: 500
  min-width: 48
  font-variation: wdth 90

; ── Buttons & shapes ──────────────────────────────────────────

button
  border-radius: 12

iconbtn
  border-radius: 12

fab
  border-radius: 16

; ── Dark mode overrides ───────────────────────────────────────

@when dark
  vstack.corpus-sidebar
    border-right: 1 solid rgba(255, 255, 255, 0.08)

  hstack.corpus-tag-row
    background: rgba(255, 255, 255, 0.06)

  card.corpus-continue-card
    border: 1 solid rgba(255, 255, 255, 0.08)

  card.corpus-recent-card
    background: rgba(255, 255, 255, 0.06)

  vstack.corpus-zoom-controls
    border: 1 solid rgba(255, 255, 255, 0.06)

  image.corpus-page-image
    background: #1e1e1e
