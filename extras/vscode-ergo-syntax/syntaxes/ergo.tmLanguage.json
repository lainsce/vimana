{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Yis",
  "scopeName": "source.yis",
  "patterns": [
    {
      "include": "#returnSpec"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functionDecl"
    },
    {
      "include": "#typeDecl"
    },
    {
      "include": "#mutableNames"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#types"
    },
    {
      "include": "#memberAccess"
    },
    {
      "include": "#functionCalls"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.yis",
          "match": "--.*$"
        }
      ]
    },
    "returnSpec": {
      "name": "meta.return-spec.yis",
      "begin": "\\(\\(",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.return.begin.yis"
        }
      },
      "end": "\\)\\)",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.return.end.yis"
        }
      },
      "patterns": [
        {
          "name": "keyword.control.return-void.yis",
          "match": "--"
        },
        {
          "name": "punctuation.separator.comma.yis",
          "match": ","
        },
        {
          "include": "#types"
        },
        {
          "include": "#memberAccess"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.interpolated.yis",
          "begin": "@\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.yis"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.yis"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.yis",
              "match": "\\\\(?:[ntr\"\\\\$]|u\\{[0-9A-Fa-f]+\\})"
            },
            {
              "name": "variable.other.interpolated.yis",
              "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
            }
          ]
        },
        {
          "name": "string.quoted.double.yis",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.yis"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.yis"
            }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.yis",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "functionDecl": {
      "patterns": [
        {
          "name": "meta.function.yis",
          "match": "\\b(fun)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.yis"
            },
            "2": {
              "name": "entity.name.function.yis"
            }
          }
        }
      ]
    },
    "typeDecl": {
      "patterns": [
        {
          "name": "meta.type.yis",
          "match": "\\b(class|struct|enum)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.yis"
            },
            "2": {
              "name": "entity.name.type.yis"
            }
          }
        }
      ]
    },
    "mutableNames": {
      "patterns": [
        {
          "name": "variable.other.mutable.yis",
          "match": "\\?[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.yis",
          "match": "\\b(?:if|elif|else|for|in|match|return|new|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.yis",
          "match": "\\b(?:cask|bring|fun|entry|class|struct|enum|pub|lock|seal|def|let|const)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.yis",
          "match": "\\b(?:true|false|null)\\b"
        },
        {
          "name": "constant.other.yis",
          "match": "\\b[A-Z][A-Z0-9_]+\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.yis",
          "match": "\\b(?:num|string|bool|int|float|char|byte|void|any)\\b"
        }
      ]
    },
    "memberAccess": {
      "patterns": [
        {
          "name": "meta.member.access.yis",
          "match": "(\\.)\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.accessor.dot.yis"
            },
            "2": {
              "name": "variable.other.member.yis"
            }
          }
        }
      ]
    },
    "functionCalls": {
      "patterns": [
        {
          "name": "support.function.call.yis",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.yis",
          "match": "(?:\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.comparison.yis",
          "match": "(?:==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.yis",
          "match": "(?:\\?\\?|&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.yis",
          "match": "(?:\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.arrow.yis",
          "match": "=>"
        },
        {
          "name": "keyword.operator.other.yis",
          "match": "(?:\\?|\\|)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.yis",
          "match": "(?:,|;|:)"
        },
        {
          "name": "punctuation.definition.array.yis",
          "match": "(?:\\[|\\])"
        },
        {
          "name": "punctuation.definition.block.yis",
          "match": "(?:\\{|\\})"
        },
        {
          "name": "punctuation.definition.group.yis",
          "match": "(?:\\(|\\))"
        }
      ]
    }
  }
}
