{
  "comments": {
    "lineComment": "--",
    "blockComment": ["--", "--"]
  },
  "brackets": [
    ["((", "))"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    {
      "open": "((",
      "close": "))"
    },
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "@\"",
      "close": "\""
    }
  ],
  "surroundingPairs": [
    ["((", "))"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*\\{\\s*$",
      "end": "^\\s*\\}\\s*$"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^.*[\\{\\[][^}\\]\"']*$",
    "decreaseIndentPattern": "^\\s*[}\\])].*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*\\.[A-Za-z_][A-Za-z0-9_]*\\((?:[^()]|\\([^()]*\\))*\\)\\s*$",
      "action": { "indent": "none" }
    },
    {
      "beforeText": "^\\s*\\)\\s*$",
      "action": { "indent": "none" }
    }
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\^\\&\\*\\(\\)\\=\\+\\[\\{\\]\\}\\|\\;\\:\\\"\\'\\,\\.\\<\\>\\/\\?\\s]+)"
}
