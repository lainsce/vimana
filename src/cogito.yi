pub class AppBar {
    pub fun add_leading_button(this, icon = string, handler = any) (( Button )) {
        __cogito_appbar_add_button(this, icon, handler).set_class("leading")
        return this
    }
    pub fun set_type(this, appbar_type = num) (( AppBar )) {
        if appbar_type == 0 {
            __cogito_node_set_class(this, "search")
        } elif appbar_type == 1 {
            __cogito_node_set_class(this, "small")
        } elif appbar_type == 3 {
            __cogito_node_set_class(this, "large")
        } else {
            __cogito_node_set_class(this, "medium")
        }
        return this
    }
    pub fun set_search(this) (( AppBar )) {
        return this.set_type(0)
    }
    pub fun set_small(this) (( AppBar )) {
        return this.set_type(1)
    }
    pub fun set_medium(this) (( AppBar )) {
        return this.set_type(2)
    }
    pub fun set_large(this) (( AppBar )) {
        return this.set_type(3)
    }
    pub fun add_trailing_button(this, icon = string, handler = any) (( Button )) {
        __cogito_appbar_add_button(this, icon, handler).set_class("trailing")
        return this
    }
    pub fun pair_with_scroller(this, scroller = Scroller) (( AppBar )) {
        __cogito_appbar_pair_scroller(this, scroller)
        return this
    }
    pub fun set_window_controls(this, layout = string) (( AppBar )) {
        __cogito_appbar_set_controls(this, layout)
        return this
    }
    pub fun set_title(this, title = string) (( AppBar )) {
        __cogito_appbar_set_title(this, title)
        return this
    }
    pub fun set_title_widget(this, widget = any) (( AppBar )) {
        __cogito_node_set_class(widget, "appbar-title")
        __cogito_container_add(this, widget)
        return this
    }
    pub fun set_subtitle(this, subtitle = string) (( AppBar )) {
        __cogito_appbar_set_subtitle(this, subtitle)
        return this
    }
    pub fun set_hexpand(this, expand = bool) (( AppBar )) {
        __cogito_container_set_hexpand(this, expand)
        return this
    }
    pub fun set_vexpand(this, expand = bool) (( AppBar )) {
        __cogito_container_set_vexpand(this, expand)
        return this
    }

    pub fun set_disabled(this, on = bool) (( AppBar )) {
        __cogito_node_set_disabled(this, on)
        return this
    }
    pub fun set_visible(this, on = bool) (( AppBar )) {
        __cogito_node_set_visible(this, on)
        return this
    }
    pub fun set_class(this, cls = string) (( AppBar )) {
        __cogito_node_set_class(this, cls)
        return this
    }
    pub fun set_id(this, id = string) (( AppBar )) {
        __cogito_node_set_id(this, id)
        return this
    }
}

