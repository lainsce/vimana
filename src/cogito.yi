pub class AppBar {
    :: add_leading_button(this, icon = string, handler = any) (( AppBar )) {
        __cogito_appbar_add_button(this, icon, handler).set_class("appbar-leading")
        return this
    }
    :: set_type(this, appbar_type = num) (( AppBar )) {
        if appbar_type == 0 {
            __cogito_node_set_class(this, "search")
        } elif appbar_type == 1 {
            __cogito_node_set_class(this, "small")
        } elif appbar_type == 3 {
            __cogito_node_set_class(this, "large")
        } else {
            __cogito_node_set_class(this, "medium")
        }
        return this
    }
    :: set_search(this) (( AppBar )) {
        return this.set_type(0)
    }
    :: set_small(this) (( AppBar )) {
        return this.set_type(1)
    }
    :: set_medium(this) (( AppBar )) {
        return this.set_type(2)
    }
    :: set_large(this) (( AppBar )) {
        return this.set_type(3)
    }
    :: add_trailing_button(this, icon = string, handler = any) (( AppBar )) {
        __cogito_appbar_add_button(this, icon, handler).set_class("trailing")
        return this
    }
    :: leading_button(this, icon = string, handler = any) (( Button )) {
        return __cogito_appbar_add_button(this, icon, handler).set_class("appbar-leading")
    }
    :: add_trailing_menu_button(this, icon = string) (( Button )) {
        return __cogito_appbar_add_button(this, icon, null).set_class("trailing")
    }
    :: pair_with_scroller(this, scroller = Scroller) (( AppBar )) {
        __cogito_appbar_pair_scroller(this, scroller)
        return this
    }
    :: set_window_controls(this, layout = string) (( AppBar )) {
        __cogito_appbar_set_controls(this, layout)
        return this
    }
    :: set_title(this, title = string) (( AppBar )) {
        __cogito_appbar_set_title(this, title)
        return this
    }
    :: set_title_widget(this, widget = any) (( AppBar )) {
        __cogito_node_set_class(widget, "appbar-title")
        __cogito_container_add(this, widget)
        return this
    }
    :: set_subtitle(this, subtitle = string) (( AppBar )) {
        __cogito_appbar_set_subtitle(this, subtitle)
        return this
    }
    :: set_hexpand(this, expand = bool) (( AppBar )) {
        __cogito_container_set_hexpand(this, expand)
        return this
    }
    :: set_vexpand(this, expand = bool) (( AppBar )) {
        __cogito_container_set_vexpand(this, expand)
        return this
    }

    :: set_disabled(this, on = bool) (( AppBar )) {
        __cogito_node_set_disabled(this, on)
        return this
    }
    :: set_visible(this, on = bool) (( AppBar )) {
        __cogito_node_set_visible(this, on)
        return this
    }
    :: set_class(this, cls = string) (( AppBar )) {
        __cogito_node_set_class(this, cls)
        return this
    }
    :: set_id(this, id = string) (( AppBar )) {
        __cogito_node_set_id(this, id)
        return this
    }
}

