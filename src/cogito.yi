pub ,: Clipper : Shape
    :: add(this, child = any) (( Clipper ))
        __cogito_container_add(this, child)
        <- this
    ;
    :: set_frame(this, width = any, height = any, radius = any) (( Clipper ))
        let ?w = clipper_num_or(width, 1)
        let ?h = clipper_num_or(height, 1)
        let ?r = clipper_num_or(radius, 0)
        if w < 1
            w = 1
        if h < 1
            h = 1

        __cogito_shape_set_size(this, w)
        __cogito_shape_set_size_h(this, h)
        __cogito_shape_set_color(this, "transparent")
        __cogito_shape_set_clip(this, true)
        clipper_apply_round_rect(this, w, h, r)
        <- this
    ;
    :: set_radius(this, radius = any, width = any, height = any) (( Clipper ))
        let ?w = width
        let ?h = height
        let ?r = clipper_num_or(radius, 0)

        if is_null(w)
            w = __cogito_shape_get_size(this)
        if is_null(h)
            h = w

        w = clipper_num_or(w, 1)
        h = clipper_num_or(h, w)
        if w < 1
            w = 1
        if h < 1
            h = 1

        clipper_apply_round_rect(this, w, h, r)
        <- this
    ;
    :: set_clip(this, on = bool) (( Clipper ))
        __cogito_shape_set_clip(this, on)
        <- this
    ;
    :: set_margins(this, top = num, right = num, bottom = num, left = num) (( Clipper ))
        __cogito_container_set_margins(this, top, right, bottom, left)
        <- this
    ;
    :: set_padding(this, top = num, right = num, bottom = num, left = num) (( Clipper ))
        __cogito_container_set_padding(this, top, right, bottom, left)
        <- this
    ;
    :: set_hexpand(this, expand = bool) (( Clipper ))
        __cogito_container_set_hexpand(this, expand)
        <- this
    ;
    :: set_vexpand(this, expand = bool) (( Clipper ))
        __cogito_container_set_vexpand(this, expand)
        <- this
    ;
    :: set_visible(this, on = bool) (( Clipper ))
        __cogito_node_set_visible(this, on)
        <- this
    ;
    :: set_class(this, cls = string) (( Clipper ))
        __cogito_node_set_class(this, cls)
        <- this
    ;
    :: set_id(this, id = string) (( Clipper ))
        __cogito_node_set_id(this, id)
        <- this
