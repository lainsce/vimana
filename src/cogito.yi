        return this.chain()
    }
    :: set_dark_mode(this, dark = bool, follow_system = bool) (( App )) {
        __cogito_app_set_dark_mode(this, dark, follow_system)
        return this.chain()
    }
    :: set_accent_from_image(this, path = string, follow_system = bool) (( string )) {
        let out = __cogito_app_set_accent_from_image(this, path, follow_system)
        return if is_null(out) { "" } else { str(out) }
    }
    :: set_ensor_variant(this, variant = num) (( App )) {
        __cogito_app_set_ensor_variant(this, variant)
        return this
    }
    :: set_contrast(this, contrast = num) (( App )) {
        __cogito_app_set_contrast(this, contrast)
        return this
    }
    :: set_icon(this, path = string) (( App )) {
        __cogito_app_set_icon(this, path)
        return this
    }
    :: set_baseline_font(this, path = string) (( App )) {
        __cogito_app_set_baseline_font(this, path)
        return this
    }
    :: set_emphasized_font(this, path = string) (( App )) {
        __cogito_app_set_emphasized_font(this, path)
        return this
    }
    :: get_icon(this) (( string )) {
        return __cogito_app_get_icon(this)
    }
    :: copy_to_clipboard(this, text = string) (( bool )) {
        return __cogito_app_copy_to_clipboard(this, text)
    }
}

