pub class App {
    pub fun run(this, win = Window) (( App )) {
        __cogito_run(this, win)
        return this
    }
    pub fun set_appid(this, id = string) (( App )) {
        __cogito_app_set_appid(this, id)
        return this.chain()
    }
    pub fun set_app_name(this, name = string) (( App )) {
        __cogito_app_set_app_name(this, name)
        return this.chain()
    }
    pub fun set_accent_color(this, color = string, follow_system = bool) (( App )) {
        __cogito_app_set_accent_color(this, color, follow_system)
        return this.chain()
    }
    pub fun set_dark_mode(this, dark = bool, follow_system = bool) (( App )) {
        __cogito_app_set_dark_mode(this, dark, follow_system)
        return this.chain()
    }
    pub fun set_accent_from_image(this, path = string, follow_system = bool) (( string )) {
        let out = __cogito_app_set_accent_from_image(this, path, follow_system)
        return if is_null(out) { "" } else { str(out) }
    }
    pub fun set_ensor_variant(this, variant = num) (( App )) {
        __cogito_app_set_ensor_variant(this, variant)
        return this
    }
    pub fun set_contrast(this, contrast = num) (( App )) {
        __cogito_app_set_contrast(this, contrast)
        return this
    }
    pub fun set_icon(this, path = string) (( App )) {
        __cogito_app_set_icon(this, path)
        return this
    }
    pub fun get_icon(this) (( string )) {
        return __cogito_app_get_icon(this)
    }
    pub fun copy_to_clipboard(this, text = string) (( bool )) {
        return __cogito_app_copy_to_clipboard(this, text)
    }
}

