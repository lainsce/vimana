cask cogito

bring stdr

-- Cogito GUI module (minimal, container-based)

!: chain() (( any ))
    this
;

-- Key scancode constants (SDL2 values, passed to on_key callback)
pub :: KEY_RETURN     (( num )) <- 40 ;
pub :: KEY_BACKSPACE  (( num )) <- 42 ;
pub :: KEY_TAB        (( num )) <- 43 ;
pub :: KEY_HOME       (( num )) <- 74 ;
pub :: KEY_DELETE     (( num )) <- 76 ;
pub :: KEY_END        (( num )) <- 77 ;
pub :: KEY_RIGHT      (( num )) <- 79 ;
pub :: KEY_LEFT       (( num )) <- 80 ;
pub :: KEY_DOWN       (( num )) <- 81 ;
pub :: KEY_UP         (( num )) <- 82 ;
pub :: KEY_KP_ENTER   (( num )) <- 88 ;

