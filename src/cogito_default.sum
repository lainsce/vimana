; Cogito default theme (light)
; Generated with primary #72dec2
@diagnostics: warn

; Primary palette
@primary: #72dec2
@on-primary: #00382b
@primary-container: #c8f7ef
@on-primary-container: #00201a

; Secondary palette
@secondary: #4a9e8f
@on-secondary: #ffffff
@secondary-container: #c8f7ef
@on-secondary-container: #00201a

; Tertiary palette
@tertiary: #3d6463
@on-tertiary: #ffffff
@tertiary-container: #c8f7ef
@on-tertiary-container: #00201a

; Error palette
@error: #ba1a1a
@on-error: #ffffff
@error-container: #ffdad6
@on-error-container: #410002

; Neutral palette
@background: #fafdfb
@on-background: #191c1a
@surface: #fafdfb
@surface-tint: #72dec229
@on-surface: #191c1a

; Surface containers
@surface-dim: #d9dbd9
@surface-bright: #fafff8
@surface-container-lowest: #ffffff
@surface-container-low: #f3f7f4
@surface-container: #eff5f2
@surface-container-high: #e8ebe9
@surface-container-highest: #e2e5e3

; Surface variant
@surface-variant: #dbe5e1
@on-surface-variant: #3f4946

; Outline
@outline: #6f7975
@outline-variant: #bec9c4

; Inverse colors
@inverse-surface: #2d312f
@inverse-on-surface: #f0f1ef
@inverse-primary: #84e8d0

; Shadow & Scrim
@shadow: #000000
@scrim: #000000

*
  color: @on-surface
  font-size: 14

; Surface color tokens
.surface
  background: @surface
  color: @on-surface

.surface-container-high
  background: @surface-container-high
  color: @on-surface

.surface-container-highest
  background: @surface-container-highest
  color: @on-surface

.surface-container-low
  background: @surface-container-low
  color: @on-surface

.surface-container-lowest
  background: @surface-container-lowest
  color: @on-surface

.surface-container
  background: @surface-container
  color: @on-surface

.surface-bright
  background: @surface-bright
  color: @on-surface

.surface-dim
  background: @surface-dim
  color: @on-surface

.surface-variant
  background: @surface-variant
  color: @on-surface-variant

; Inverse color tokens
.inverse-primary
  color: @inverse-primary

.inverse-primary-fill
  background: @inverse-primary
  color: @primary

.inverse-surface
  background: @inverse-surface
  color: @inverse-on-surface

.on-inverse-surface
  background: @inverse-on-surface
  color: @inverse-surface

; Error color tokens
.error
  background: @error
  color: @on-error

.on-error
  background: @on-error
  color: @error

.error-container
  background: @error-container
  color: @on-error-container

.on-error-container
  background: @on-error-container
  color: @error-container

; Primary color tokens
.primary
  background: @primary
  color: @on-primary

.on-primary
  background: @on-primary
  color: @primary

.primary-container
  background: @primary-container
  color: @on-primary-container

.on-primary-container
  background: @on-primary-container
  color: @primary-container

.secondary
  background: @secondary
  color: @on-secondary

.on-secondary
  background: @on-secondary
  color: @secondary

.secondary-container
  background: @secondary-container
  color: @on-secondary-container

.on-secondary-container
  background: @on-secondary-container
  color: @secondary-container

.tertiary
  background: @tertiary
  color: @on-tertiary

.on-tertiary
  background: @on-tertiary
  color: @tertiary

.tertiary-container
  background: @tertiary-container
  color: @on-tertiary-container

.on-tertiary-container
  background: @on-tertiary-container
  color: @tertiary-container

; On-surface tokens
.on-surface
  background: @on-surface
  color: @surface

.on-surface-variant
  background: @on-surface-variant
  color: @surface-variant

; Outline tokens
.outline
  border-color: @outline

.outline-variant
  border-color: @outline-variant

.outline-fill
  background: @outline
  color: @surface

.outline-variant-fill
  background: @outline-variant
  color: @surface

; Shadow & scrim
.scrim
  background: @scrim

.shadow
  background: @scrim

; Typography
.big-display
  color: @on-surface
  font-family: serif
  font-size: 56
  font-weight: normal

.display
  color: @on-surface
  font-family: serif
  font-size: 36
  font-weight: normal

.view-title
  color: @on-surface
  font-size: 24
  font-weight: normal

.view-subtitle
  color: @on-surface
  font-size: 18
  font-weight: bold

.heading
  color: @on-surface
  font-size: 16
  font-weight: normal

.content-title
  color: @on-surface
  font-size: 16
  font-weight: bold

.content-subtitle
  color: @on-surface
  font-size: 14
  font-weight: normal

.title
  color: @on-surface
  font-size: 24
  font-weight: normal

.subtitle
  color: @on-surface
  font-size: 18
  font-weight: bold

.body
  color: @on-surface
  font-size: 14
  font-weight: normal

.caption
  color: @on-surface
  font-size: 12
  font-weight: bold

.tabular
  font-variant-numeric: tnum

.monospace
  font-variant-monospace: monospace

; Widget styles (alphabetical order)
about_window
  background: @surface-container-high
  color: @on-surface
  border-radius: 26
  padding: 24

active_indicator
  color: @primary

appbar
  background: @background
  color: @on-surface

appbar .iconbtn
  background: transparent

appbar .window-close
  background: @error

appbar .window-close:hover
  background: @outline-variant

appbar .window-close:active
  background: @error

appbar .window-max
  background: @secondary

appbar .window-max:hover
  background: @secondary

appbar .window-max:active
  background: @tertiary

appbar .window-min
  background: @outline-variant

appbar .window-min:hover
  background: @error-container

appbar .window-min:active
  background: @outline

appbar.sidebar
  background: @surface-container-high
  color: @on-surface

appbar.view
  background: @background
  color: @on-surface

avatar
  background: @secondary-container
  color: @on-secondary-container
  min-width: 64
  min-height: 64

badge
  background: @error
  color: @on-error
  font-size: 11
  min-width: 10
  min-height: 10

banner
  background: @secondary-container
  color: @on-secondary-container
  padding: 16
  min-height: 52

banner:selection
  color: @primary

bottom_sheet
  background: @surface-container-low
  color: @on-surface
  border-radius: 28 28 0 0
  padding: 16

bottom-nav
  background: @on-secondary
  color: @on-surface
  min-height: 80
  padding: 0 8

bottom-nav:selection
  background: @surface-container-high
  color: @on-surface

bottom-sheet
  background: @surface-container-low
  color: @on-surface
  border-radius: 28 28 0 0
  padding: 16

button
  background: @primary
  color: @on-primary

button:hover
  background: alpha(@primary, 8%)

button:active
  background: alpha(@primary, 11%)

button.outlined
  background: transparent
  color: @primary
  border: 1 solid @outline

button.outlined:hover
  background: alpha(@primary, 8%)

button.outlined:active
  background: alpha(@primary, 11%)

button.outlined:disabled
  color: alpha(@on-surface, 32%)
  border-color: alpha(@on-surface, 32%)
  background: transparent

button.text
  background: transparent
  color: @primary

button.text:hover
  background: alpha(@primary, 8%)

button.text:active
  background: alpha(@primary, 11%)

button.text:disabled
  color: alpha(@on-surface, 32%)
  background: transparent

button.error
  color: @error
  border-color: @error

button.error:hover
  background: alpha(@error, 8%)

button.error:active
  background: alpha(@error, 11%)

button.error:disabled
  color: alpha(@on-surface, 32%)
  border-color: alpha(@on-surface, 32%)
  background: transparent

button.card-action
  background: transparent
  color: @primary

button.card-action:hover
  background: alpha(@primary, 8%)

button.card-action:active
  background: alpha(@primary, 11%)

button.card-action:disabled
  color: alpha(@on-surface, 32%)
  background: transparent

button:disabled
  background: alpha(@on-surface, 18%)
  color: alpha(@on-surface, 32%)

button:focus
  border: 2 solid @primary

button.toolbar_format
  background: transparent
  color: @primary
  border-radius: 100
  min-width: 48
  min-height: 48
  padding: 0 8
  box-shadow: none

button.toolbar_format:hover
  background: alpha(@primary, 8%)

button.toolbar_format:active
  background: alpha(@primary, 11%)

button.toolbar_format_active
  background: @primary
  color: @on-primary
  border-radius: 100
  min-width: 48
  min-height: 48
  padding: 0 8
  box-shadow: none

button.toolbar_format_active:hover
  background: alpha(@primary, 8%)

button.toolbar_format_active:active
  background: alpha(@primary, 11%)

@when reduced-motion
  button
    transition: 0 linear
  iconbtn
    transition: 0 linear

card
  background: @surface-container-low
  color: @on-surface
  border-radius: 16
  padding: 16

card.elevated
  background: @surface-container-low
  elevation: 1

card.filled
  background: @surface-container-highest
  elevation: 0

card.outlined
  background: @surface
  border: 1 solid @outline
  elevation: 0

carousel
  background: transparent
  color: @on-surface
  min-height: 240
  min-width: 360
  border-radius: 26

carousel_item
  background: @primary-container
  color: @on-surface
  border-radius: 26
  padding: 16

checkbox
  color: @on-surface
  min-height: 24
  min-width: 24

checkbox .box
  background: transparent
  border-radius: 4
  border: 2 solid @on-surface-variant

checkbox .box:hover
  background: @primary

checkbox .box:active
  background: @primary

checkbox .check
  color: @on-surface

checkbox .check:hover
  color: @on-surface

checkbox .check:active
  color: @shadow

checkbox:checked
  background: @primary

checkbox:checked .box
  background: @primary
  border: 0 none @primary

checkbox:checked .check
  color: @on-primary

checkbox:disabled
  color: alpha(@on-surface, 32%)

chip
  background: transparent
  color: @on-surface
  border-radius: 100
  min-height: 32
  padding: 0 16
  border: 1 solid @outline

chip:hover
  background: alpha(@on-surface, 8%)

chip:active
  background: alpha(@on-surface, 11%)

chip:checked
  background: @primary-container
  color: @on-primary
  border: 0 none @primary-container

chip:disabled
  background: alpha(@on-surface, 18%)
  color: alpha(@on-surface, 32%)
  border-color: alpha(@on-surface, 32%)

content_list
  background: @surface-variant
  color: @on-surface
  padding: 0 16
  min-height: 80

content_list label
  background: transparent

content_list=first
  border-radius: 12 12 8 8

content_list=last
  border-radius: 8 8 12 12

content_list=middle
  border-radius: 8

content_list=single
  border-radius: 12

datepicker
  background: @on-secondary
  border-radius: 18
  min-width: 360
  padding: 16
  box-shadow: [
    0 1 3 0 alpha(@shadow, 12%)
  ]

datepicker:selection
  background: @primary

dialog
  background: @surface-container-high
  color: @on-surface
  border-radius: 28
  min-width: 280
  max-width: 560
  min-height: 240
  padding: 24
  box-shadow: [
    0 8 16 0 alpha(@shadow, 24%)
  ]

dialog vstack
  background: @surface-container-high
  color: @on-surface

dialog hstack
  background: @surface-container-high
  color: @on-surface

dialog zstack
  background: @surface-container-high
  color: @on-surface

dialog fixed
  background: @surface-container-high
  color: @on-surface

dialogslot
  background: alpha(@scrim, 32%)
  color: @on-surface

divider
  background: @outline-variant
  min-height: 1

dropdown
  background: @surface-container-high
  color: @on-surface
  border-radius: 4 4 0 0
  min-height: 56
  padding: 8 16

dropdown:hover
  background: @surface-container-high

dropdown:disabled
  background: alpha(@on-surface, 18%)
  color: alpha(@on-surface, 32%)

empty_page
  background: transparent
  color: @on-surface

fab
  elevation: 3

fab:hover
  background: alpha(@primary, 8%)

fab:active
  background: alpha(@primary, 11%)

fab:disabled
  background: alpha(@on-surface, 18%)
  color: alpha(@on-surface, 32%)

fixed
  background: transparent
  color: @on-surface

grid
  background: @on-secondary
  border-radius: 8
  color: @on-surface

grid:selection
  background: @primary

hstack
  background: @background
  color: @on-surface

iconbtn
  background: alpha(@shadow, 5%)
  color: @on-surface

iconbtn:hover
  background: alpha(@on-surface, 8%)

iconbtn:active
  background: alpha(@on-surface, 11%)

iconbtn:disabled
  background: alpha(@on-surface, 18%)
  color: alpha(@on-surface, 32%)

iconbtn.filled
  background: @primary
  color: @on-primary

iconbtn.filled:hover
  background: alpha(@primary, 8%)

iconbtn.filled:active
  background: alpha(@primary, 11%)

iconbtn.iconic
  background: transparent
  color: @primary

iconbtn.iconic:hover
  background: alpha(@primary, 8%)

iconbtn.iconic:active
  background: alpha(@primary, 11%)

iconbtn.iconic:disabled
  background: transparent
  color: alpha(@on-surface, 32%)

iconbtn.outlined
  background: transparent
  color: @on-surface-variant
  border: 1 solid @outline

iconbtn.outlined:hover
  background: alpha(@on-surface-variant, 8%)

iconbtn.outlined:active
  background: alpha(@on-surface-variant, 11%)

iconbtn.tonal
  background: @primary-container
  color: @on-primary-container

iconbtn.tonal:hover
  background: alpha(@primary-container, 8%)

iconbtn.tonal:active
  background: alpha(@primary-container, 11%)

image
  background: transparent

label
  color: @on-surface
  padding: 8

label.carousel-item-label
  font-size: 21
  font-weight: bold
  color: @on-secondary
  box-shadow: [ 0 2 4 0 alpha(@shadow, 14%) ]

list
  background: @on-secondary
  color: @on-surface

list:selection
  background: @primary

menu
  background: @on-secondary
  border-radius: 4
  color: @on-surface
  box-shadow: 2
  font-size: 14

menu item
  border-radius: 0
  padding: 8 12
  min-height: 42

menu:selection
  background: @primary

menu_button
  background: transparent
  color: @on-surface
  padding: 8 12

menu_button:hover
  background: alpha(@on-surface, 8%)

menu_button:active
  background: alpha(@on-surface, 11%)

menu_button:checked
  background: @secondary-container
  color: @on-secondary-container

nav-rail
  background: @surface
  color: @on-surface
  min-width: 96
  padding: 4 0

nav-rail:selection
  background: @surface-container-high
  color: @on-surface

popover
  background: @on-secondary
  border-radius: 12
  padding: 16
  box-shadow: [
    0 2 8 0 alpha(@shadow, 12%)
  ]

progress
  background: @surface-dim
  border-radius: 100
  track-height: 4
  min-height: 12
  min-width: 120

progress:selection
  background: @primary

radio
  color: @on-surface
  min-height: 24
  min-width: 24

radio .box
  background: transparent
  border-radius: 100
  border: 2 solid @on-surface-variant

radio .box:hover
  border-color: @on-surface

radio .box:active
  border-color: @primary

radio .check
  color: @on-surface

radio .check:hover
  color: @on-surface-variant

radio .check:active
  color: @primary

radio:checked
  background: @primary

radio:checked .box
  background: @primary
  border: 0 none @primary

radio:checked .check
  color: @on-primary

radio:disabled
  color: alpha(@on-surface, 32%)

scroller
  background: @surface-container-low
  color: @on-surface
  padding: 0

scroller.sidebar
  background: @surface-container-high
  color: @on-surface

searchfield
  background: @surface-container-high
  color: @on-surface
  border-radius: 999
  min-height: 56
  min-width: 180
  padding: 8 16

searchfield:hover
  background: @surface-container-high

searchfield:active
  border-color: @outline
  border-width: 2

searchfield:focus
  border: 2 solid @primary

searchfield:disabled
  background: alpha(@on-surface, 18%)
  color: alpha(@on-surface, 32%)

searchfield:selection
  background: @primary

side-sheet
  background: @surface-container-low
  color: @on-surface
  border-radius: 16 0 0 16
  padding: 16 24 24 24

side-sheet.modal
  background: @surface-container-low
  color: @on-surface
  border-radius: 16 0 0 16
  padding: 24 24 24 24

side-sheet.inset
  background: @surface-container-low
  color: @on-surface
  border-radius: 16
  padding: 16 24 24 24

side-sheet.sidebar
  background: @surface-container-high
  color: @on-surface
  border-radius: 0
  border: 1 solid @outline
  padding: 24 24 24 24

slider
  background: @surface-variant
  color: @primary
  track-height: 4
  min-height: 48
  min-width: 360

slider:disabled
  color: alpha(@on-surface, 32%)

split_button
  background: @primary
  color: @on-primary

split_button:hover
  background: alpha(@primary, 8%)

split_button:active
  background: alpha(@primary, 11%)

stepper
  background: @surface-container-low
  color: @on-surface
  border-radius: 8
  min-height: 32
  min-width: 96

stepper:hover
  background: alpha(@surface-container-low, 8%)

stepper:active
  background: alpha(@surface-container-low, 11%)

stepper:disabled
  background: alpha(@on-surface, 18%)
  color: alpha(@on-surface, 32%)

switch
  color: @on-surface
  min-height: 28
  min-width: 64

switch track
  background: @surface-container-highest
  border: 2 solid @outline

switch track:hover
  background: @outline

switch track:active
  background: @primary

switch:checked track
  background: @primary
  border: 0 none @primary

switch knob
  background: @on-secondary
  min-width: 32
  min-height: 24

switch knob:hover
  background: @surface-container-low

switch knob:active
  background: @surface-container-high

switch .track
  background: @surface-container-highest
  border: 2 solid @outline

switch .track:hover
  background: @outline

switch .track:active
  background: @primary

switch:checked .track
  background: @primary
  border: 0 none @primary

switch .knob
  background: @on-secondary
  min-width: 32
  min-height: 24

switch .knob:hover
  background: @surface-container-low

switch .knob:active
  background: @surface-container-high

switch .knob:checked
  background: @surface

switch:disabled
  color: alpha(@on-surface, 32%)

switch:disabled track
  background: alpha(@on-surface, 18%)

switch:disabled knob
  background: alpha(@on-surface, 18%)

switchbar
  background: @surface
  color: @on-surface
  border: 1 solid @outline
  border-radius: 12
  min-height: 56

tabs
  background: @inverse-on-surface
  color: @on-surface
  border-radius: 10
  min-height: 42

tabs:selection
  background: @on-secondary

textfield
  background: @surface-container-high
  color: @on-surface
  border-radius: 4 4 0 0
  border: 0 none @shadow
  min-height: 56
  padding: 8 16

textfield:hover
  background: @surface-container-high

textfield:focus
  border: 2 solid @primary

textfield:disabled
  background: alpha(@on-surface, 18%)
  color: alpha(@on-surface, 32%)

textfield:selection
  background: @primary

textfield.outlined
  background: transparent
  color: @on-surface
  border: 1 solid @outline
  border-radius: 4
  min-height: 56
  padding: 8 16

textfield.outlined:hover
  background: transparent
  border-color: @on-surface

textfield.outlined:focus
  background: transparent
  border: 2 solid @primary

textfield.outlined:disabled
  background: transparent
  color: alpha(@on-surface, 32%)
  border-color: alpha(@on-surface, 32%)

textview
  background: @surface-container-low
  color: @on-surface
  border-radius: 8
  min-height: 96

textview:focus
  border: 2 solid @primary

textview:selection
  background: @primary

timepicker
  background: @surface-container
  color: @on-surface
  border: 1 solid @outline
  border-radius: 8
  min-height: 56
  min-width: 220

timepicker:hover
  background: @surface-variant

timepicker:selection
  background: @primary

tip_view
  background: @secondary-container
  color: @on-secondary-container
  border-radius: 8
  padding: 12

toast
  background: @on-background
  color: @on-secondary
  border-radius: 10
  min-height: 34

toast:selection
  background: @primary

toasts
  padding: 8 16

toolbar
  background: @inverse-on-surface
  color: @on-surface
  min-height: 64
  padding: 8 16

toolbar.floating
  border-radius: 999
  elevation: 1
  padding: 8

toolbar.floating_compact
  border-radius: 999
  elevation: 1
  padding: 8

tooltip
  background: @on-background
  color: @on-secondary
  border-radius: 6
  font-size: 14
  padding: 8

treeview
  background: @surface-container-low
  color: @on-surface
  border-radius: 8
  min-height: 180
  min-width: 360
  padding: 8

view_chooser
  background: @surface
  color: @on-surface
  border-radius: 8
  min-height: 48

view_dual
  background: @surface

view_switcher
  background: @surface
  color: @on-surface

viewswitcher
  background: @on-secondary
  color: @on-surface

vstack
  background: @background
  color: @on-surface

vstack.sidebar
  background: @surface-container-high
  color: @on-surface

welcome_screen
  background: @background
  color: @on-surface

window
  background: @surface

zstack
  background: @background
  color: @on-surface

dialog vstack
  background: @surface-container-high
  color: @on-surface

dialog hstack
  background: @surface-container-high
  color: @on-surface

dialog zstack
  background: @surface-container-high
  color: @on-surface

dialog fixed
  background: @surface-container-high
  color: @on-surface

; About window styles
.about-window
  background: @on-secondary
  color: @on-surface

label.about-window-title
  color: @on-surface
  font-size: 28
  font-weight: bold

label.about-window-license
  color: @outline
  font-size: 14

hstack.about-window-actions
  background: transparent
  padding: 4 0 0 0

image.about-window-icon
  min-width: 128
  min-height: 128

; Color picker
colorpicker
  background: @on-secondary
  color: @on-surface
  border-radius: 18
  min-width: 360
  padding: 16

colorpicker:selection
  background: @primary

; Datepicker classes
.datepicker
  background: @on-secondary
  color: @on-surface
  border-radius: 18
  min-width: 360
  padding: 16

.datepicker:selection
  background: @primary

; Textfield/textview classes
.textfield:selection
  background: @primary

.textview:selection
  background: @primary

; Button group
buttongroup
  background: @secondary-container
  color: @on-secondary-container

buttongroup:hover
  background: alpha(@secondary-container, 8%)

buttongroup:active
  background: alpha(@secondary-container, 11%)

buttongroup:selection
  background: @secondary-container
  color: @on-secondary-container
  border: 1 solid @secondary-container

buttongroup:disabled
  background: alpha(@on-surface, 18%)
  color: alpha(@on-surface, 32%)

; Settings styles
settings_list
  background: @surface
  color: @on-surface
  border-radius: 12

settings_page
  background: @background
  color: @on-surface

settings_row
  background: transparent
  color: @on-surface
  min-height: 56
  padding: 8 16

settings_window
  background: @background
  color: @on-surface

; Menu section
menu_section
  background: transparent

menu_section item
  border-radius: 0
  padding: 8 12
  min-height: 42

; Switch knob checked states
switch .knob:checked
  background: @surface

switch knob:checked
  background: @surface

; FAB menu
fab-menu
  elevation: 2

; Keyboard focus ring
button:focus, button.text:focus, button.outlined:focus, iconbtn:focus, fab:focus, chip:focus, checkbox:focus, radio:focus, slider:focus, stepper:focus, buttongroup:focus, dropdown:focus, datepicker:focus, colorpicker:focus, nav-rail:focus, bottom-nav:focus
  border: 2 solid @primary

; Appbar window button
appbar .window-button
  min-width: 14
